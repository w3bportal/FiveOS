<Application x:Class="FiveOS.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:FiveOS.Converters"
             xmlns:vm="clr-namespace:FiveOS.ViewModels"
             xmlns:views="clr-namespace:FiveOS.Views"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══════════════════════════════════════════════════════════
                 VS Code Dark+ theme overrides.
                 Flat panels, neutral grays, VS blue accent. These keys are
                 the same wpf-ui Fluent uses internally — overriding them after
                 the merged dictionaries re-skins every templated control
                 without forking templates.
                 ═══════════════════════════════════════════════════════════ -->
            <CornerRadius x:Key="ControlCornerRadius">3</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">4</CornerRadius>

            <!-- Color tokens — VS Code Dark+ (editor / sidebar / panel tiers).
                 Kept as Color so we can derive brushes / gradient stops. -->
            <Color x:Key="C4DAppBgColor">#FF1E1E1E</Color>       <!-- editor.background -->
            <Color x:Key="C4DPanelColor">#FF252526</Color>       <!-- sideBar.background -->
            <Color x:Key="C4DPanelDeepColor">#FF181818</Color>   <!-- panel.background -->
            <Color x:Key="C4DPanelRaisedColor">#FF37373D</Color> <!-- list.inactiveSelectionBackground -->
            <Color x:Key="C4DBorderColor">#FF454545</Color>      <!-- widget.border -->
            <Color x:Key="C4DHoverColor">#FF2A2D2E</Color>       <!-- list.hoverBackground -->
            <Color x:Key="C4DAccentColor">#FF007ACC</Color>      <!-- focusBorder / activityBarBadge -->
            <Color x:Key="C4DAccentDeepColor">#FF1177BB</Color>  <!-- button.hoverBackground -->
            <Color x:Key="C4DAccentSoftColor">#33007ACC</Color>  <!-- translucent accent wash -->
            <Color x:Key="C4DTextPrimaryColor">#FFCCCCCC</Color>
            <Color x:Key="C4DTextSecondaryColor">#FF858585</Color>
            <Color x:Key="C4DTextDimColor">#FF656565</Color>
            <Color x:Key="C4DWarnColor">#FFCCA700</Color>
            <Color x:Key="C4DInputBgColor">#FF3C3C3C</Color>    <!-- input.background -->
            <Color x:Key="C4DLinkColor">#FF3794FF</Color>        <!-- textLink.foreground -->
            <Color x:Key="C4DSelectionColor">#FF094771</Color>  <!-- list.activeSelectionBackground -->

            <!-- Brushes derived from the tokens above. -->
            <SolidColorBrush x:Key="C4DAppBgBrush"        Color="{StaticResource C4DAppBgColor}" />
            <SolidColorBrush x:Key="C4DPanelBrush"        Color="{StaticResource C4DPanelColor}" />
            <SolidColorBrush x:Key="C4DPanelDeepBrush"    Color="{StaticResource C4DPanelDeepColor}" />
            <SolidColorBrush x:Key="C4DPanelRaisedBrush"  Color="{StaticResource C4DPanelRaisedColor}" />
            <SolidColorBrush x:Key="C4DBorderBrush"       Color="{StaticResource C4DBorderColor}" />
            <SolidColorBrush x:Key="C4DHoverBrush"        Color="{StaticResource C4DHoverColor}" />
            <SolidColorBrush x:Key="C4DAccentBrush"       Color="{StaticResource C4DAccentColor}" />
            <SolidColorBrush x:Key="C4DAccentDeepBrush"   Color="{StaticResource C4DAccentDeepColor}" />
            <SolidColorBrush x:Key="C4DAccentSoftBrush"   Color="{StaticResource C4DAccentSoftColor}" />
            <SolidColorBrush x:Key="C4DTextPrimaryBrush"  Color="{StaticResource C4DTextPrimaryColor}" />
            <SolidColorBrush x:Key="C4DTextSecondaryBrush" Color="{StaticResource C4DTextSecondaryColor}" />
            <SolidColorBrush x:Key="C4DTextDimBrush"      Color="{StaticResource C4DTextDimColor}" />
            <SolidColorBrush x:Key="C4DInputBgBrush"      Color="{StaticResource C4DInputBgColor}" />
            <SolidColorBrush x:Key="C4DLinkBrush"         Color="{StaticResource C4DLinkColor}" />
            <SolidColorBrush x:Key="C4DSelectionBrush"    Color="{StaticResource C4DSelectionColor}" />

            <!-- ═══════ wpf-ui brush overrides ═══════
                 Rebinding wpf-ui's resource keys to VS Code brushes makes
                 every existing DynamicResource lookup in the app inherit the
                 new palette without touching individual XAML files. -->
            <SolidColorBrush x:Key="ApplicationBackgroundBrush"   Color="{StaticResource C4DAppBgColor}" />
            <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource C4DAppBgColor}" />
            <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource C4DPanelDeepColor}" />
            <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush"  Color="{StaticResource C4DPanelColor}" />
            <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource C4DPanelRaisedColor}" />

            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"   Color="{StaticResource C4DPanelColor}" />
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource C4DPanelDeepColor}" />
            <SolidColorBrush x:Key="ControlFillColorTertiaryBrush"  Color="{StaticResource C4DPanelRaisedColor}" />
            <SolidColorBrush x:Key="ControlFillColorDisabledBrush"  Color="#FF2D2D2D" />
            <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent" />
            <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{StaticResource C4DInputBgColor}" />

            <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource C4DBorderColor}" />
            <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource C4DBorderColor}" />
            <SolidColorBrush x:Key="ControlElevationBorderBrush"    Color="{StaticResource C4DBorderColor}" />
            <SolidColorBrush x:Key="ControlStrongStrokeColorDefaultBrush" Color="{StaticResource C4DBorderColor}" />

            <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent" />
            <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush"  Color="{StaticResource C4DHoverColor}" />
            <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush"   Color="{StaticResource C4DPanelRaisedColor}" />
            <SolidColorBrush x:Key="SubtleFillColorDisabledBrush"   Color="Transparent" />

            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"      Color="{StaticResource C4DTextPrimaryColor}" />
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"    Color="{StaticResource C4DTextSecondaryColor}" />
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"     Color="{StaticResource C4DTextDimColor}" />
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"     Color="{StaticResource C4DTextDimColor}" />

            <!-- VS Code blue accent — replaces the Windows system accent across
                 toggles, focused inputs, checkbox marks, slider track, etc. -->
            <SolidColorBrush x:Key="SystemAccentColorBrush"         Color="{StaticResource C4DAccentColor}" />
            <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush"  Color="{StaticResource C4DAccentColor}" />
            <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource C4DAccentDeepColor}" />
            <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource C4DAccentDeepColor}" />
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush"   Color="{StaticResource C4DAccentColor}" />
            <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="{StaticResource C4DAccentColor}" />
            <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush"  Color="{StaticResource C4DAccentDeepColor}" />
            <SolidColorBrush x:Key="AccentTextFillColorDisabledBrush"  Color="#FF656565" />
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"    Color="#FF0E639C" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"  Color="{StaticResource C4DAccentDeepColor}" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"   Color="{StaticResource C4DAccentSoftColor}" />
            <SolidColorBrush x:Key="AccentFillColorDisabledBrush"   Color="#FF3A3D41" />
            <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{StaticResource C4DAccentDeepColor}" />

            <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush"   Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush"  Color="#FFCCCCCC" />
            <SolidColorBrush x:Key="TextOnAccentFillColorSelectedTextBrush" Color="#FFFFFFFF" />

            <!-- Tooltips across the app — short delay so the inline hints we
                 ship on every interactive control feel responsive, long
                 ShowDuration so multi-sentence explanations stay open long
                 enough to read. Defaults are 0.4s delay / 5s duration; the
                 first is sluggish for power users, the second too short for
                 anything past one line. -->
            <Style TargetType="{x:Type ToolTip}">
                <Setter Property="MaxWidth" Value="320" />
            </Style>
            <Style x:Key="HelpIconStyle" TargetType="{x:Type ui:SymbolIcon}">
                <Setter Property="Symbol" Value="Info20" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Opacity" Value="0.45" />
                <Setter Property="Margin" Value="6,0,0,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Cursor" Value="Help" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="200" />
                <Setter Property="ToolTipService.ShowDuration" Value="30000" />
            </Style>

            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibility" />
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibility" />
            <conv:InverseBooleanConverter x:Key="InverseBoolean" />
            <conv:StringEqualsMultiConverter x:Key="StringEquals" />
            <conv:PathToImageSourceConverter x:Key="PathToImageSource" />
            <conv:FileExistsToBoolConverter x:Key="FileExistsToBool" />
            <conv:FileMissingToVisibilityConverter x:Key="FileMissingToVisibility" />
            <conv:HexToColorConverter x:Key="HexColor" />
            <conv:MaterialPresetIsConverter x:Key="MaterialPresetIs" />

            <!-- VM → View mapping for tab content. ContentControl in MainWindow
                 resolves the right UserControl by matching DataType. -->
            <DataTemplate DataType="{x:Type vm:OptimizeViewModel}">
                <views:OptimizeView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TxAdminOptimizeViewModel}">
                <views:TxAdminOptimizeView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VehiclesViewModel}">
                <views:VehiclesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RpfConverterViewModel}">
                <views:RpfConverterView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ImageTo3DViewModel}">
                <views:ImageTo3DView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
