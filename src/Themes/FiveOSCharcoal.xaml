<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!--
        Charcoal IDE theme — mid-grey panels (43/38/31), accent-driven
        highlights (Settings → Accent color; default blue), muted text.
        Filled-track round-thumb sliders. Overrides WPF-UI Fluent Dark keys
        so every DynamicResource control inherits the look without per-view
        restyles.
    -->

    <CornerRadius x:Key="ControlCornerRadius">3</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">4</CornerRadius>

    <!-- ── Color tokens (C4D Dark scheme) ────────────────────────────── -->
    <Color x:Key="FiveOSAppBgColor">#FF2B2B2B</Color>          <!-- COLOR_BG -->
    <Color x:Key="FiveOSPanelColor">#FF262626</Color>         <!-- COLOR_BG_DARK1 -->
    <Color x:Key="FiveOSPanelDeepColor">#FF1F1F1F</Color>     <!-- COLOR_BG_DARK2 -->
    <Color x:Key="FiveOSPanelRaisedColor">#FF3D3D3D</Color>   <!-- COLOR_BG_PALETTE -->
    <Color x:Key="FiveOSBorderColor">#FF363636</Color>        <!-- COLOR_HORIZONTAL_SEPARATOR -->
    <Color x:Key="FiveOSHoverColor">#FF333333</Color>
    <Color x:Key="FiveOSInputBgColor">#FF1C1C1C</Color>       <!-- COLOR_BGEDIT -->
    <Color x:Key="FiveOSTrackColor">#FF4D4D4D</Color>         <!-- COLOR_BGGADGET -->
    <Color x:Key="FiveOSAccentColor">#FF0078D4</Color>
    <Color x:Key="FiveOSAccentBrightColor">#FF3A9EEC</Color>
    <Color x:Key="FiveOSAccentDeepColor">#FF005A9E</Color>
    <Color x:Key="FiveOSAccentSoftColor">#330078D4</Color>
    <Color x:Key="FiveOSTextPrimaryColor">#FFCCCCCC</Color>   <!-- COLOR_TEXT_EDIT -->
    <Color x:Key="FiveOSTextSecondaryColor">#FFA6A6A6</Color> <!-- COLOR_TEXT -->
    <Color x:Key="FiveOSTextDimColor">#FF666666</Color>       <!-- COLOR_TEXT_DISABLED -->
    <Color x:Key="FiveOSSelectionColor">#FF0078D4</Color>

    <SolidColorBrush x:Key="FiveOSAppBgBrush" Color="{StaticResource FiveOSAppBgColor}" />
    <SolidColorBrush x:Key="FiveOSPanelBrush" Color="{StaticResource FiveOSPanelColor}" />
    <SolidColorBrush x:Key="FiveOSPanelDeepBrush" Color="{StaticResource FiveOSPanelDeepColor}" />
    <SolidColorBrush x:Key="FiveOSPanelRaisedBrush" Color="{StaticResource FiveOSPanelRaisedColor}" />
    <SolidColorBrush x:Key="FiveOSBorderBrush" Color="{StaticResource FiveOSBorderColor}" />
    <SolidColorBrush x:Key="FiveOSHoverBrush" Color="{StaticResource FiveOSHoverColor}" />
    <SolidColorBrush x:Key="FiveOSInputBgBrush" Color="{StaticResource FiveOSInputBgColor}" />
    <SolidColorBrush x:Key="FiveOSTrackBrush" Color="{StaticResource FiveOSTrackColor}" />
    <!-- Accent brushes use DynamicResource so Settings pink/teal/… update live. -->
    <SolidColorBrush x:Key="FiveOSAccentBrush" Color="{DynamicResource FiveOSAccentColor}" />
    <SolidColorBrush x:Key="FiveOSAccentBrightBrush" Color="{DynamicResource FiveOSAccentBrightColor}" />
    <SolidColorBrush x:Key="FiveOSAccentDeepBrush" Color="{DynamicResource FiveOSAccentDeepColor}" />
    <SolidColorBrush x:Key="FiveOSAccentSoftBrush" Color="{DynamicResource FiveOSAccentSoftColor}" />
    <SolidColorBrush x:Key="FiveOSTextPrimaryBrush" Color="{StaticResource FiveOSTextPrimaryColor}" />
    <SolidColorBrush x:Key="FiveOSTextSecondaryBrush" Color="{StaticResource FiveOSTextSecondaryColor}" />
    <SolidColorBrush x:Key="FiveOSTextDimBrush" Color="{StaticResource FiveOSTextDimColor}" />
    <SolidColorBrush x:Key="FiveOSSelectionBrush" Color="{DynamicResource FiveOSSelectionColor}" />

    <!-- ── WPF-UI surface overrides ─────────────────────────────────── -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource FiveOSAppBgColor}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource FiveOSAppBgColor}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource FiveOSPanelDeepColor}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{StaticResource FiveOSPanelColor}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource FiveOSPanelRaisedColor}" />

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource FiveOSPanelColor}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource FiveOSPanelDeepColor}" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource FiveOSPanelRaisedColor}" />
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="#FF2D2D2D" />
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{StaticResource FiveOSInputBgColor}" />

    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource FiveOSBorderColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource FiveOSBorderColor}" />
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource FiveOSBorderColor}" />
    <SolidColorBrush x:Key="ControlStrongStrokeColorDefaultBrush" Color="{StaticResource FiveOSBorderColor}" />
    <SolidColorBrush x:Key="ControlStrongFillColorDefaultBrush" Color="{StaticResource FiveOSTrackColor}" />

    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent" />
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource FiveOSHoverColor}" />
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource FiveOSPanelRaisedColor}" />
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="Transparent" />

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource FiveOSTextPrimaryColor}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource FiveOSTextSecondaryColor}" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource FiveOSTextDimColor}" />
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource FiveOSTextDimColor}" />

    <!-- Accent — defaults match Blue preset; ThemeAccent rewrites these at runtime. -->
    <Color x:Key="SystemAccentColor">#FF0078D4</Color>
    <Color x:Key="SystemAccentColorPrimary">#FF3A9EEC</Color>
    <Color x:Key="SystemAccentColorSecondary">#FF0078D4</Color>
    <Color x:Key="SystemAccentColorTertiary">#FF005A9E</Color>

    <SolidColorBrush x:Key="SystemAccentColorBrush" Color="{DynamicResource FiveOSAccentColor}" />
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{DynamicResource FiveOSAccentBrightColor}" />
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{DynamicResource FiveOSAccentColor}" />
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{DynamicResource FiveOSAccentDeepColor}" />
    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="{DynamicResource FiveOSAccentBrightColor}" />
    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="{DynamicResource FiveOSAccentColor}" />
    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush" Color="{DynamicResource FiveOSAccentDeepColor}" />
    <SolidColorBrush x:Key="AccentTextFillColorDisabledBrush" Color="#FF6E6E6E" />
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{DynamicResource FiveOSAccentColor}" />
    <SolidColorBrush x:Key="AccentFillColorPrimaryBrush" Color="{DynamicResource FiveOSAccentColor}" />
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{DynamicResource FiveOSAccentBrightColor}" />
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{DynamicResource FiveOSAccentSoftColor}" />
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="#FF3A3D41" />
    <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{DynamicResource FiveOSAccentDeepColor}" />

    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="#FFCCCCCC" />
    <SolidColorBrush x:Key="TextOnAccentFillColorSelectedTextBrush" Color="#FFFFFFFF" />

    <!-- ── Slider — filled accent track + solid round thumb (Settings-style) ─ -->
    <SolidColorBrush x:Key="FiveOSSliderTrackBrush" Color="#FF3A3A3A" />

    <Style x:Key="FiveOSSliderThumb" TargetType="Thumb">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <!-- Fixed outer box so hover/drag scale doesn't shift layout. -->
                    <Grid Width="16" Height="16">
                        <Ellipse x:Name="ThumbShape"
                                 Width="14" Height="14"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource SystemAccentColorBrush}"
                                 StrokeThickness="0"
                                 SnapsToDevicePixels="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbShape" Property="Width" Value="16" />
                            <Setter TargetName="ThumbShape" Property="Height" Value="16" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbShape" Property="Width" Value="16" />
                            <Setter TargetName="ThumbShape" Property="Height" Value="16" />
                            <Setter TargetName="ThumbShape" Property="Fill" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ThumbShape" Property="Fill" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Invisible repeat buttons so the track still receives clicks. -->
    <Style x:Key="FiveOSSliderRepeatButton" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="FiveOSHorizontalSlider" TargetType="Slider">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TickBar x:Name="TopTick" Grid.Row="0" Placement="Top" Height="4"
                     Fill="{DynamicResource TextFillColorTertiaryBrush}" Visibility="Collapsed" />
            <Border Grid.Row="1" Margin="7,0" Background="Transparent" VerticalAlignment="Center"
                    MinHeight="22">
                <Grid VerticalAlignment="Center" Height="22">
                    <!-- Unfilled track (full width) -->
                    <Border Height="4" CornerRadius="2"
                            Background="{DynamicResource FiveOSSliderTrackBrush}"
                            VerticalAlignment="Center"
                            SnapsToDevicePixels="True" />
                    <!-- Filled portion (left of thumb) -->
                    <Track x:Name="PART_Track" VerticalAlignment="Center">
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Style="{StaticResource FiveOSSliderRepeatButton}" Command="Slider.DecreaseLarge">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border Background="{DynamicResource SystemAccentColorBrush}"
                                                Height="4" CornerRadius="2"
                                                VerticalAlignment="Center"
                                                SnapsToDevicePixels="True" />
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                        </Track.DecreaseRepeatButton>
                        <Track.Thumb>
                            <Thumb Style="{StaticResource FiveOSSliderThumb}" />
                        </Track.Thumb>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Style="{StaticResource FiveOSSliderRepeatButton}" Command="Slider.IncreaseLarge" />
                        </Track.IncreaseRepeatButton>
                    </Track>
                </Grid>
            </Border>
            <TickBar x:Name="BottomTick" Grid.Row="2" Placement="Bottom" Height="4"
                     Fill="{DynamicResource TextFillColorTertiaryBrush}" Visibility="Collapsed" />
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="TickPlacement" Value="TopLeft">
                <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="BottomRight">
                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="Both">
                <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="FiveOSVerticalSlider" TargetType="Slider">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" MinWidth="{TemplateBinding MinWidth}" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TickBar x:Name="LeftTick" Grid.Column="0" Placement="Left" Width="4"
                     Fill="{DynamicResource TextFillColorTertiaryBrush}" Visibility="Collapsed" />
            <Border Grid.Column="1" Margin="0,7" Background="Transparent" HorizontalAlignment="Center"
                    MinWidth="22">
                <Grid HorizontalAlignment="Center" Width="22">
                    <Border Width="4" CornerRadius="2"
                            Background="{DynamicResource FiveOSSliderTrackBrush}"
                            HorizontalAlignment="Center" />
                    <Track x:Name="PART_Track" Orientation="Vertical">
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Style="{StaticResource FiveOSSliderRepeatButton}" Command="Slider.DecreaseLarge">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border Background="{DynamicResource SystemAccentColorBrush}"
                                                Width="4" CornerRadius="2"
                                                HorizontalAlignment="Center" />
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                        </Track.DecreaseRepeatButton>
                        <Track.Thumb>
                            <Thumb Style="{StaticResource FiveOSSliderThumb}" />
                        </Track.Thumb>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Style="{StaticResource FiveOSSliderRepeatButton}" Command="Slider.IncreaseLarge" />
                        </Track.IncreaseRepeatButton>
                    </Track>
                </Grid>
            </Border>
            <TickBar x:Name="RightTick" Grid.Column="2" Placement="Right" Width="4"
                     Fill="{DynamicResource TextFillColorTertiaryBrush}" Visibility="Collapsed" />
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="TickPlacement" Value="TopLeft">
                <Setter TargetName="LeftTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="BottomRight">
                <Setter TargetName="RightTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="Both">
                <Setter TargetName="LeftTick" Property="Visibility" Value="Visible" />
                <Setter TargetName="RightTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Implicit Slider style — filled track + round accent thumb everywhere. -->
    <Style TargetType="Slider">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorBrush}" />
        <Setter Property="Template" Value="{StaticResource FiveOSHorizontalSlider}" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="MinWidth" Value="22" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Template" Value="{StaticResource FiveOSVerticalSlider}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Toolbar ToggleButtons (Rig / Ghosts / FK / …). Default WPF template
         paints IsChecked with SystemColors.HighlightBrush (Windows blue) —
         that ignored Settings accent. Named styles (EyeToggle etc.) keep
         their own templates and are unaffected. -->
    <Style TargetType="ToggleButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SystemAccentColorBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
