<ui:FluentWindow x:Class="FiveOS.Views.LevelPickerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Welcome to FiveOS"
                 Width="720" Height="420"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">

    <Window.Resources>
        <Style x:Key="LevelCard" TargetType="Border">
            <Setter Property="Width" Value="200" />
            <Setter Property="Margin" Value="9" />
            <Setter Property="Padding" Value="18,18" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Welcome to FiveOS"
                     ShowMaximize="False" ShowMinimize="False" ShowClose="False" />

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="20,0">
            <TextBlock Text="How much do you want to see?"
                       FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="Pick a level to start with — you can change it any time in Settings."
                       FontSize="13" Opacity="0.65" HorizontalAlignment="Center" Margin="0,4,0,18" />

            <WrapPanel HorizontalAlignment="Center">
                <Border Style="{StaticResource LevelCard}" Tag="0" MouseLeftButtonUp="OnPick">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Sparkle24" FontSize="30" />
                        <TextBlock Text="Beginner" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                        <TextBlock Text="Just the essentials — drop a model, name it, convert. Smart defaults handle the rest."
                                   FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource LevelCard}" Tag="1" MouseLeftButtonUp="OnPick">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Layer24" FontSize="30" />
                        <TextBlock Text="Standard" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                        <TextBlock Text="The normal toolset and options — the full set of everyday features."
                                   FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource LevelCard}" Tag="2" MouseLeftButtonUp="OnPick">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Settings24" FontSize="30" />
                        <TextBlock Text="Advanced" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                        <TextBlock Text="Everything unlocked — manual controls, all tools, power-user options."
                                   FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>

        <TextBlock Grid.Row="2" Margin="0,0,0,14" HorizontalAlignment="Center"
                   FontSize="11" Opacity="0.5"
                   Text="Change it later under Settings → General → Experience level." />
    </Grid>
</ui:FluentWindow>
