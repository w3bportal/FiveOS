<Window x:Class="FiveOS.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:FiveOS.Views.Controls"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Width="640"
        Height="360"
        Icon="pack://application:,,,/Assets/Branding/FiveOS.ico"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3" />
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.4" />
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="8"
            BorderThickness="1"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            Background="{DynamicResource ApplicationBackgroundBrush}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />     <!-- Logo + info row -->
                <RowDefinition Height="Auto" />  <!-- Progress, caption, copyright -->
            </Grid.RowDefinitions>

            <!-- ───── Top: logo (left) + info column (right) ───── -->
            <Grid Grid.Row="0" Margin="36,32,36,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Big square brand mark on the left -->
                <Border Grid.Column="0"
                        VerticalAlignment="Top">
                    <Image Source="pack://application:,,,/Assets/Branding/FiveOS.png"
                           Width="160" Height="160"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <!-- Title / version / notice on the right -->
                <StackPanel Grid.Column="1"
                            Margin="20,8,0,0"
                            VerticalAlignment="Top">
                    <TextBlock Text="FiveOS"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,2" />
                    <TextBlock x:Name="VersionText"
                               Text="Version 0.0.0"
                               FontSize="13"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               Margin="0,0,0,18" />

                    <TextBlock Text="Notice:"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               LineHeight="17"
                               Text="All in One FiveM Modding Tool. Free to use." />
                </StackPanel>
            </Grid>

            <!-- ───── Bottom: dot-matrix loader + caption + copyright ───── -->
            <StackPanel Grid.Row="1" Margin="36,0,36,18">

                <!-- Indeterminate dot-matrix loader. Caption text below
                     conveys phase ("Building viewer...", "Ready.") so we
                     don't lose progress info from dropping the bar. -->
                <ctrl:DotMatrixLoader x:Name="Loader"
                                       LoaderStyle="HelixGlow"
                                       DotSize="8"
                                       DotSpacing="4"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10">
                    <ctrl:DotMatrixLoader.DotColor>
                        <SolidColorBrush Color="{DynamicResource SystemAccentColorPrimary}" />
                    </ctrl:DotMatrixLoader.DotColor>
                </ctrl:DotMatrixLoader>

                <TextBlock x:Name="CaptionText"
                           Text="Starting up..."
                           FontSize="11"
                           Foreground="#8FB4E6"
                           Opacity="0.9"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6" />

                <TextBlock Text="Copyright © 2026 FiveOS"
                           FontSize="10"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>

        </Grid>
    </Border>
</Window>
