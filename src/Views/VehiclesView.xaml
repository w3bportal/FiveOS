<UserControl x:Class="FiveOS.Views.VehiclesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:vm="clr-namespace:FiveOS.ViewModels"
             xmlns:ctrl="clr-namespace:FiveOS.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver"
             DragEnter="OnDragEnter"
             DragLeave="OnDragLeave"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded"
             d:DataContext="{d:DesignInstance vm:VehiclesViewModel}">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MetaFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <ContextMenu x:Key="VehTreeMenu"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="Optimize (make smaller)" Click="OnOptimizeFile"
                      IsEnabled="{Binding CanOptimizeNode}"
                      ToolTip="Shrink this model or texture. Overwrites it in place.">
                <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowMinimize24" /></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Edit meta…" Click="OnEditXml" IsEnabled="{Binding IsMetaNode}"
                      ToolTip="Open this meta in the Details editor.">
                <MenuItem.Icon><ui:SymbolIcon Symbol="DocumentEdit24" /></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Rename…" Click="OnRename" IsEnabled="{Binding CanRename}"
                      ToolTip="Rename a file or a whole car.">
                <MenuItem.Icon><ui:SymbolIcon Symbol="Rename24" /></MenuItem.Icon>
            </MenuItem>
            <Separator />
            <MenuItem Header="Show in Explorer" Click="OnOpenFileFolder">
                <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24" /></MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <Style x:Key="VehTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="ContextMenu" Value="{StaticResource VehTreeMenu}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <EventSetter Event="MouseDoubleClick" Handler="OnTreeDoubleClick" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ToggleButton x:Name="Expander" Grid.Column="0" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Width="16" Height="22">
                                            <TextBlock x:Name="Arrow" Text="›" FontSize="14" Opacity="0.6"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       RenderTransformOrigin="0.5,0.5" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="RenderTransform">
                                                    <Setter.Value><RotateTransform Angle="90" /></Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Border x:Name="Bd" Grid.Column="1" CornerRadius="4" Padding="4,4" Margin="0,1"
                                    Background="Transparent" SnapsToDevicePixels="True">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Grid.Column="1" Margin="12,0,0,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate x:Key="VehTreeItemTemplate" ItemsSource="{Binding Children}">
            <Grid MinWidth="120" Margin="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="15" Opacity="0.85"
                               Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Name}" FontFamily="Consolas" FontSize="12"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontFamily="Consolas" FontSize="10"
                           Opacity="0.5" Margin="8,0,0,0" VerticalAlignment="Center" />
                <Border Grid.Column="3"
                        Visibility="{Binding IsUnoptimized, Converter={StaticResource BooleanToVisibility}}"
                        CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                        Background="#26E0A33A" BorderBrush="#59E0A33A" BorderThickness="1"
                        VerticalAlignment="Center"
                        ToolTip="Large textures/models — right-click → Optimize.">
                    <TextBlock Text="heavy" FontSize="9" FontWeight="SemiBold"
                               Foreground="#E0A33A" VerticalAlignment="Center" />
                </Border>
                <Button Grid.Column="4" Click="OnRemoveCarNode"
                        Visibility="{Binding IsCar, Converter={StaticResource BooleanToVisibility}}"
                        Background="Transparent" BorderThickness="0" Padding="4,0" Margin="4,0,0,0"
                        Cursor="Hand" ToolTip="Remove from queue">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" Opacity="0.7" />
                </Button>
            </Grid>
        </HierarchicalDataTemplate>

        <DataTemplate x:Key="QueueItemTemplate" DataType="{x:Type vm:CarInput}">
            <Grid Margin="0,1" MinWidth="120">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Symbol="VehicleCar24" FontSize="15" Opacity="0.85"
                               Margin="0,0,8,0" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontFamily="Consolas" FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="Queued" FontSize="10" Opacity="0.45" />
                </StackPanel>
                <Button Grid.Column="2" Click="OnRemoveCar"
                        Tag="{Binding}"
                        Background="Transparent" BorderThickness="0" Padding="4,0" Margin="4,0,0,0"
                        Cursor="Hand" ToolTip="Remove from queue">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" Opacity="0.7" />
                </Button>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="VehicleCar24" FontSize="18" Opacity="0.85"
                                   Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="Car Pack" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding QueueCountText}" FontSize="11" Opacity="0.5"
                               Margin="12,0,0,0" VerticalAlignment="Center"
                               Visibility="{Binding HasQueue, Converter={StaticResource BooleanToVisibility}}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="16,0"
                            Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibility}}">
                    <StackPanel Margin="0,0,16,0" MinWidth="64">
                        <TextBlock Text="TOTAL CARS" Style="{StaticResource StatLabel}" />
                        <TextBlock Text="{Binding StatCars}" Style="{StaticResource StatValue}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0" MinWidth="64">
                        <TextBlock Text="SIZE" Style="{StaticResource StatLabel}" />
                        <TextBlock Text="{Binding StatSizeText}" Style="{StaticResource StatValue}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0" MinWidth="72">
                        <TextBlock Text="POLYGONS" Style="{StaticResource StatLabel}" />
                        <TextBlock Text="{Binding StatPolygonsText}" Style="{StaticResource StatValue}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0" MinWidth="72">
                        <TextBlock Text="UNOPTIMIZED" Style="{StaticResource StatLabel}" />
                        <TextBlock Text="{Binding StatUnoptimized}" Style="{StaticResource StatValue}" Foreground="#E0A33A" />
                    </StackPanel>
                    <StackPanel MinWidth="64">
                        <TextBlock Text="OPTIMIZED" Style="{StaticResource StatLabel}" />
                        <TextBlock Text="{Binding StatOptimized}" Style="{StaticResource StatValue}" Foreground="#3FB950" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Content="Cancel"
                               Appearance="Danger"
                               Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibility}}"
                               Click="OnCancelConvert" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" x:Name="MainSplitGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LayersCol" Width="260" MinWidth="180" MaxWidth="480" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderThickness="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="12,12,12,8">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Multi-car pack" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding MultiCarHint}" FontSize="10" Opacity="0.5" Margin="0,2,0,0" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1"
                                             IsChecked="{Binding MergeIntoPack, Mode=TwoWay}"
                                             VerticalAlignment="Center"
                                             IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                             ToolTip="Queue multiple cars into one pack" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0"
                                       Content="{Binding AddCarsButtonText}"
                                       Appearance="Secondary"
                                       HorizontalAlignment="Stretch"
                                       IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                       Click="OnBrowseInput"
                                       ToolTip="Pick dlc.rpf files or folders." />
                            <ui:Button Grid.Column="2"
                                       Content="{Binding ImportButtonText}"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       IsEnabled="{Binding CanConvert}"
                                       Click="OnConvert"
                                       ToolTip="Import queued cars into a FiveM pack." />
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Content="New template"
                                       Appearance="Secondary"
                                       HorizontalAlignment="Stretch"
                                       IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                       Click="OnNewTemplate"
                                       ToolTip="Create empty FiveM pack folders: stream, data, audio…" />
                            <ui:Button Grid.Column="2" Content="Load folder…"
                                       Appearance="Secondary"
                                       HorizontalAlignment="Stretch"
                                       IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                       Click="OnLoadFolder"
                                       ToolTip="Open an existing FiveM car resource folder." />
                        </Grid>

                        <TextBlock Text="Or paste a gta5-mods link" FontSize="10" Opacity="0.5" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding ModUrl, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="gta5-mods.com/vehicles/…"
                                        FontSize="11"
                                        ToolTip="Downloads and adds the mod to the queue." />
                            <ui:Button Grid.Column="1" Content="Add"
                                       Appearance="Secondary" Margin="6,0,0,0" Padding="10,0"
                                       IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                       Click="OnImportFromUrl"
                                       ToolTip="Download and add to the queue." />
                        </Grid>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="LAYERS" Style="{StaticResource SectionHeader}"
                               Margin="14,4,14,8" />

                    <Grid Grid.Row="2" Margin="8,0,8,8">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding ShowLayersEmpty, Converter={StaticResource BooleanToVisibility}}">
                            <ui:SymbolIcon Symbol="Layer24" FontSize="28" Opacity="0.3" HorizontalAlignment="Center" />
                            <TextBlock Text="No layers yet"
                                       FontSize="13" FontWeight="SemiBold" Opacity="0.55"
                                       HorizontalAlignment="Center" Margin="0,10,0,4" />
                            <TextBlock Text="Add to queue, New template, or drop a dlc.rpf here."
                                       FontSize="11" Opacity="0.45" TextWrapping="Wrap" MaxWidth="180"
                                       TextAlignment="Center" HorizontalAlignment="Center" />
                        </StackPanel>

                        <ListBox x:Name="QueueList"
                                 ItemsSource="{Binding Queue}"
                                 ItemTemplate="{StaticResource QueueItemTemplate}"
                                 SelectedItem="{Binding SelectedQueueItem, Mode=TwoWay}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                 Visibility="{Binding ShowPendingQueue, Converter={StaticResource BooleanToVisibility}}"
                                 PreviewMouseLeftButtonDown="OnQueueMouseDown">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,6" />
                                    <Setter Property="Margin" Value="0,1" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="False" />
                                                            <Condition Property="IsMouseOver" Value="True" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <TreeView x:Name="FilesTree"
                                  ItemsSource="{Binding CarNodes}"
                                  ItemContainerStyle="{StaticResource VehTreeItemStyle}"
                                  ItemTemplate="{StaticResource VehTreeItemTemplate}"
                                  BorderThickness="0" Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                  Visibility="{Binding ShowLayersTree, Converter={StaticResource BooleanToVisibility}}"
                                  PreviewMouseLeftButtonDown="OnQueueMouseDown"
                                  SelectedItemChanged="OnTreeSelected" />
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          x:Name="LayersSplitter"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource ControlElevationBorderBrush}"
                          ShowsPreview="False"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE"
                          DragCompleted="OnLayersSplitterDragCompleted" />

            <Grid Grid.Column="2" x:Name="WorkspaceGrid" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="StageRow" Height="*" MinHeight="160" />
                    <RowDefinition Height="5" />
                    <RowDefinition x:Name="DetailsRow" Height="380" MinHeight="140" MaxHeight="560" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10,10,10,0" x:Name="StageGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition x:Name="PaintCol" Width="220" MinWidth="160" MaxWidth="420" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="4" BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Background="#0d0d10" ClipToBounds="True">
                        <Grid>
                            <wv2:WebView2 x:Name="CarPreview" DefaultBackgroundColor="#0d0d10" />

                            <StackPanel x:Name="PreviewHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        IsHitTestVisible="False">
                                <ui:SymbolIcon Symbol="VehicleCar24" FontSize="36" Opacity="0.28"
                                               Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding FilesEmptyTitle}"
                                           FontSize="13" FontWeight="SemiBold" Opacity="0.55" Foreground="White"
                                           HorizontalAlignment="Center" Margin="0,12,0,4" />
                                <TextBlock Text="{Binding FilesEmptyHint}"
                                           FontSize="11" Opacity="0.4" Foreground="White"
                                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="280"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel x:Name="PreviewLoader" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="Collapsed" IsHitTestVisible="False">
                                <ctrl:DotMatrixLoader LoaderStyle="BlockDrop" DotSize="5" DotSpacing="2"
                                                      HorizontalAlignment="Center" />
                                <TextBlock x:Name="PreviewLoaderText" Text="Loading…"
                                           FontSize="11" Opacity="0.8" Foreground="White"
                                           HorizontalAlignment="Center" Margin="0,10,0,0" />
                            </StackPanel>

                            <TextBlock x:Name="CarMeshInfoText"
                                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                       Margin="10,0,10,7" FontSize="10" Opacity="0.65"
                                       Foreground="White" IsHitTestVisible="False"
                                       TextTrimming="CharacterEllipsis" Text="" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,8,8,0"
                                        Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibility}}">
                                <ui:Button x:Name="GtaFolderBtn" Content="GTA"
                                           Appearance="Secondary" FontSize="10" Padding="8,3"
                                           Click="OnSetGtaFolder"
                                           ToolTip="Point at GTA V for shared vehicle textures." />
                                <ui:Button Content="↺" Appearance="Secondary" FontSize="11" Padding="9,3" Margin="5,0,0,0"
                                           Click="OnCarRecenter" ToolTip="Recenter camera." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="{DynamicResource ControlElevationBorderBrush}"
                                  ShowsPreview="False"
                                  ResizeBehavior="PreviousAndNext"
                                  Cursor="SizeWE"
                                  DragCompleted="OnPaintSplitterDragCompleted" />

                    <Border Grid.Column="2"
                            CornerRadius="4" BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibility}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="PAINT &amp; VEHICLE CONTROLS" Style="{StaticResource SectionHeader}" />
                                <WrapPanel Margin="0,0,0,10">
                                    <WrapPanel.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="Width" Value="22" />
                                            <Setter Property="Height" Value="22" />
                                            <Setter Property="CornerRadius" Value="4" />
                                            <Setter Property="Margin" Value="0,0,6,6" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                                        </Style>
                                    </WrapPanel.Resources>
                                    <Border Background="#9A9EA3" Tag="9A9EA3" MouseLeftButtonUp="OnPaintColor" ToolTip="Silver" />
                                    <Border Background="#E8E8EA" Tag="E8E8EA" MouseLeftButtonUp="OnPaintColor" ToolTip="White" />
                                    <Border Background="#1A1A1D" Tag="1A1A1D" MouseLeftButtonUp="OnPaintColor" ToolTip="Black" />
                                    <Border Background="#3A3F44" Tag="3A3F44" MouseLeftButtonUp="OnPaintColor" ToolTip="Gunmetal" />
                                    <Border Background="#B01818" Tag="B01818" MouseLeftButtonUp="OnPaintColor" ToolTip="Red" />
                                    <Border Background="#1E3A8A" Tag="1E3A8A" MouseLeftButtonUp="OnPaintColor" ToolTip="Blue" />
                                    <Border Background="#1E6B3A" Tag="1E6B3A" MouseLeftButtonUp="OnPaintColor" ToolTip="Green" />
                                    <Border Background="#D4A017" Tag="D4A017" MouseLeftButtonUp="OnPaintColor" ToolTip="Gold" />
                                    <Border Background="#C2560F" Tag="C2560F" MouseLeftButtonUp="OnPaintColor" ToolTip="Orange" />
                                </WrapPanel>
                                <ui:ToggleSwitch x:Name="DoorsToggle" Content="Open doors"
                                                 IsEnabled="False" FontSize="12" Margin="0,0,0,4"
                                                 Checked="OnDoorsToggled" Unchecked="OnDoorsToggled" />
                                <TextBlock x:Name="DoorsHint" FontSize="10" Opacity="0.5" TextWrapping="Wrap"
                                           Margin="0,0,0,10"
                                           Text="Load a car to unlock doors." />
                                <ItemsControl x:Name="PartsList" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource ControlElevationBorderBrush}"
                              ShowsPreview="False"
                              ResizeBehavior="PreviousAndNext"
                              Cursor="SizeNS"
                              DragCompleted="OnDetailsSplitterDragCompleted" />

                <Border Grid.Row="2"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        Margin="10,0,10,10"
                        CornerRadius="4"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                        <Grid>
                            <StackPanel Visibility="{Binding ShowCarDetails, Converter={StaticResource BooleanToVisibility}}">
                                <TextBlock Text="DETAILS" Style="{StaticResource SectionHeader}" />

                                <StackPanel Visibility="{Binding HasDetail, Converter={StaticResource InverseBooleanToVisibility}}"
                                            Margin="0,4,0,16">
                                    <TextBlock Text="Nothing selected"
                                               FontSize="13" FontWeight="SemiBold" Opacity="0.55" />
                                    <TextBlock Text="Select a layer to see its source and stats."
                                               FontSize="11" Opacity="0.45" TextWrapping="Wrap" Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel Visibility="{Binding HasDetail, Converter={StaticResource BooleanToVisibility}}"
                                            Margin="0,0,0,18">
                                    <TextBlock Text="{Binding DetailTitle}" FontSize="15" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding DetailTitle}" />
                                    <TextBlock Text="{Binding DetailSubtitle}" FontSize="11" Opacity="0.55" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding DetailStats}" FontSize="12" Opacity="0.8" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding DetailSource}" FontSize="10" FontFamily="Consolas"
                                               Opacity="0.5" TextWrapping="Wrap" Margin="0,8,0,0"
                                               ToolTip="{Binding DetailSource}" />
                                </StackPanel>

                                <Border Visibility="{Binding HasReviewNotes, Converter={StaticResource BooleanToVisibility}}"
                                        CornerRadius="6" BorderThickness="1" Margin="0,0,0,16"
                                        BorderBrush="#E0A33A"
                                        Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                        Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="HEADS UP" FontSize="9" FontWeight="SemiBold" Opacity="0.8" Margin="0,0,0,4" />
                                        <ItemsControl ItemsSource="{Binding ReviewNotes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="10" Opacity="0.85"
                                                               TextWrapping="Wrap" Margin="0,1" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="RESOURCE" Style="{StaticResource SectionHeader}" />
                                        <ui:TextBox Text="{Binding PackName, UpdateSourceTrigger=PropertyChanged}"
                                                    PlaceholderText="auto name"
                                                    ToolTip="FiveM resource folder name." />
                                        <TextBlock Text="SAVE TO" Style="{StaticResource SectionHeader}" Margin="0,14,0,8" />
                                        <Border CornerRadius="6"
                                                Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                Padding="10,8">
                                            <TextBlock Text="{Binding OutputPath}"
                                                       FontSize="11" FontFamily="Consolas"
                                                       TextWrapping="Wrap" Opacity="0.85" />
                                        </Border>
                                        <ui:Button Content="Change folder…"
                                                   Appearance="Secondary"
                                                   HorizontalAlignment="Stretch"
                                                   Margin="0,8,0,0"
                                                   Click="OnBrowseOutput" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="OPTIMIZE" Style="{StaticResource SectionHeader}" />
                                        <TextBlock Text="{Binding KeepRatioDisplay}" FontSize="11" Opacity="0.7" Margin="0,0,0,4" />
                                        <Slider x:Name="OptimizeSlider"
                                                Minimum="0.05" Maximum="0.95" SmallChange="0.05" LargeChange="0.1"
                                                Value="{Binding KeepRatio, Mode=TwoWay}"
                                                TickFrequency="0.05" IsSnapToTickEnabled="True" />
                                        <CheckBox Content="Keep panel edges crisp"
                                                  IsChecked="{Binding PreserveBoundary, Mode=TwoWay}"
                                                  FontSize="11" Margin="0,8,0,0" />
                                        <CheckBox x:Name="TextureDownsizeCheck" Content="Shrink huge textures"
                                                  IsChecked="True"
                                                  FontSize="11" Margin="0,6,0,0" />
                                        <ui:Button Content="Optimize everything"
                                                   Appearance="Secondary"
                                                   HorizontalAlignment="Stretch"
                                                   Margin="0,12,0,0"
                                                   Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibility}}"
                                                   IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                                   Click="OnOptimizeAll" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel Visibility="{Binding ShowMetaEditor, Converter={StaticResource BooleanToVisibility}}">
                                <TextBlock Text="META EDITOR" Style="{StaticResource SectionHeader}" />
                                <TextBlock Text="{Binding MetaTitle}" FontSize="15" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />
                                <TextBlock FontSize="10" Opacity="0.5" TextWrapping="Wrap" Margin="0,0,0,10"
                                           Text="Form fields — not raw XML. Switch to Raw to edit the full file." />

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button x:Name="MetaModeFormBtn" Grid.Column="0" Content="Form"
                                               Appearance="Primary"
                                               HorizontalAlignment="Stretch"
                                               IsEnabled="{Binding MetaSupportsForm}"
                                               Click="OnMetaModeForm" />
                                    <ui:Button x:Name="MetaModeRawBtn" Grid.Column="2" Content="Raw editor"
                                               Appearance="Secondary"
                                               HorizontalAlignment="Stretch"
                                               Click="OnMetaModeRaw" />
                                </Grid>

                                <Grid Margin="0,0,0,10"
                                      Visibility="{Binding MetaFormVisible, Converter={StaticResource BooleanToVisibility}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button Grid.Column="0" Content="Import meta…"
                                               Appearance="Secondary" HorizontalAlignment="Stretch"
                                               Click="OnMetaImport" />
                                    <ui:Button Grid.Column="2" Content="Reset form"
                                               Appearance="Secondary" HorizontalAlignment="Stretch"
                                               Click="OnMetaReset" />
                                </Grid>

                                <StackPanel Visibility="{Binding MetaFormVisible, Converter={StaticResource BooleanToVisibility}}">
                                    <UniformGrid Columns="2" Visibility="{Binding ShowMetaVehicles, Converter={StaticResource BooleanToVisibility}}">
                                        <StackPanel Margin="0,0,8,10">
                                            <TextBlock Text="MODEL NAME" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaModelName, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="GAME NAME" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaGameName, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,10">
                                            <TextBlock Text="VEHICLE MAKE" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaVehicleMake, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="VEHICLE CLASS" Style="{StaticResource MetaFieldLabel}" />
                                            <ComboBox SelectedValue="{Binding MetaVehicleClass, Mode=TwoWay}"
                                                      SelectedValuePath="Content">
                                                <ComboBoxItem Content="VC_SPORT" />
                                                <ComboBoxItem Content="VC_SEDAN" />
                                                <ComboBoxItem Content="VC_SUPER" />
                                                <ComboBoxItem Content="VC_MUSCLE" />
                                                <ComboBoxItem Content="VC_SUV" />
                                                <ComboBoxItem Content="VC_COMPACT" />
                                                <ComboBoxItem Content="VC_COUPE" />
                                                <ComboBoxItem Content="VC_MUSCLE" />
                                                <ComboBoxItem Content="VC_OFF_ROAD" />
                                                <ComboBoxItem Content="VC_INDUSTRIAL" />
                                                <ComboBoxItem Content="VC_UTILITY" />
                                                <ComboBoxItem Content="VC_VAN" />
                                                <ComboBoxItem Content="VC_CYCLE" />
                                                <ComboBoxItem Content="VC_BOAT" />
                                                <ComboBoxItem Content="VC_HELICOPTER" />
                                                <ComboBoxItem Content="VC_PLANE" />
                                                <ComboBoxItem Content="VC_SERVICE" />
                                                <ComboBoxItem Content="VC_EMERGENCY" />
                                                <ComboBoxItem Content="VC_MILITARY" />
                                                <ComboBoxItem Content="VC_COMMERCIAL" />
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,10">
                                            <TextBlock Text="HANDLING ID" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaHandlingId, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="FREQUENCY" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaFrequency, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,10">
                                            <TextBlock Text="FLAGS" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaFlags, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <UniformGrid Columns="2" Visibility="{Binding ShowMetaHandling, Converter={StaticResource BooleanToVisibility}}">
                                        <StackPanel Margin="0,0,8,10">
                                            <TextBlock Text="HANDLING ID" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaHandlingId, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="MASS (KG)" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaMass, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,10">
                                            <TextBlock Text="INITIAL DRIVE FORCE" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaInitialDriveForce, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="BRAKE FORCE" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaBrakeForce, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,10">
                                            <TextBlock Text="TRACTION CURVE MAX" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaTractionCurveMax, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="TRACTION CURVE MIN" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaTractionCurveMin, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,10">
                                            <TextBlock Text="TOP SPEED (KPH)" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaTopSpeedKph, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="DOWNFORCE MODIFIER" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaDownforceModifier, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <UniformGrid Columns="2" Visibility="{Binding ShowMetaCarvariations, Converter={StaticResource BooleanToVisibility}}">
                                        <StackPanel Margin="0,0,8,10">
                                            <TextBlock Text="MODEL NAME" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaModelName, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="COLOR 1" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaColor1, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,10">
                                            <TextBlock Text="COLOR 2" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaColor2, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="PEARLESCENT" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaPearlescent, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="KITS / MODKITS" Style="{StaticResource MetaFieldLabel}" />
                                            <ui:TextBox Text="{Binding MetaKits, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>

                                <TextBox Visibility="{Binding MetaRawVisible, Converter={StaticResource BooleanToVisibility}}"
                                         Text="{Binding MetaRawText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" AcceptsTab="True"
                                         TextWrapping="NoWrap"
                                         FontFamily="Consolas" FontSize="12"
                                         MinHeight="180"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         Margin="0,0,0,10" />

                                <ui:Button Content="Save meta"
                                           Appearance="Primary"
                                           HorizontalAlignment="Left"
                                           MinWidth="140"
                                           Click="OnMetaSave" />
                                <TextBlock Text="{Binding MetaStatusNote}" FontSize="10" Opacity="0.7"
                                           Margin="0,8,0,0" TextWrapping="Wrap"
                                           Foreground="#3FB950" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ctrl:DotMatrixLoader Grid.Column="0"
                                      LoaderStyle="BlockDrop"
                                      DotSize="5" DotSpacing="2"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibility}}" />

                <StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Summary}" FontSize="12" Opacity="0.85"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Summary}" />
                    <ProgressBar IsIndeterminate="True" Height="3" Margin="0,4,0,0"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibility}}" />
                </StackPanel>

                <ui:Button Grid.Column="2" Content="Open output"
                           Appearance="Secondary"
                           IsEnabled="{Binding HasOutput}"
                           Click="OnOpenOutput"
                           ToolTip="Open the produced resource folder.">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="FolderOpen24" />
                    </ui:Button.Icon>
                </ui:Button>
            </Grid>
        </Border>

        <Border x:Name="DropOverlay"
                Grid.RowSpan="3"
                Background="#33000000"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="10" Padding="28,18"
                    BorderThickness="2"
                    BorderBrush="{DynamicResource AccentControlElevationBorderBrush}">
                <TextBlock Text="Drop to add to queue" FontSize="15" FontWeight="SemiBold" />
            </Border>
        </Border>
    </Grid>
</UserControl>
