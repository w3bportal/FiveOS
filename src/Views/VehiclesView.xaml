<UserControl x:Class="FiveOS.Views.VehiclesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:vm="clr-namespace:FiveOS.ViewModels"
             xmlns:ctrl="clr-namespace:FiveOS.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver"
             DragEnter="OnDragEnter"
             DragLeave="OnDragLeave"
             d:DataContext="{d:DesignInstance vm:VehiclesViewModel}">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Round numbered step badge for the "① Add → ② Convert" guide. -->
        <Style x:Key="StepBadge" TargetType="Border">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="StepNumber" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="StepTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>

        <!-- Pill-segment RadioButton: two side-by-side as a Single | Pack strip. -->
        <Style x:Key="SegmentTab" TargetType="RadioButton">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Seg" CornerRadius="5" Padding="0,7" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Seg" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Seg" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Seg" Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ═══ Shared file-tree resources (used by the queue navigator) ═══ -->
        <ContextMenu x:Key="VehTreeMenu"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="Optimize (make smaller)" Click="OnOptimizeFile"
                      IsEnabled="{Binding CanOptimizeNode}"
                      ToolTip="Shrink this model or texture using the Advanced → shrink settings. Overwrites it in place.">
                <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowMinimize24" /></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Edit XML…" Click="OnEditXml" IsEnabled="{Binding IsMetaNode}"
                      ToolTip="Open this meta file (vehicles / handling / carcols / carvariations) in a text editor.">
                <MenuItem.Icon><ui:SymbolIcon Symbol="DocumentEdit24" /></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Rename…" Click="OnRename" IsEnabled="{Binding CanRename}"
                      ToolTip="Rename a file, or a whole car — its models/textures AND the spawn-name references in the metas.">
                <MenuItem.Icon><ui:SymbolIcon Symbol="Rename24" /></MenuItem.Icon>
            </MenuItem>
            <Separator />
            <MenuItem Header="Show in Explorer" Click="OnOpenFileFolder">
                <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24" /></MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <!-- Re-templated TreeViewItem: WE control the selection colour (accent fill
             behind light text) so it's readable in every state. -->
        <Style x:Key="VehTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="ContextMenu" Value="{StaticResource VehTreeMenu}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <EventSetter Event="MouseDoubleClick" Handler="OnTreeDoubleClick" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ToggleButton x:Name="Expander" Grid.Column="0" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Width="16" Height="22">
                                            <TextBlock x:Name="Arrow" Text="›" FontSize="14" Opacity="0.6"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       RenderTransformOrigin="0.5,0.5" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="RenderTransform">
                                                    <Setter.Value><RotateTransform Angle="90" /></Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Border x:Name="Bd" Grid.Column="1" CornerRadius="4" Padding="4,4" Margin="0,1"
                                    Background="Transparent" SnapsToDevicePixels="True">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Left" VerticalAlignment="Center" />
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Grid.Column="1" Margin="12,0,0,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Row: icon · name · detail · (× remove on car branches) -->
        <HierarchicalDataTemplate x:Key="VehTreeItemTemplate" ItemsSource="{Binding Children}">
            <Grid MinWidth="150" Margin="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="16" Opacity="0.85"
                               Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Name}" FontFamily="Consolas" FontSize="12.5"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />

                <!-- "Unoptimized" badge — shown only on cars whose textures/models
                     are still heavy; clears once they're optimized (files shrink). -->
                <Border Grid.Column="2"
                        Visibility="{Binding IsUnoptimized, Converter={StaticResource BooleanToVisibility}}"
                        CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                        Background="#26E0A33A" BorderBrush="#59E0A33A" BorderThickness="1"
                        VerticalAlignment="Center"
                        ToolTip="This car still has large textures/models. Right-click → Optimize to shrink them.">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="9" Foreground="#E0A33A"
                                       VerticalAlignment="Center" Margin="0,0,3,0" />
                        <TextBlock Text="unoptimized" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#E0A33A" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Column="3" Text="{Binding Detail}" FontSize="10.5" Margin="10,0,2,0"
                           Opacity="0.55" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="4" Click="OnRemoveCarNode"
                        Visibility="{Binding IsCar, Converter={StaticResource BooleanToVisibility}}"
                        Background="Transparent" BorderThickness="0" Padding="4,0" Margin="4,0,0,0"
                        Cursor="Hand" ToolTip="Remove this car from the pack">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" Opacity="0.7" />
                </Button>
            </Grid>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ───────── Header (shared by both modes; the segment on the right
             switches between the convert workspace and the hosted Carcols
             Fixer pane) ───────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border CornerRadius="6"
                            Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Padding="8" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Grid>
                            <ui:SymbolIcon Symbol="VehicleCar24" FontSize="20"
                                           Visibility="{Binding IsCarcolsMode, Converter={StaticResource InverseBooleanToVisibility}}" />
                            <ui:SymbolIcon Symbol="Wrench24" FontSize="20"
                                           Visibility="{Binding IsCarcolsMode, Converter={StaticResource BooleanToVisibility}}" />
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Vehicles" FontSize="15" FontWeight="SemiBold"
                                   Visibility="{Binding IsCarcolsMode, Converter={StaticResource InverseBooleanToVisibility}}" />
                        <TextBlock Text="Carcols Fixer" FontSize="15" FontWeight="SemiBold"
                                   Visibility="{Binding IsCarcolsMode, Converter={StaticResource BooleanToVisibility}}" />
                        <TextBlock Text="Turn a singleplayer car into a FiveM-ready vehicle. Add a car, hit Convert — done. Then right-click a file to make it smaller."
                                   FontSize="11" Opacity="0.6" Margin="0,2,0,0"
                                   Visibility="{Binding IsCarcolsMode, Converter={StaticResource InverseBooleanToVisibility}}" />
                        <TextBlock Text="Scan your vehicle resources for clashing modkit, siren and light-settings IDs — the silent cause of wrong tuning parts and broken sirens — and remap them automatically."
                                   FontSize="11" Opacity="0.6" Margin="0,2,0,0"
                                   Visibility="{Binding IsCarcolsMode, Converter={StaticResource BooleanToVisibility}}" />
                    </StackPanel>
                </StackPanel>

                <!-- Mode segment: convert workspace vs Carcols Fixer -->
                <Border Grid.Column="1" CornerRadius="6" Padding="2" Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0" GroupName="VehiclesTopMode"
                                     Style="{StaticResource SegmentTab}"
                                     Content="Convert" MinWidth="104"
                                     IsChecked="{Binding IsConvertMode, Mode=OneWay}"
                                     Click="OnModeConvert"
                                     ToolTip="The car-conversion workspace — turn SP add-on cars into FiveM resources." />
                        <RadioButton Grid.Column="1" GroupName="VehiclesTopMode"
                                     Style="{StaticResource SegmentTab}"
                                     Content="Carcols Fixer" MinWidth="104"
                                     IsChecked="{Binding IsCarcolsMode, Mode=OneWay}"
                                     Click="OnModeCarcols"
                                     ToolTip="Find modkit, siren and light-settings ID conflicts across your vehicle resources (wrong tuning parts, broken sirens) and remap them automatically." />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ───────── Body: guided steps | files | advanced ───────── -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsCarcolsMode, Converter={StaticResource InverseBooleanToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" MinWidth="220" MaxWidth="480" />
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="0.85*" MinWidth="180" MaxWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- Guided-steps sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,18">

                        <!-- ── STEP 1 — Add your car(s) ── -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Style="{StaticResource StepBadge}">
                                <TextBlock Text="1" Style="{StaticResource StepNumber}" />
                            </Border>
                            <TextBlock Text="Add your car" Style="{StaticResource StepTitle}" />
                        </StackPanel>

                        <!-- Single car vs Car pack (a queue of cars). -->
                        <Border CornerRadius="6" Padding="2" Margin="0,0,0,10"
                                IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0" GroupName="VehMode"
                                             Style="{StaticResource SegmentTab}"
                                             Content="Single car"
                                             IsChecked="{Binding MergeIntoPack, Converter={StaticResource InverseBoolean}, Mode=OneWay}"
                                             Click="OnModeSingle"
                                             ToolTip="Convert one car into its own FiveM resource." />
                                <RadioButton Grid.Column="1" GroupName="VehMode"
                                             Style="{StaticResource SegmentTab}"
                                             Content="Car pack"
                                             IsChecked="{Binding MergeIntoPack, Mode=OneWay}"
                                             Click="OnModePack"
                                             ToolTip="Queue up several cars and merge them into one resource." />
                            </Grid>
                        </Border>

                        <!-- ══ SINGLE-CAR view ══ -->
                        <Border Visibility="{Binding MergeIntoPack, Converter={StaticResource InverseBooleanToVisibility}}"
                                IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                Padding="16,18" MinHeight="128">
                            <Grid>
                                <!-- Empty: prompt + Browse -->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding HasInput, Converter={StaticResource InverseBooleanToVisibility}}">
                                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="26" Opacity="0.5" HorizontalAlignment="Center" />
                                    <TextBlock Text="Drag your car mod here"
                                               FontSize="13" FontWeight="SemiBold" Opacity="0.8"
                                               HorizontalAlignment="Center" Margin="0,8,0,2" />
                                    <TextBlock Text="a dlc.rpf file or its folder"
                                               FontSize="11" Opacity="0.5" HorizontalAlignment="Center" />
                                    <ui:Button Content="Browse files…"
                                               Appearance="Primary"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0"
                                               Click="OnBrowseInput"
                                               ToolTip="Pick your car's dlc.rpf file (or its folder)." />
                                </StackPanel>

                                <!-- Selected: name + change -->
                                <StackPanel Visibility="{Binding HasInput, Converter={StaticResource BooleanToVisibility}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="20"
                                                       Foreground="#3FB950" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="Car added" FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding InputDisplay}"
                                               FontSize="11" FontFamily="Consolas" Opacity="0.75"
                                               TextWrapping="Wrap" TextAlignment="Center"
                                               Margin="0,8,0,0" MaxHeight="72" TextTrimming="CharacterEllipsis" />
                                    <ui:Button Content="Change…"
                                               Appearance="Secondary"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0"
                                               Click="OnBrowseInput" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ══ CAR-PACK view: a queue of cars ══ -->
                        <StackPanel Visibility="{Binding MergeIntoPack, Converter={StaticResource BooleanToVisibility}}"
                                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}">
                            <TextBlock Text="PACK NAME" Style="{StaticResource SectionHeader}" />
                            <ui:TextBox Text="{Binding PackName, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="car_pack1"
                                        ToolTip="The merged resource's folder name (e.g. car_pack1). Leave blank to auto-name it." />

                            <ui:Button Content="Add a car…"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,8,0,0"
                                       Click="OnBrowseInput"
                                       ToolTip="Pick another car's dlc.rpf (or folder) to add to the pack. You can also drag several in at once.">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="Add24" />
                                </ui:Button.Icon>
                            </ui:Button>
                            <TextBlock Text="…or drag several dlc.rpf files / folders in at once."
                                       FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="2,6,0,0" />
                        </StackPanel>

                        <!-- Car-pack queue as a tree: each car a branch, expand to
                             its files. Click to preview; × removes a car; right-click
                             to optimize / edit / rename. -->
                        <StackPanel Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibility}}"
                                    Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,6">
                                <TextBlock Text="CARS IN THIS PACK" Style="{StaticResource SectionHeader}" Margin="0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding QueueCountText}" FontSize="11" Opacity="0.5"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                            <Border CornerRadius="8" BorderThickness="1" MaxHeight="300" MinHeight="86"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                    Padding="4,6">
                                <TreeView x:Name="FilesTree"
                                          ItemsSource="{Binding CarNodes}"
                                          ItemContainerStyle="{StaticResource VehTreeItemStyle}"
                                          ItemTemplate="{StaticResource VehTreeItemTemplate}"
                                          BorderThickness="0" Background="Transparent"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                          PreviewMouseLeftButtonDown="OnQueueMouseDown"
                                          SelectedItemChanged="OnTreeSelected" />
                            </Border>
                        </StackPanel>

                        <!-- …or a link -->
                        <TextBlock Text="…or paste a gta5-mods link"
                                   FontSize="11" Opacity="0.55" Margin="2,14,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding ModUrl, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="https://www.gta5-mods.com/vehicles/…"
                                        ToolTip="Paste a gta5-mods.com car page link. FiveOS downloads it and converts it for you." />
                            <ui:Button Grid.Column="1" Content="Get"
                                       Appearance="Secondary" Margin="6,0,0,0" Padding="14,0"
                                       IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                       Click="OnImportFromUrl"
                                       ToolTip="Download the mod from the link and convert it." />
                        </Grid>
                        <TextBlock Text="Links from mega / drive / mediafire can't be auto-downloaded — grab those yourself and drag them in."
                                   FontSize="10" Opacity="0.45" TextWrapping="Wrap" Margin="2,6,0,0" />

                        <!-- ── STEP 2 — Convert ── -->
                        <StackPanel Orientation="Horizontal" Margin="0,24,0,4">
                            <Border Style="{StaticResource StepBadge}">
                                <TextBlock Text="2" Style="{StaticResource StepNumber}" />
                            </Border>
                            <TextBlock Text="Convert to FiveM" Style="{StaticResource StepTitle}" />
                        </StackPanel>
                        <TextBlock FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Text="Single car converts automatically. For a pack, add all your cars, then click Convert." />

                        <ui:Button Content="Convert"
                                   Appearance="Primary"
                                   HorizontalAlignment="Stretch"
                                   Padding="0,11" FontSize="14" FontWeight="SemiBold"
                                   IsEnabled="{Binding CanConvert}"
                                   Click="OnConvert"
                                   ToolTip="Build the FiveM resource. For a car pack this merges every car in the queue into one resource.">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="VehicleCar24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Cancel conversion"
                                   Appearance="Danger"
                                   HorizontalAlignment="Stretch"
                                   Padding="0,11" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibility}}"
                                   Click="OnCancelConvert"
                                   ToolTip="Stop the conversion. For a car pack, cars already written stay; the rest are skipped.">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Dismiss24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <TextBlock Text="{Binding Summary}"
                                   FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="2,8,0,0" />

                        <!-- Warnings from the last conversion -->
                        <Border Visibility="{Binding HasReviewNotes, Converter={StaticResource BooleanToVisibility}}"
                                CornerRadius="6" BorderThickness="1" Margin="0,12,0,0"
                                BorderBrush="#E0A33A"
                                Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                Padding="10,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <ui:SymbolIcon Symbol="Warning24" FontSize="13" Foreground="#E0A33A" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="HEADS UP" FontSize="9" FontWeight="SemiBold" Opacity="0.8" VerticalAlignment="Center" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding ReviewNotes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="10" Opacity="0.85"
                                                       TextWrapping="Wrap" Margin="0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- File list — the produced resource's files, right-click to optimize -->
            <Grid Grid.Column="1" Margin="16"
                  Visibility="{Binding ShowFilesSection, Converter={StaticResource BooleanToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="2,0,2,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Your car's files" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="Click a car or file to preview. Right-click to optimize, edit or rename."
                                   FontSize="11" Opacity="0.55" Margin="0,1,0,0" />
                    </StackPanel>
                    <ui:Button Grid.Column="1" Content="Optimize everything"
                               Appearance="Primary" FontSize="12" Padding="12,6" VerticalAlignment="Center"
                               Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibility}}"
                               IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                               Click="OnOptimizeAll"
                               ToolTip="Shrink every model and texture in the resource at once.">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="ArrowMinimize24" />
                        </ui:Button.Icon>
                    </ui:Button>
                </Grid>

                <!-- Row 1: file tree | drag-handle | 3D preview & mods. -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="1.4*" MinWidth="160" />
                    </Grid.ColumnDefinitions>

                    <GridSplitter Grid.Column="1" Width="7" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                                  Background="Transparent" Cursor="SizeWE" ToolTip="Drag to resize the preview." />

                    <!-- Files (tree) -->
                    <Border Grid.Column="0" CornerRadius="8" BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Background="{DynamicResource ControlFillColorDefaultBrush}" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Search + sort toolbar (only once there are files) -->
                            <StackPanel Grid.Row="0" Margin="8,8,8,4"
                                        Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibility}}">
                                <ui:TextBox PlaceholderText="Search files…" FontSize="12"
                                            Text="{Binding FileSearch, UpdateSourceTrigger=PropertyChanged}">
                                    <ui:TextBox.Icon>
                                        <ui:SymbolIcon Symbol="Search24" />
                                    </ui:TextBox.Icon>
                                </ui:TextBox>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <!-- sort field -->
                                    <Border Grid.Column="0" CornerRadius="6" Padding="2"
                                            Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <RadioButton Grid.Column="0" GroupName="VehSort" Style="{StaticResource SegmentTab}"
                                                         Content="Size" Click="OnSortSize"
                                                         IsChecked="{Binding SortBySize, Mode=OneWay}"
                                                         ToolTip="Order by file size." />
                                            <RadioButton Grid.Column="1" GroupName="VehSort" Style="{StaticResource SegmentTab}"
                                                         Content="Type" Click="OnSortType"
                                                         IsChecked="{Binding SortByType, Mode=OneWay}"
                                                         ToolTip="Group models, textures and settings together." />
                                            <RadioButton Grid.Column="2" GroupName="VehSort" Style="{StaticResource SegmentTab}"
                                                         Content="Date" Click="OnSortDate"
                                                         IsChecked="{Binding SortByDate, Mode=OneWay}"
                                                         ToolTip="Order by when the file was last changed." />
                                        </Grid>
                                    </Border>
                                    <!-- direction -->
                                    <ui:Button Grid.Column="1" Margin="6,0,0,0" FontSize="11" Padding="10,0"
                                               Appearance="Secondary" VerticalAlignment="Stretch"
                                               Content="{Binding SortDirLabel}" Click="OnToggleSortDir"
                                               ToolTip="Flip the order (biggest↔smallest, newest↔oldest)." />
                                </Grid>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding HasFiles, Converter={StaticResource InverseBooleanToVisibility}}">
                                    <ui:SymbolIcon Symbol="VehicleCar24" FontSize="40" Opacity="0.25" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding FilesEmptyTitle}" FontSize="14" FontWeight="SemiBold" Opacity="0.6"
                                               HorizontalAlignment="Center" Margin="0,10,0,4" />
                                    <TextBlock Text="{Binding FilesEmptyHint}" FontSize="11.5" Opacity="0.5"
                                               TextAlignment="Center" TextWrapping="Wrap" MaxWidth="320" HorizontalAlignment="Center" />
                                </StackPanel>
                                <!-- MIDDLE detail = highlighted car's files + shared config. -->
                                <TreeView ItemsSource="{Binding MiddleNodes}"
                                          ItemContainerStyle="{StaticResource VehTreeItemStyle}"
                                          ItemTemplate="{StaticResource VehTreeItemTemplate}"
                                          BorderThickness="0" Background="Transparent" Padding="6,8"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolean}}"
                                          Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibility}}"
                                          SelectedItemChanged="OnTreeSelected" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 3D preview + mods (Col 2) -->
                <Grid Grid.Column="2" Margin="6,0,0,0" Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="120" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 3D preview (fills the available height) -->
                    <Border Grid.Row="0"
                            CornerRadius="8" BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Background="#0d0d10" ClipToBounds="True">
                        <Grid>
                            <wv2:WebView2 x:Name="CarPreview" DefaultBackgroundColor="#0d0d10" />

                            <!-- hint before a model is picked -->
                            <StackPanel x:Name="PreviewHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        IsHitTestVisible="False">
                                <ui:SymbolIcon Symbol="VehicleCar24" FontSize="30" Opacity="0.3"
                                               Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="Click a .yft model to preview it"
                                           FontSize="12" Opacity="0.5" Foreground="White"
                                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="220"
                                           HorizontalAlignment="Center" Margin="0,8,0,0" />
                            </StackPanel>

                            <!-- texture / model loading spinner -->
                            <StackPanel x:Name="PreviewLoader" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="Collapsed" IsHitTestVisible="False">
                                <ctrl:DotMatrixLoader LoaderStyle="BlockDrop" DotSize="5" DotSpacing="2"
                                                      HorizontalAlignment="Center" />
                                <TextBlock x:Name="PreviewLoaderText" Text="Loading…"
                                           FontSize="11" Opacity="0.8" Foreground="White"
                                           HorizontalAlignment="Center" Margin="0,10,0,0" />
                            </StackPanel>

                            <TextBlock x:Name="CarMeshInfoText"
                                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                       Margin="10,0,10,7" FontSize="10" Opacity="0.65"
                                       Foreground="White" IsHitTestVisible="False"
                                       TextTrimming="CharacterEllipsis" Text="" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,7,7,0">
                                <ui:Button x:Name="GtaFolderBtn" Content="GTA folder"
                                           Appearance="Secondary" FontSize="10" Padding="8,3"
                                           Click="OnSetGtaFolder"
                                           ToolTip="Point at your GTA V install so bodies/trim show GTA's shared vehicle textures (vehshare). Nothing is copied." />
                                <ui:Button Content="↺" Appearance="Secondary" FontSize="11" Padding="9,3" Margin="5,0,0,0"
                                           Click="OnCarRecenter" ToolTip="Recenter — reset the camera to frame the model." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Mods controls: paint colour + open doors + toggle parts -->
                    <Border Grid.Row="1" Margin="0,10,0,0" MaxHeight="270"
                            CornerRadius="8" BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="14,12">
                                <TextBlock Text="PAINT COLOUR" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                                <WrapPanel>
                                    <WrapPanel.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="Width" Value="24" />
                                            <Setter Property="Height" Value="24" />
                                            <Setter Property="CornerRadius" Value="4" />
                                            <Setter Property="Margin" Value="0,0,6,6" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                                        </Style>
                                    </WrapPanel.Resources>
                                    <Border Background="#9A9EA3" Tag="9A9EA3" MouseLeftButtonUp="OnPaintColor" ToolTip="Silver" />
                                    <Border Background="#E8E8EA" Tag="E8E8EA" MouseLeftButtonUp="OnPaintColor" ToolTip="White" />
                                    <Border Background="#1A1A1D" Tag="1A1A1D" MouseLeftButtonUp="OnPaintColor" ToolTip="Black" />
                                    <Border Background="#3A3F44" Tag="3A3F44" MouseLeftButtonUp="OnPaintColor" ToolTip="Gunmetal" />
                                    <Border Background="#B01818" Tag="B01818" MouseLeftButtonUp="OnPaintColor" ToolTip="Red" />
                                    <Border Background="#1E3A8A" Tag="1E3A8A" MouseLeftButtonUp="OnPaintColor" ToolTip="Blue" />
                                    <Border Background="#1E6B3A" Tag="1E6B3A" MouseLeftButtonUp="OnPaintColor" ToolTip="Green" />
                                    <Border Background="#D4A017" Tag="D4A017" MouseLeftButtonUp="OnPaintColor" ToolTip="Gold" />
                                    <Border Background="#C2560F" Tag="C2560F" MouseLeftButtonUp="OnPaintColor" ToolTip="Orange" />
                                </WrapPanel>

                                <ui:ToggleSwitch x:Name="DoorsToggle" Content="Open doors"
                                                 IsEnabled="False" FontSize="12" Margin="0,8,0,0"
                                                 Checked="OnDoorsToggled" Unchecked="OnDoorsToggled"
                                                 ToolTip="Swing the doors / bonnet / boot open (approximate hinge angles). Only works when the model separates them from the chassis." />
                                <TextBlock Text="PARTS &amp; EXTRAS" Style="{StaticResource SectionHeader}" Margin="0,14,0,6" />
                                <ItemsControl x:Name="PartsList" />
                                <TextBlock Text="Untick a part to hide it (extras, spoilers, accessories)."
                                           FontSize="10" Opacity="0.45" TextWrapping="Wrap" Margin="0,6,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
                </Grid>
            </Grid>

            <!-- ── Advanced sidebar (right) ── -->
            <Border Grid.Column="2"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18,18">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="16" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Advanced" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="Optional — the defaults already work for most cars. Single-car vs Car-pack is chosen up in step ①."
                                   FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="0,0,0,4" />

                        <!-- Same binding as PACK NAME in step ① — hide the duplicate when Car pack is on. -->
                        <StackPanel Visibility="{Binding MergeIntoPack, Converter={StaticResource InverseBooleanToVisibility}}">
                            <TextBlock Text="RESOURCE NAME" Style="{StaticResource SectionHeader}" Margin="0,18,0,8" />
                            <ui:TextBox Text="{Binding PackName, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="auto (from the car's name)"
                                        ToolTip="The FiveM resource folder name. Leave blank to name it automatically." />
                        </StackPanel>

                        <TextBlock Text="SAVE TO" Style="{StaticResource SectionHeader}" Margin="0,18,0,8" />
                        <Border CornerRadius="6"
                                Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                Padding="10,8">
                            <TextBlock Text="{Binding OutputPath}"
                                       FontSize="11" FontFamily="Consolas"
                                       TextWrapping="Wrap" Opacity="0.85" />
                        </Border>
                        <ui:Button Content="Change folder…"
                                   Appearance="Secondary"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,8,0,0"
                                   Click="OnBrowseOutput"
                                   ToolTip="Choose where the FiveM resource folder is written." />

                        <TextBlock Text="HOW MUCH TO SHRINK" Style="{StaticResource SectionHeader}" Margin="0,18,0,8" />
                        <TextBlock Text="{Binding KeepRatioDisplay}" FontSize="11" Opacity="0.75" Margin="0,0,0,4" />
                        <Slider x:Name="OptimizeSlider"
                                Minimum="0.05" Maximum="0.95" SmallChange="0.05" LargeChange="0.1"
                                Value="{Binding KeepRatio, Mode=TwoWay}"
                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                ToolTip="How much of the model's detail to keep when you Optimize. 50% roughly halves the polycount." />
                        <CheckBox Content="Keep panel edges crisp"
                                  IsChecked="{Binding PreserveBoundary, Mode=TwoWay}"
                                  FontSize="11" Margin="0,6,0,0"
                                  ToolTip="Lock the open edges of each body piece so panels don't tear when shrunk." />
                        <CheckBox x:Name="TextureDownsizeCheck" Content="Shrink huge textures"
                                  IsChecked="True"
                                  FontSize="11" Margin="0,6,0,0"
                                  ToolTip="Cap any texture bigger than 1K down to 1024px (halves a 2K, quarters a 4K) — the standard FiveM vehicle target." />
                        <TextBlock Text="These apply when you right-click a file → Optimize."
                                   FontSize="10" Opacity="0.45" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ───────── Footer ───────── -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Padding="16,12"
                Visibility="{Binding IsCarcolsMode, Converter={StaticResource InverseBooleanToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ctrl:DotMatrixLoader Grid.Column="0"
                                      LoaderStyle="BlockDrop"
                                      DotSize="5" DotSpacing="2"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibility}}" />

                <StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Summary}" FontSize="12" Opacity="0.85"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Summary}" />
                    <ProgressBar IsIndeterminate="True" Height="3" Margin="0,4,0,0"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibility}}" />
                </StackPanel>

                <ui:Button Grid.Column="2" Content="Open output folder"
                           Appearance="Secondary"
                           IsEnabled="{Binding HasOutput}"
                           Click="OnOpenOutput"
                           ToolTip="Open the produced resource folder in Explorer. Copy it into your server's resources/ and add `ensure` it.">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="FolderOpen24" />
                    </ui:Button.Icon>
                </ui:Button>
            </Grid>
        </Border>

        <!-- ══ CARCOLS FIXER mode — hosted pane. The VM is the singleton
             MainViewModel.CarcolsVm (resolved to CarcolsFixerView by the
             App.xaml DataTemplate), so scan results survive mode and tab
             switches. Same hosting pattern as the txAdmin card in Optimize. ══ -->
        <ContentControl Grid.Row="1" Grid.RowSpan="2"
                        Content="{Binding DataContext.CarcolsVm, RelativeSource={RelativeSource AncestorType=Window}}"
                        Visibility="{Binding IsCarcolsMode, Converter={StaticResource BooleanToVisibility}}" />

        <!-- Drag-drop highlight overlay -->
        <Border x:Name="DropOverlay"
                Grid.RowSpan="3"
                Background="#33000000"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="10" Padding="28,18"
                    BorderThickness="2"
                    BorderBrush="{DynamicResource AccentControlElevationBorderBrush}">
                <TextBlock Text="Drop your car mod here (dlc.rpf file or folder)" FontSize="15" FontWeight="SemiBold" />
            </Border>
        </Border>
    </Grid>
</UserControl>
