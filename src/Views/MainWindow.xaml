<ui:FluentWindow x:Class="FiveOS.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:FiveOS.ViewModels"
                 xmlns:local="clr-namespace:FiveOS.Views"
                 xmlns:ctrl="clr-namespace:FiveOS.Views.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 xmlns:loc="clr-namespace:FiveOS.Markup"
                 xmlns:svc="clr-namespace:FiveOS.Services"
                 mc:Ignorable="d"
                 Title="FiveOS"
                 Icon="pack://application:,,,/Assets/Branding/FiveOS.ico"
                 Height="940" Width="1520"
                 MinHeight="480" MinWidth="720"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen"
                 WindowState="Maximized"
                 AllowDrop="True"
                 Drop="OnFileDropped"
                 DragOver="OnDragOver"
                 PreviewDrop="OnFileDropped"
                 PreviewDragOver="OnDragOver"
                 PreviewKeyDown="OnWindowKeyDown"
                 d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.InputBindings>
        <!-- Undo/redo shortcuts. Ctrl+Y is the Windows-standard redo;
             Ctrl+Shift+Z is also accepted for muscle-memory parity with
             Mac / Adobe / VS Code. -->
        <KeyBinding Key="Z" Modifiers="Control"
                    Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control"
                    Command="{Binding RedoCommand}" />
        <KeyBinding Key="Z" Modifiers="Control+Shift"
                    Command="{Binding RedoCommand}" />
        <KeyBinding Key="R" Modifiers="Control"
                    Command="{Binding ToggleReferencePedCommand}" />
        <KeyBinding Key="L" Modifiers="Control"
                    Command="{Binding ToggleLayersPanelCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <!-- Tiny "section header" for sidebar: small caps, dimmed, letter-spaced. -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="Margin" Value="16,18,16,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>

        <!-- Inline label above a control. -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- Stat card row used in the GEOMETRY section. -->
        <Style x:Key="StatRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <!-- ─── Skeleton loading ───
             A horizontal-shimmer placeholder for content that's loading.
             x:Shared="False" forces a fresh brush per consumer so each
             skeleton's animation runs independently (animations require
             unfrozen brushes; without x:Shared the brush is reused and
             only the first instance animates). -->
        <LinearGradientBrush x:Key="SkeletonShimmerBrush"
                             x:Shared="False"
                             StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#15FFFFFF" Offset="0.0" />
            <GradientStop Color="#3AFFFFFF" Offset="0.5" />
            <GradientStop Color="#15FFFFFF" Offset="1.0" />
            <LinearGradientBrush.Transform>
                <TranslateTransform X="-1" />
            </LinearGradientBrush.Transform>
        </LinearGradientBrush>

        <Style x:Key="Skeleton" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{StaticResource SkeletonShimmerBrush}" />
            <Setter Property="MinHeight" Value="14" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation
                                Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.Transform).(TranslateTransform.X)"
                                From="-1" To="2"
                                Duration="0:0:1.4" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- ─── Underlined horizontal tab look ───
             A flat tab header (no pill / no panel border) with a 2-px
             accent underline that animates in on hover and stays solid
             when selected. Used by both the top-level TabControl and the
             sidebar File/Sketchfab TabControl so they look uniform. -->
        <Style x:Key="UnderlineTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="2" />
                            </Grid.RowDefinitions>
                            <ContentPresenter Grid.Row="0"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                            <Border Grid.Row="1"
                                    x:Name="Underline"
                                    Background="{DynamicResource SystemAccentColorBrush}"
                                    Opacity="0"
                                    HorizontalAlignment="Stretch"
                                    SnapsToDevicePixels="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Order matters: IsMouseOver runs first so
                                 IsSelected wins when both are true. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Reorderable variant: same look as UnderlineTabItem but injects
             a vertical-dots "grip" handle in front of the header text when
             the parent window's IsTabEditMode is true. Used by the top-level
             tab strip; the inner File/Sketchfab strip keeps the plain style. -->
        <Style x:Key="ReorderableUnderlineTabItem" TargetType="TabItem"
               BasedOn="{StaticResource UnderlineTabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="2" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}">
                                <!-- Grip dots: ⠿ (Braille pattern dots-12345678).
                                     Hidden until edit mode flips on. -->
                                <TextBlock x:Name="Grip"
                                           Text="⠿"
                                           FontSize="14"
                                           Margin="0,0,6,0"
                                           Opacity="0.55"
                                           Visibility="Collapsed"
                                           VerticalAlignment="Center" />
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  TextElement.FontSize="{TemplateBinding FontSize}"
                                                  TextElement.FontWeight="{TemplateBinding FontWeight}" />
                            </StackPanel>
                            <Border Grid.Row="1"
                                    x:Name="Underline"
                                    Background="{DynamicResource SystemAccentColorBrush}"
                                    Opacity="0"
                                    HorizontalAlignment="Stretch"
                                    SnapsToDevicePixels="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsTabEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter TargetName="Grip" Property="Visibility" Value="Visible" />
                                <Setter Property="Cursor" Value="SizeAll" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UnderlineTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource UnderlineTabItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- Header strip with a hairline divider so the
                                 underline sits directly on top of it. -->
                            <Border Grid.Row="0"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                                <TabPanel x:Name="HeaderPanel"
                                          IsItemsHost="True"
                                          Background="Transparent"
                                          KeyboardNavigation.TabIndex="1" />
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="{TemplateBinding Padding}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Activity-rail ListBoxItem ───
             Win11-style nav pill: rounded background, accent left bar
             when selected, hover/selected colors that match the rest
             of the app. Icon + label live inside the item template
             (in the XAML below) — keeping that structure means the
             SymbolIcon's font inheritance isn't broken by a Button
             content presenter wrapping it. -->
        <!-- Plain Border-based rail item (replaces the ListBoxItem template
             so wpf-ui's theme can't slip in a sharp left-edge accent). The
             owning Border supplies its own selected-state DataTrigger
             inline. -->
        <!-- C4D-style left palette button: square, flat, 2-px bottom accent
             when selected. The corner-radius is intentionally 2 px so the
             icons line up edge-to-edge like Cinema 4D's tool palette. -->
        <Style x:Key="RailItem" TargetType="Border">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="6,2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,2,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- C4D-style top command-palette button. Tiny flat icon, 2-px
             radius, ghost background, blue-ish hover. The whole bar reads
             as a strip of icons separated by tone — exactly how C4D's
             command palette renders above its viewport. -->
        <Style x:Key="C4DPaletteButton" TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- 1-px vertical separator used between command-palette groups. -->
        <Style x:Key="C4DPaletteSeparator" TargetType="Border">
            <Setter Property="Width" Value="1" />
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="Background" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <!-- C4D-style coordinate field: tiny axis label + read-only numeric
             box, monospace. Used in the bottom Coordinate Manager strip. -->
        <Style x:Key="C4DCoordLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,4,0" />
        </Style>
        <Style x:Key="C4DCoordValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>

        <!-- Legacy RailButton (kept for any leftover callers; new rail uses RailListItem). -->
        <Style x:Key="RailButton" TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- TitleBar -->
            <RowDefinition Height="Auto" />
            <!-- Menu -->
            <RowDefinition Height="*" />
            <!-- TabControl (per-tab content) -->
            <RowDefinition Height="Auto" />
            <!-- Status bar (shared across tabs) -->
        </Grid.RowDefinitions>

        <!-- ───────── Title bar ─────────
             Painted with the C4D panel-deep tone so the chrome reads as
             one continuous dark strip down to the menu / command palette. -->
        <Border Grid.Row="0" Background="{DynamicResource ApplicationBackgroundBrush}">
            <ui:TitleBar Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                         ShowMaximize="True"
                         ShowMinimize="True"
                         ShowClose="True">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Assets/Branding/FiveOS.png" />
                </ui:TitleBar.Icon>
                <!-- Update badge — top-right, next to the caption buttons.
                     Lit by the background update poll; stays visible even
                     after "Skip" so the update is always one click away. -->
                <ui:TitleBar.Header>
                    <ui:Button x:Name="UpdateBadgeButton"
                               Margin="0,4,8,4"
                               Padding="10,2"
                               FontSize="11"
                               Appearance="Info"
                               Click="OnUpdateBadgeClick"
                               ToolTip="A newer FiveOS is available — click to see what's new and install it."
                               Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibility}}"
                               Content="{Binding UpdateBadgeLabel}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="ArrowDownload24" />
                        </ui:Button.Icon>
                    </ui:Button>
                </ui:TitleBar.Header>
            </ui:TitleBar>
        </Border>

        <!-- ───────── Menu ─────────
             The classic C4D-style top bar (File / Edit / View / Settings /
             Help). Kept inside a StackPanel in row 1 so the grid rows below
             don't need renumbering. -->
        <StackPanel Grid.Row="1" Background="{DynamicResource ApplicationBackgroundBrush}">
        <Menu Background="Transparent"
              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
              Padding="8,2,8,4">
                <MenuItem Header="{loc:Loc Menu.File}">
                    <MenuItem Header="{loc:Loc Menu.OpenModel}"
                              InputGestureText="Ctrl+O"
                              Click="OnFileOpen"
                              ToolTip="Load a 3D file (.obj/.glb/.gltf/.fbx/.dae/.ply/.stl) into the 3D Model tab" />
                    <MenuItem Header="{loc:Loc Menu.BatchConvert}"
                              InputGestureText="Ctrl+Shift+O"
                              Click="OnFileBatchConvert"
                              ToolTip="Queue up to 30 source meshes and convert them in one shot into a single FiveM resource." />
                    <MenuItem Header="{loc:Loc Menu.AddTextures}"
                              InputGestureText="Ctrl+T"
                              Click="OnFileAddTextures"
                              ToolTip="Queue PNG/DDS files for the Texture Optimize tab" />
                    <MenuItem Header="{loc:Loc Menu.OpenMapFolder}"
                              InputGestureText="Ctrl+M"
                              Click="OnFileOpenMapFolder"
                              ToolTip="Select a map's resources folder (.ytd files) for the Mapping Optimize tab" />
                    <Separator />
                    <MenuItem Header="Emote">
                        <MenuItem Header="Open Rigged Model…"
                                  Click="OnFileEmoteOpenRig"
                                  ToolTip="Load a rigged .glb / .fbx into the Emote workspace." />
                        <MenuItem Header="GTA Male Skeleton"
                                  Click="OnFileEmoteGtaMale"
                                  ToolTip="Load the synthetic mp_m_freemode_01 skeleton." />
                        <MenuItem Header="GTA Female Skeleton"
                                  Click="OnFileEmoteGtaFemale"
                                  ToolTip="Load the synthetic mp_f_freemode_01 skeleton." />
                        <Separator />
                        <MenuItem Header="Video &gt; Emote"
                                  Click="OnFileEmoteVideoToEmote"
                                  ToolTip="Turn a short video into an emote via FiveOS Cloud." />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="{loc:Loc Menu.OpenOutput}"
                              Click="OnFileOpenOutput"
                              ToolTip="Open the folder where converted props land (Downloads by default). Optimize results overwrite in place next to the source." />
                    <MenuItem Header="Welcome screen"
                              Click="OnShowWelcome"
                              ToolTip="Reopen the Welcome screen — recent files and a quick launcher for every tool." />
                    <Separator />
                    <MenuItem Header="{loc:Loc Menu.Exit}"
                              InputGestureText="Alt+F4"
                              Click="OnFileExit" />
                </MenuItem>
                <MenuItem Header="{loc:Loc Menu.Edit}">
                    <MenuItem Header="{loc:Loc Menu.Undo}"
                              InputGestureText="Ctrl+Z"
                              Command="{Binding UndoCommand}"
                              ToolTip="Step back through sidebar edits — collision, material, asset toggles, prop name, etc." />
                    <MenuItem Header="{loc:Loc Menu.Redo}"
                              InputGestureText="Ctrl+Y"
                              Command="{Binding RedoCommand}"
                              ToolTip="Re-apply an undone edit." />
                </MenuItem>
                <MenuItem Header="{loc:Loc Menu.View}">
                    <MenuItem Header="{loc:Loc Menu.ShowReferencePed}"
                              InputGestureText="Ctrl+R"
                              IsCheckable="True"
                              IsChecked="{Binding ShowReferencePed, Mode=TwoWay}"
                              Click="OnViewToggleReference"
                              ToolTip="Show a 1.75m-ish humanoid model alongside your prop, with a height ruler — useful for sanity-checking scale." />
                    <MenuItem Header="{loc:Loc Menu.ChooseReference}"
                              Click="OnViewChooseReference"
                              ToolTip="Pick the model used as the scale reference. Defaults to ~/Downloads/ped_scale.fbx." />
                    <MenuItem Header="{loc:Loc Menu.ResetDefault}"
                              Click="OnViewResetReference"
                              ToolTip="Restore the default ped_scale.fbx reference path." />
                    <Separator />
                    <MenuItem Header="{loc:Loc Menu.LayersPanel}"
                              InputGestureText="Ctrl+L"
                              IsCheckable="True"
                              IsChecked="{Binding IsLayersPanelOpen, Mode=TwoWay}"
                              ToolTip="Show / hide the per-part layers panel — toggle visibility of named meshes. Hidden parts are excluded from the converted YDR." />
                </MenuItem>
                <MenuItem Header="{loc:Loc Menu.Settings}"
                          Click="OnSettingsOpen"
                          InputGestureText="Ctrl+,"
                          ToolTip="API keys, output folders, language and other preferences." />
                <MenuItem Header="{loc:Loc Menu.Help}">
                    <MenuItem Header="{loc:Loc Menu.CheckUpdates}"
                              Click="OnHelpCheckForUpdates"
                              ToolTip="Compare your build to the latest release on github.com/w3bportal/FiveOS." />
                    <Separator />
                    <MenuItem Header="{loc:Loc Menu.About}"
                              Click="OnHelpAbout" />
                </MenuItem>
        </Menu>

        <!-- (Command palette removed — every action lives in the menu above;
             the palette buttons were half-wired and duplicated it.) -->
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT AREA: ~180px nav rail on the left (icon + label)
             plus one feature view at a time on the right. Each rail button
             flips ActiveView; the selected one tints its background +
             foreground. Width is wide enough to fit the longest label
             ("Image → 3D") with breathing room on both sides.
             ═══════════════════════════════════════════════════════════════ -->
        <!-- Collapse the entire content region (rail + all views) while the
             Settings overlay is open. Required because the 3D viewports are
             native WebView2 HwndHosts that ignore WPF z-order (the "airspace"
             problem) — an opaque overlay drawn on top of them still lets the
             3D model punch through. Hiding the content makes WebView2 drop its
             native window so Settings renders cleanly. Restored on close. -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsSettingsOpen, Converter={StaticResource InverseBooleanToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ─── Activity rail (left) ───
                 Fixed-width nav rail with icon + label per row. The
                 collapse / hover-expand mechanic was removed when the
                 burger toggle came out — the rail stays expanded so users
                 always see what each icon means (the icon-only 42px rail
                 that shipped before left every workspace unlabelled). -->
            <Border Grid.Column="0"
                    x:Name="ActivityRail"
                    Width="176"
                    Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"><!--
                    Rail is ALWAYS visible — the built-in workspaces (3D
                    Model / Optimize / Mods→RPF / Emotes) live here
                    and are the user's only navigation path. The
                    HasAnyAddons gate that used to sit on this Border was
                    a bug: it correctly hides the ADDONS divider + caption
                    below, but accidentally hid the whole rail on fresh
                    installs with no addons enabled, stranding users on
                    the default 3D view with no way to reach the others.
                    -->
                <DockPanel LastChildFill="True">
                    <!-- Feature view list — plain Border rows in a StackPanel
                         (not a ListBox) because the wpf-ui ListBoxItem theme
                         was painting a sharp left-edge accent that ignored
                         our custom template. Each Border carries its target
                         AppView name in Tag (used by the click handler) and
                         picks up its selected/hover styling from the
                         RailItem style; per-item DataTriggers on the matching
                         IsXView flag tint the active row. -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0">
                    <StackPanel Margin="0,6,0,0">
                        <!-- Home/Dashboard was retired — the app boots straight
                             into the 3D Model tool and a Blender-style Welcome
                             splash (recent files + quick tools) floats over it
                             on launch (File → Welcome screen reopens it). -->

                        <!-- 3D Model rail entry — opens the Props view (the
                             3D Model / Weapons inner toggle picks the sub-
                             mode). -->
                        <Border Tag="3D"
                                ToolTip="3D Model — convert 3D files (.fbx/.glb/.obj/etc.) into FiveM-ready .ydr drawables. Includes prop and weapon export modes."
                                MouseLeftButtonUp="OnRailItemClick">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource RailItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Is3DView}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Cube24" FontSize="18" Margin="11,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Loc Rail.Model3D}" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- Optimize rail entry — promoted out of the inner
                             segmented control so it reads as a peer workspace
                             rather than a sub-tab of the 3D Model flow.
                             Routes through OnInnerToggleClick so the same
                             "abandon current 3D session?" prompt fires when
                             the user has work in flight. -->
                        <Border Tag="Optimize"
                                ToolTip="Optimize — batch-shrink existing FiveM assets. Decimate drawables (.ydr/.ydd/.yft), downscale textures (.ytd), and rebuild collision (.ybn) without re-exporting from source."
                                MouseLeftButtonUp="OnInnerToggleClick">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource RailItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOptimizeView}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Sparkle24" FontSize="18" Margin="11,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Loc Rail.Optimize}" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- Emotes rail entry — Animation → Emote (clip
                             converter) and Pose → Emote (posing workspace)
                             combined into one tab with mode cards
                             (EmotesView), like Optimize's mode picker. -->
                        <Border Tag="Emotes"
                                Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}"
                                ToolTip="Emotes — convert a baked animation clip (.glb/.gltf/.fbx) into a .ycd emote, or author poses and keyframe emotes from scratch."
                                MouseLeftButtonUp="OnRailItemClick">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource RailItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEmotesView}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="EmojiHand24" FontSize="18" Margin="11,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Loc Rail.Emotes}" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- Vehicles rail entry — SP car → FiveM studio
                             (convert, 3D preview, sounds, handling). -->
                        <Border Tag="Vehicles"
                                Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}"
                                ToolTip="Vehicles — turn singleplayer add-on cars (dlc.rpf or a gta5-mods link) into FiveM resources, preview them in 3D, audition engine sounds, and tune handling."
                                MouseLeftButtonUp="OnRailItemClick">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource RailItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVehiclesView}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="VehicleCar24" FontSize="18" Margin="11,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Loc Rail.Vehicles}" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- (Carcols Fixer was its own rail entry; it's now a
                             mode inside the Vehicles tab — OpenView("Carcols")
                             still deep-links there.) -->

                        <!-- RPF rail entry — pack a loose FiveM resource
                             folder into a single OPEN .rpf archive. Plain
                             OnRailItemClick (no in-flight 3D-session prompt);
                             "Rpf" Tag round-trips through OpenView's
                             Enum.TryParse onto AppView.Rpf. -->
                        <Border Tag="Rpf"
                                Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}"
                                ToolTip="RPF — pack a loose FiveM resource folder (stream assets + meta) into a single OPEN .rpf that opens in OpenIV / CodeWalker."
                                MouseLeftButtonUp="OnRailItemClick">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource RailItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRpfView}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Archive24" FontSize="18" Margin="11,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Loc Rail.Rpf}" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- ADDONS group: optional features the user opts into
                             via Settings → Addons. The divider + caption only
                             render when at least one addon is enabled, so a
                             fresh install just shows the 3D entry. -->
                        <Border Margin="10,12,10,6"
                                Height="1"
                                Background="{DynamicResource ControlElevationBorderBrush}"
                                Opacity="0.5"
                                Visibility="{Binding HasAnyAddons, Converter={StaticResource BooleanToVisibility}}" />
                        <TextBlock Text="ADDONS"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Opacity="0.45"
                                   HorizontalAlignment="Left"
                                   Margin="14,0,0,4"
                                   Visibility="{Binding HasAnyAddons, Converter={StaticResource BooleanToVisibility}}" />

                        <!-- One rail entry per enabled third-party plugin.
                             The Tag holds "plugin:&lt;id&gt;" so the rail
                             click handler routes through OpenViewCommand
                             and the active-style trigger fires when that
                             plugin id matches ActivePluginId. -->
                        <ItemsControl ItemsSource="{Binding EnabledPluginRailEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Tag="{Binding RailTag}"
                                            ToolTip="{Binding Name}"
                                            MouseLeftButtonUp="OnRailItemClick">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource RailItem}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource StringEquals}">
                                                                <Binding Path="DataContext.ActivePluginId" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                <Binding Path="Id" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <!-- Fallback to a generic puzzle-piece icon. Plugins
                                             that ship a custom PNG can be wired up later — the
                                             rail's 18px slot is a tight fit for arbitrary art. -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:SymbolIcon Symbol="PuzzlePiece24" FontSize="18" Margin="11,0,12,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="118" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- View-swap container (right) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- Inner-mode segmented toggle (3D only) -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Inner mode toggle for the unified 3D entry. Only renders
                     when Is3DView is true so plugin views get the full pane
                     height. -->
                <Border Grid.Row="0"
                        Padding="16,10,16,8"
                        Visibility="{Binding Is3DView, Converter={StaticResource BooleanToVisibility}}">
                    <Border CornerRadius="6"
                            Padding="3"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="3D Model"
                                       Click="OnInnerToggleClick"
                                       Tag="Props"
                                       Padding="14,4"
                                       FontSize="12"
                                       Appearance="Transparent"
                                       ToolTip="Static prop / map asset export. Outputs .ydr (drawable), .ybn (optional collision), and .ytyp (archetype) ready to drop into a FiveM resource folder. This is the most common workflow.">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Style.Triggers>
                                            <!-- Active only when Props view is showing AND we're
                                                 in Prop sub-mode — the same IsPropsView is also
                                                 true during Weapon mode so we have to bracket
                                                 with IsPropMode to keep the highlight on the
                                                 right toggle. -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsPropsView}" Value="True" />
                                                    <Condition Binding="{Binding IsPropMode}"  Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                            <!-- Weapons mode removed (to be re-added later). -->
                        </StackPanel>
                    </Border>
                </Border>

                <!-- The actual view-swap container; rows-shifted to row 1 so
                     the toggle bar sits above when in 3D mode. -->
                <Grid Grid.Row="1">

                <!-- ════ DASHBOARD (landing screen) ════ -->
                <Grid Visibility="{Binding IsDashboard, Converter={StaticResource BooleanToVisibility}}">
                    <Grid.Resources>
                        <Style x:Key="DashTile" TargetType="Border">
                            <Setter Property="Width" Value="238" />
                            <Setter Property="Height" Value="158" />
                            <Setter Property="Margin" Value="9" />
                            <Setter Property="Padding" Value="18,16" />
                            <Setter Property="CornerRadius" Value="10" />
                            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Resources>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24,28">
                            <TextBlock Text="{loc:Loc Dashboard.Welcome}"
                                       FontSize="30" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="{loc:Loc Dashboard.Subtitle}"
                                       FontSize="14" Opacity="0.6" HorizontalAlignment="Center" Margin="0,4,0,26" />
                            <WrapPanel HorizontalAlignment="Center" MaxWidth="796">
                                <Border Style="{StaticResource DashTile}" Tag="Props" MouseLeftButtonUp="OnDashboardCardClick">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="Cube24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.PropsTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.PropsDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashTile}" Tag="Optimize" MouseLeftButtonUp="OnDashboardCardClick">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="Sparkle24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.OptimizeTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.OptimizeDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashTile}" Tag="TxAdmin" MouseLeftButtonUp="OnDashboardCardClick"
                                        Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="Server24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.TxAdminTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.TxAdminDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashTile}" Tag="Emotes" MouseLeftButtonUp="OnDashboardCardClick"
                                        Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="EmojiHand24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.EmotesTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.EmotesDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashTile}" Tag="Vehicles" MouseLeftButtonUp="OnDashboardCardClick"
                                        Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="VehicleCar24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.VehiclesTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.VehiclesDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashTile}" Tag="Rpf" MouseLeftButtonUp="OnDashboardCardClick"
                                        Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="Archive24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.RpfTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.RpfDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ════ 3D → PROP VIEW ════ -->
                <Grid Visibility="{Binding IsPropsView, Converter={StaticResource BooleanToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <!-- Sidebar + viewport -->
                        <RowDefinition Height="Auto" />
                        <!-- Pack panel (visible when Pack mode is on) -->
                        <RowDefinition Height="Auto" />
                        <!-- Footer (prop name + convert) -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" MinWidth="160" MaxWidth="420" />
                            <!-- Sidebar (drag the splitter to resize) -->
                            <ColumnDefinition Width="4" />
                            <!-- Splitter -->
                            <ColumnDefinition Width="*" MinWidth="160" />
                            <!-- Viewport -->
                        </Grid.ColumnDefinitions>
                        <GridSplitter Grid.Column="1"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="{DynamicResource ControlElevationBorderBrush}"
                                      ShowsPreview="False"
                                      ResizeBehavior="PreviousAndNext"
                                      Cursor="SizeWE" />

            <!-- ───────── Left sidebar ───────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,0,16">

                        <!-- ─── SOURCE ─── -->
                        <DockPanel Margin="16,18,16,8">
                            <ui:SymbolIcon DockPanel.Dock="Right"
                                           Style="{StaticResource HelpIconStyle}"
                                           ToolTip="Where the 3D model comes from. Drop an .fbx/.glb/.obj/.dae/.stl on the viewport, click 'Open model…', or paste a Sketchfab URL. Once loaded, the file shows up as a card here." />
                            <TextBlock Text="SOURCE"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Loaded-file card. Hidden until a model has been
                             picked from either the File or Sketchfab tab. -->
                        <Border Margin="16,0,16,8"
                                Padding="12,10"
                                CornerRadius="6"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                Visibility="{Binding HasModel, Converter={StaticResource BooleanToVisibility}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding SourceFileName}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding SourcePath}" />
                                <ui:Button Grid.Row="0" Grid.Column="1"
                                           Click="OnClearSource"
                                           Appearance="Transparent"
                                           Width="22" Height="22"
                                           Padding="0"
                                           Margin="6,0,-4,0"
                                           VerticalAlignment="Center"
                                           ToolTip="Remove this model and load another">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                            Orientation="Horizontal"
                                            Margin="0,4,0,0">
                                    <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            CornerRadius="3"
                                            Padding="6,1">
                                        <TextBlock Text="{Binding SourceFileFormat}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="White" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Two ways to add a model: pick a file, or paste
                             a Sketchfab URL. The picked source ends up in the
                             card above either way. -->
                        <TabControl Margin="16,0,16,0"
                                    Style="{StaticResource UnderlineTabControl}">
                            <TabItem Header="File" FontSize="12" Padding="10,4"
                                     ToolTip="Open a 3D model from disk. Supports .fbx, .glb, .gltf, .obj, .dae, .ply, .stl.">

                                <StackPanel Margin="0,8,0,0">
                                    <ui:Button HorizontalAlignment="Stretch"
                                               Content="Open model..."
                                               Appearance="Secondary"
                                               Click="OnFileOpen"
                                               ToolTip="Browse to a 3D model file. Same as dragging the file onto the viewport.">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Cube24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <TextBlock Text="…or drop a file onto the viewport."
                                               FontSize="10"
                                               Opacity="0.55"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Sketchfab" FontSize="12" Padding="10,4"
                                     ToolTip="Pull a 3D model directly from Sketchfab by URL. Requires a Sketchfab API token configured in Settings → Integrations.">
                                <StackPanel Margin="0,8,0,0">
                                    <ui:TextBox x:Name="SketchfabUrlBox"
                                                PlaceholderText="https://sketchfab.com/3d-models/..."
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                KeyDown="OnSketchfabUrlKeyDown"
                                                ToolTip="Paste the full Sketchfab model URL here, then press Enter or click Import. The model must be marked downloadable on Sketchfab." />
                                    <ui:Button Margin="0,8,0,0"
                                               HorizontalAlignment="Stretch"
                                               Content="Import from URL"
                                               Appearance="Secondary"
                                               Click="OnSketchfabSidebarImport"
                                               ToolTip="Download the model at the URL above and load it into the viewer.">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="ArrowDownload24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <TextBlock FontSize="10"
                                               Opacity="0.55"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Text="Model must be marked downloadable. Requires a Sketchfab API token in Settings." />
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="AI" FontSize="12" Padding="10,4"
                                     ToolTip="Generate a 3D model from a reference image using an AI provider (Meshy, etc.), then load it straight into the viewer. Requires a provider API key in Settings.">
                                <StackPanel Margin="0,8,0,0">
                                    <ui:Button HorizontalAlignment="Stretch"
                                               Content="Generate from image..."
                                               Appearance="Secondary"
                                               Click="OnOpenAiGenerator"
                                               ToolTip="Open the image-to-3D generator. Pick an image, choose a provider, get a model back.">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Image24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <TextBlock FontSize="10"
                                               Opacity="0.55"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Text="Generate a 3D model with Meshy or another AI provider, then load it straight into the viewer. Requires an API key in Settings." />
                                </StackPanel>
                            </TabItem>
                        </TabControl>

                        <!-- ─── GEOMETRY ─── (only meaningful with a model
                             loaded; pre-load the rows showed dashes and
                             pushed every other section down without
                             telling the user anything). -->
                        <StackPanel Visibility="{Binding HasModel, Converter={StaticResource BooleanToVisibility}}">
                            <DockPanel Margin="16,18,16,8">
                                <ui:SymbolIcon DockPanel.Dock="Right"
                                               Style="{StaticResource HelpIconStyle}"
                                               ToolTip="Vertex and triangle counts for the loaded model. FiveM targets keep these low — under ~10,000 tris and ~8 MB source per static prop is a healthy ceiling. Generate LODs in the ASSETS section if your high-detail mesh is heavier than that." />
                                <TextBlock Text="GEOMETRY"
                                           FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                            <Grid Margin="16,0,16,0" Style="{StaticResource StatRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Vertices" FontSize="12" Opacity="0.7" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding VertsDisplay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas"
                                           Visibility="{Binding IsModelLoading, Converter={StaticResource InverseBooleanToVisibility}}" />
                                <Border Grid.Column="1"
                                        Style="{StaticResource Skeleton}"
                                        Width="80" Height="13"
                                        Visibility="{Binding IsModelLoading, Converter={StaticResource BooleanToVisibility}}" />
                            </Grid>
                            <Grid Margin="16,0,16,0" Style="{StaticResource StatRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Triangles" FontSize="12" Opacity="0.7" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TrisDisplay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas"
                                           Visibility="{Binding IsModelLoading, Converter={StaticResource InverseBooleanToVisibility}}" />
                                <Border Grid.Column="1"
                                        Style="{StaticResource Skeleton}"
                                        Width="64" Height="13"
                                        Visibility="{Binding IsModelLoading, Converter={StaticResource BooleanToVisibility}}" />
                            </Grid>
                        </StackPanel>

                        <!-- ─── ORIENTATION ─── (Auto-detect handles ~95% of
                             files, so the section collapses by default — keep
                             out of the way until the user needs to override). -->
                        <!-- Advanced sidebar controls (orientation, collision,
                             material, assets, LODs). Hidden in Beginner, whose
                             flow is just drop -> name -> Convert on smart
                             defaults. Shown at Standard and Advanced. -->
                        <StackPanel Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                        <Expander Margin="16,12,16,0"
                                  Padding="0,4,0,0"
                                  IsExpanded="False"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ToolTip="GTA/RAGE expects Z-up. Most glTF/OBJ assets are Y-up; FBX is mixed (Blender exports Y-up, Maya/Max usually Z-up). 'Auto-detect' reads the FBX header and falls back to Y-up. Override if your prop ships sideways in-game.">
                            <Expander.Header>
                                <TextBlock Text="ORIENTATION"
                                           FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Expander.Header>
                            <StackPanel Margin="0,4,0,0">
                                <TextBlock Text="Up axis" Style="{StaticResource FieldLabel}" />
                                <ComboBox SelectedIndex="{Binding UpAxisIndex, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          ToolTip="Which axis your source model treats as 'up'. RAGE expects Z-up; the exporter rotates Y-up sources by -90° on X. Auto-detect reads the FBX header (most reliable for game-pipeline FBX) and falls back to Y-up for glTF/OBJ. Override only if your prop ships sideways in-game.">
                                    <ComboBoxItem Content="Auto-detect" ToolTip="Read FBX UpAxis metadata; fall back to Y-up. Right answer for ~95% of files." />
                                    <ComboBoxItem Content="Y is up" ToolTip="Force Y-up interpretation — apply the -90°X rotation. Use for Blender FBX, glTF, OBJ." />
                                    <ComboBoxItem Content="Z is up" ToolTip="Force Z-up interpretation — no rotation. Use for Maya / 3ds Max FBX." />
                                </ComboBox>
                            </StackPanel>
                        </Expander>

                        <!-- ─── COLLISION ─── (prop only — weapons use
                             per-bone hit detection from the gun_root
                             skeleton, not scene-level collision meshes) -->
                        <DockPanel Margin="16,18,16,8"
                                   Visibility="{Binding IsPropMode, Converter={StaticResource BooleanToVisibility}}">
                            <ui:SymbolIcon DockPanel.Dock="Right"
                                           Style="{StaticResource HelpIconStyle}"
                                           ToolTip="Physical collision for the prop. Without this RAGE treats your prop as a phantom — players walk through it. The bound ships either embedded in the YDR (one file, recommended) or as a sibling .ybn. Pick the surface material so footsteps, bullet impacts, and bullet penetration use the right sound/effect set." />
                            <TextBlock Text="COLLISION"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Margin="16,0,16,0"
                                    Visibility="{Binding IsPropMode, Converter={StaticResource BooleanToVisibility}}">
                            <ui:ToggleSwitch IsChecked="{Binding IncludeCollision}"
                                             Content="Generate collision mesh"
                                             Margin="0,0,0,8"
                                             ToolTip="Build a polygon-accurate BoundComposite > GeometryBVH from the loaded mesh. Off = no collision; the prop will be a phantom (players walk through it, bullets pass through, vehicles roll over it as if it isn't there). On is the default — turn off only if you're shipping collision separately." />
                            <ui:ToggleSwitch IsChecked="{Binding EmbedCollision}"
                                             Content="Embed in YDR (no .ybn)"
                                             IsEnabled="{Binding IsCollisionEmbeddable}"
                                             ToolTip="Attach the BoundComposite to Drawable.Bound so the YDR ships visual + collision in one file. Recommended for .ymap-placed static props (RAGE loads the bound from the same drawable resource it pulled for the visual). Off ships a sibling scene.ybn — useful if you want to swap in a Sollumz-built .ybn later."
                                             Margin="0,0,0,8" />
                            <TextBlock Text="Collision material" Style="{StaticResource FieldLabel}" />
                            <ComboBox SelectedValue="{Binding CollisionMaterial}"
                                      SelectedValuePath="Content"
                                      HorizontalAlignment="Stretch"
                                      IsEnabled="{Binding IncludeCollision}"
                                      ToolTip="Surface material — drives footstep / impact / penetration sounds and visual effects. CONCRETE for buildings and roads, METAL for vehicles and railings, WOOD for crates and trees, GRASS / DIRT / SAND for terrain, GLASS for windows (smashable), FOLIAGE for vegetation (bullets pass through).">
                                <ComboBoxItem Content="CONCRETE" />
                                <ComboBoxItem Content="METAL" />
                                <ComboBoxItem Content="WOOD" />
                                <ComboBoxItem Content="PLASTIC" />
                                <ComboBoxItem Content="GLASS" />
                                <ComboBoxItem Content="RUBBER" />
                                <ComboBoxItem Content="GRASS" />
                                <ComboBoxItem Content="DIRT" />
                                <ComboBoxItem Content="SAND" />
                                <ComboBoxItem Content="ROCK" />
                                <ComboBoxItem Content="FOLIAGE" />
                            </ComboBox>
                        </StackPanel>

                        <!-- ─── GLASS ─── only when a layer is Material → Glass -->
                        <DockPanel Margin="16,18,16,8"
                                   Visibility="{Binding ShowGlassSettings, Converter={StaticResource BooleanToVisibility}}">
                            <ui:SymbolIcon DockPanel.Dock="Right"
                                           Style="{StaticResource HelpIconStyle}"
                                           ToolTip="How glass/window/mirror parts export. Appearance sets see-through vs reflective; Breakable makes the glass shatter (VFX + sound) and lets bullets pass when shot. Applies to any part FiveOS detects as glass, or that you tag Glass in the layers panel." />
                            <TextBlock Text="GLASS"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Margin="16,0,16,0"
                                    Visibility="{Binding ShowGlassSettings, Converter={StaticResource BooleanToVisibility}}">
                            <TextBlock Text="Appearance" Style="{StaticResource FieldLabel}" />
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="See-through" FontSize="11" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <Slider Grid.Column="1" Minimum="0" Maximum="1"
                                        Value="{Binding GlassOpacity}"
                                        VerticalAlignment="Center"
                                        ToolTip="Slide toward See-through for clear glass, toward Reflective for a shiny mirror-like surface (reflects the environment / sky). Applies to every glass part on export." />
                                <TextBlock Grid.Column="2" Text="Reflective" FontSize="11" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </Grid>
                            <ui:ToggleSwitch IsChecked="{Binding BreakableGlass}"
                                             Content="Breakable glass (shatters when shot)"
                                             Margin="0,8,0,0"
                                             ToolTip="Glass parts get GLASS_SHOOT_THROUGH collision — bullets pass through and the engine plays the glass-shatter VFX + sound on hit. Off keeps glass solid. Shatter-on-shot, not a physically-fragmenting .yft fragment." />
                        </StackPanel>

                        <!-- ─── ASSETS ─── -->
                        <!-- Hidden in weapon mode: ytyp doesn't apply to
                             weapons (they're spawned via give-weapon, not
                             placed in maps), and we always extract textures
                             for weapons since the YTD pairs with the YDR
                             via weaponarchetypes.meta. -->
                        <DockPanel Margin="16,18,16,8"
                                   Visibility="{Binding IsPropMode, Converter={StaticResource BooleanToVisibility}}">
                            <ui:SymbolIcon DockPanel.Dock="Right"
                                           Style="{StaticResource HelpIconStyle}"
                                           ToolTip="Files the exporter generates alongside the .ydr. The .ytyp registers the archetype so the prop can be placed in .ymap files; texture extraction bakes embedded textures from the source FBX/GLB into the YDR's TextureDictionary. LOD generation produces medium/low/very-low detail versions of the mesh so the engine streams a coarser silhouette at distance." />
                            <TextBlock Text="ASSETS"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Margin="16,0,16,0"
                                    Visibility="{Binding IsPropMode, Converter={StaticResource BooleanToVisibility}}">
                            <ui:ToggleSwitch IsChecked="{Binding IncludeYtyp}"
                                             Content="Generate .ytyp metadata"
                                             Margin="0,0,0,8"
                                             ToolTip="Write a .ytyp file that registers your prop as a placeable archetype. Without this you can spawn the model from script (CreateObject) but it can't be placed in a .ymap via CodeWalker." />
                            <ui:ToggleSwitch IsChecked="{Binding ExtractTextures}"
                                             Content="Extract embedded textures"
                                             Margin="0,0,0,8"
                                             ToolTip="Pull diffuse + normal maps from your source FBX/GLB (embedded or sidecar PNGs), encode them as DDS, and bake them into the YDR's TextureDictionary. Turn off only if you're shipping a separate .ytd dictionary." />
                            <ui:ToggleSwitch IsChecked="{Binding AnimatedProp}"
                                             Content="Animated prop (rig + animation)"
                                             Margin="0,0,0,8"
                                             ToolTip="If your model ships a rig AND an animation clip, export it as an ANIMATED prop: the engine attaches a skeleton, rigidly binds each part to a bone, writes a matching .ycd, and sets the ytyp's Auto Start Anim flag so a placed prop plays on its own. Falls back to a normal static prop when there's no animation. Rigid binding animates WHOLE parts, so it suits mechanical models whose moving pieces are separate meshes — verify the motion on your FiveM server." />

                            <!-- Auto-spin sub-options: only relevant when
                                 Animated prop is on. Synthesizes a 360° spin
                                 for a model that has no animation of its own. -->
                            <StackPanel Margin="16,0,0,8"
                                        Visibility="{Binding AnimatedProp, Converter={StaticResource BooleanToVisibility}}">
                                <ui:ToggleSwitch IsChecked="{Binding AutoSpin}"
                                                 Content="Auto-spin (no animation in file)"
                                                 Margin="0,0,0,6"
                                                 ToolTip="Model has no animation baked in? Generate one: FiveOS puts a rotation bone at the model's centre and spins it 360° on loop. Ideal for gears, fans, wheels, signs, turntables — no pre-animated file needed." />
                                <StackPanel Visibility="{Binding AutoSpin, Converter={StaticResource BooleanToVisibility}}">
                                    <Grid Margin="0,2,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Spin axis" VerticalAlignment="Center" Opacity="0.7" />
                                        <ComboBox Grid.Column="1" SelectedIndex="{Binding SpinAxisIndex}"
                                                  HorizontalAlignment="Left" Width="150"
                                                  ToolTip="Which axis the prop turns around. Z = vertical (fans, turntables); X / Y = horizontal (wheels, rollers).">
                                            <ComboBoxItem Content="X (horizontal)" />
                                            <ComboBoxItem Content="Y (horizontal)" />
                                            <ComboBoxItem Content="Z (vertical)" />
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Secs / rev" VerticalAlignment="Center" Opacity="0.7" />
                                        <ui:NumberBox Grid.Column="1" Value="{Binding SpinSeconds, Mode=TwoWay}"
                                                      Minimum="0.2" Maximum="120" SmallChange="0.5" LargeChange="1"
                                                      HorizontalAlignment="Left" Width="150"
                                                      ToolTip="Seconds for one full turn. Lower = faster spin." />
                                    </Grid>
                                    <ui:ToggleSwitch IsChecked="{Binding SpinReverse}"
                                                     Content="Reverse direction"
                                                     Margin="0,0,0,4" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Batch fix-up for models that ship without
                                 textures (common with .obj exports or
                                 textures-stripped FBX). Opens a multi-image
                                 file picker; each picked image is fuzzy-
                                 matched to a part by filename stem, shown
                                 in the preview, and baked into the YDR on
                                 Convert via part-diffuse overrides. -->
                            <ui:Button HorizontalAlignment="Stretch"
                                       Margin="0,0,0,8"
                                       Appearance="Secondary"
                                       Content="Add Missing Textures..."
                                       Click="OnAddMissingTextures"
                                       IsEnabled="{Binding HasModel}"
                                       ToolTip="Pick one or more image files; each is matched to a part by filename and applied as that part's diffuse. Changes show in the preview and bake into the export on Convert.">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="ImageAdd24" />
                                </ui:Button.Icon>
                            </ui:Button>
                            <ui:ToggleSwitch IsChecked="{Binding GenerateLods}"
                                             Content="Generate LODs (med / low / vlow)"
                                             Margin="0,0,0,8"
                                             ToolTip="Deep-clone the High mesh three times and decimate each via quadric-edge-collapse to populate Med (50%), Low (20%), and VLow (5%) tier slots in the YDR. RAGE then streams a coarser silhouette as the camera moves away. Adds ~30-50% to the YDR size; worth it for any prop visible from across the map, overkill for small clutter." />
                            <!-- Per-tier LOD draw distances (m). Hidden until
                                 Generate LODs is on — the four NumberBoxes
                                 are dead weight otherwise. High renders
                                 0 → High, Med renders High → Med, etc. Past
                                 VLow the prop disappears entirely; that
                                 value also drives the .ytyp's archetype cull
                                 radius. -->
                            <StackPanel Visibility="{Binding GenerateLods, Converter={StaticResource BooleanToVisibility}}">
                                <TextBlock Text="LOD distances (m)"
                                           Opacity="0.6"
                                           Margin="0,4,0,4"
                                           FontSize="11" />
                                <Grid Margin="0,0,0,4"
                                      ToolTip="Distance (m) at which the engine STOPS rendering the High tier and switches to Med. Defaults to 60 m. Drop this lower for small props; raise it for landmarks where the high-poly silhouette matters at distance.">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="High" Width="48"
                                               VerticalAlignment="Center" Opacity="0.8" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding LodDistHigh}"
                                                  Minimum="5" Maximum="2000"
                                                  SmallChange="10" LargeChange="50"
                                                  MaxDecimalPlaces="0"
                                                  ClearButtonEnabled="False" />
                                </Grid>
                                <Grid Margin="0,0,0,4"
                                      ToolTip="Distance (m) at which the engine switches from Med to Low. Defaults to 120 m. Only meaningful when 'Generate LODs' is on.">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Med" Width="48"
                                               VerticalAlignment="Center" Opacity="0.8" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding LodDistMed}"
                                                  Minimum="5" Maximum="2000"
                                                  SmallChange="10" LargeChange="50"
                                                  MaxDecimalPlaces="0"
                                                  ClearButtonEnabled="False" />
                                </Grid>
                                <Grid Margin="0,0,0,4"
                                      ToolTip="Distance (m) at which the engine switches from Low to VLow. Defaults to 250 m. Only meaningful when 'Generate LODs' is on.">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Low" Width="48"
                                               VerticalAlignment="Center" Opacity="0.8" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding LodDistLow}"
                                                  Minimum="5" Maximum="2000"
                                                  SmallChange="10" LargeChange="50"
                                                  MaxDecimalPlaces="0"
                                                  ClearButtonEnabled="False" />
                                </Grid>
                                <Grid Margin="0,0,0,4"
                                      ToolTip="Outer draw distance (m). Past this distance the prop disappears entirely — RAGE culls the whole entity. Also written to the .ytyp's archetype-level cull radius so the engine drops the prop from streaming at the same point the drawable stops rendering. Defaults to 500 m.">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="VLow" Width="48"
                                               VerticalAlignment="Center" Opacity="0.8" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding LodDistVlow}"
                                                  Minimum="5" Maximum="2000"
                                                  SmallChange="10" LargeChange="50"
                                                  MaxDecimalPlaces="0"
                                                  ClearButtonEnabled="False" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        </StackPanel>

                        <!-- ─── TRANSFORM ─── (sidebar coords; live-mirrored
                             from the viewer's gizmo and pushed back to the
                             viewer when the user types into a NumberBox.
                             Hidden until a model is loaded, and collapsed
                             by default — the in-viewport gizmo and the
                             Coordinate Manager strip already show the
                             values, so the NumberBoxes only matter when
                             the user wants to type an exact transform. -->
                        <Expander Margin="16,12,16,0"
                                  Padding="0,4,0,0"
                                  IsExpanded="False"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  Visibility="{Binding HasModel, Converter={StaticResource BooleanToVisibility}}"
                                  ToolTip="Position / rotation / scale the prop is exported with. Mirrors the gizmo in the 3D viewport — drag the gizmo handles or expand this section to type values. Position is preview-only (the prop always exports at the origin so it spawns cleanly wherever placed in a .ymap); rotation and scale ARE baked into the exported geometry.">
                            <Expander.Header>
                                <TextBlock Text="TRANSFORM"
                                           FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Expander.Header>
                            <StackPanel Margin="0,4,0,0">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="POS" FontSize="10" FontWeight="SemiBold" Opacity="0.6" VerticalAlignment="Center"
                                               ToolTip="Position offset in metres. Preview-only — the prop always exports at the origin (0, 0, 0) so it spawns cleanly wherever placed in a .ymap. Scroll-wheel over a field to nudge; Shift+wheel for bigger steps." />
                                    <ui:NumberBox Grid.Column="1" Value="{Binding TransformPosX}" SmallChange="0.01" LargeChange="0.1" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Position X (preview only, not baked into export)." />
                                    <ui:NumberBox Grid.Column="3" Value="{Binding TransformPosY}" SmallChange="0.01" LargeChange="0.1" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Position Y (preview only, not baked into export)." />
                                    <ui:NumberBox Grid.Column="5" Value="{Binding TransformPosZ}" SmallChange="0.01" LargeChange="0.1" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Position Z (preview only, not baked into export)." />
                                </Grid>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="ROT" FontSize="10" FontWeight="SemiBold" Opacity="0.6" VerticalAlignment="Center"
                                               ToolTip="Euler angles in degrees (XYZ order). Baked into the exported drawable so the prop ships in this orientation. Scroll-wheel for 1° steps, Shift+wheel for 15°." />
                                    <ui:NumberBox Grid.Column="1" Value="{Binding TransformRotX}" SmallChange="1" LargeChange="15" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="1" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Rotation X (pitch) in degrees — baked into the export." />
                                    <ui:NumberBox Grid.Column="3" Value="{Binding TransformRotY}" SmallChange="1" LargeChange="15" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="1" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Rotation Y (yaw) in degrees — baked into the export." />
                                    <ui:NumberBox Grid.Column="5" Value="{Binding TransformRotZ}" SmallChange="1" LargeChange="15" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="1" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Rotation Z (roll) in degrees — baked into the export." />
                                </Grid>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="SCL" FontSize="10" FontWeight="SemiBold" Opacity="0.6" VerticalAlignment="Center"
                                               ToolTip="Per-axis scale factor. 1.0 = source size on that axis. Baked into the exported drawable — turn off the gizmo's Uniform-scale toggle to stretch along a single axis. Scroll-wheel for 0.01 steps." />
                                    <ui:NumberBox Grid.Column="1" Value="{Binding TransformScaleX}" SmallChange="0.01" LargeChange="0.1" Minimum="0.001" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Scale X — baked into the export." />
                                    <ui:NumberBox Grid.Column="3" Value="{Binding TransformScaleY}" SmallChange="0.01" LargeChange="0.1" Minimum="0.001" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Scale Y — baked into the export." />
                                    <ui:NumberBox Grid.Column="5" Value="{Binding TransformScaleZ}" SmallChange="0.01" LargeChange="0.1" Minimum="0.001" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Scale Z — baked into the export." />
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button Grid.Column="0"
                                               HorizontalAlignment="Stretch"
                                               Appearance="Secondary"
                                               Content="Reset"
                                               Command="{Binding ResetTransformCommand}"
                                               ToolTip="Reset position, rotation, and scale to their defaults." />
                                    <ui:Button Grid.Column="2"
                                               HorizontalAlignment="Stretch"
                                               Appearance="Secondary"
                                               Content="Snap to Ground"
                                               Click="OnSnapToGround"
                                               ToolTip="Drop the model so its bounding-box bottom sits flush with Y=0 (the grid plane = the ground plane after the export's Y-up→Z-up swap). Honors current rotation and scale.">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="ArrowDown24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                </Grid>
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ───────── Center viewport ───────── -->
            <Grid Grid.Column="2" Margin="16,8,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <!-- Layers panel — collapses out of layout when off so
                         the viewport reclaims the full width. Width=Auto on
                         the column means the inner Border's own Width owns
                         the size. -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <!-- Optimization-health banner. Auto-height so it
                         disappears entirely when not visible. We can't
                         z-overlay WebView2 (airspace), so the banner has
                         to push the viewport down via row layout. -->
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ═══════════════════════════════════════════════════
                     OPTIMIZATION HEALTH BANNER
                     ═══════════════════════════════════════════════════ -->
                <Border Grid.Row="0" Grid.Column="0"
                        Margin="0,0,0,8"
                        CornerRadius="6"
                        BorderThickness="1"
                        Padding="14,10"
                        Visibility="{Binding IsOptimizationHintVisible, Converter={StaticResource BooleanToVisibility}}">
                    <Border.Style>
                        <!-- Yellow for Warn, red-tinted for Fail. Both
                             stay readable in light + dark themes. -->
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#22FFC857" />
                            <Setter Property="BorderBrush" Value="#88FFC857" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OptimizationHintIsFail}" Value="True">
                                    <Setter Property="Background" Value="#22FF6060" />
                                    <Setter Property="BorderBrush" Value="#88FF6060" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon Grid.Column="0"
                                       Symbol="Warning24"
                                       FontSize="22"
                                       VerticalAlignment="Center"
                                       Margin="2,0,12,0"
                                       Foreground="#FFC857">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Foreground" Value="#FFC857" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OptimizationHintIsFail}" Value="True">
                                            <Setter Property="Foreground" Value="#FF7060" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding OptimizationHintTitle}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding OptimizationHintBody}"
                                       FontSize="11"
                                       Opacity="0.8"
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding IsOptimizationHintPreviewing, Converter={StaticResource InverseBooleanToVisibility}}" />

                            <!-- Preview-mode slider + projected stats. The
                                 user drags freely; releasing the slider
                                 (debounced in code-behind) triggers the
                                 actual decimate + viewer reload. The
                                 model is never modified on disk until
                                 they click Confirm. -->
                            <Grid Margin="0,4,0,0"
                                  Visibility="{Binding IsOptimizationHintPreviewing, Converter={StaticResource BooleanToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- Shared preview slider: tri target for the
                                     decimate preview, max texture resolution
                                     (power-of-two, tick-snapped) for the
                                     texture-optimize preview. -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding OptimizeSliderLabel}"
                                           FontSize="11"
                                           Opacity="0.75"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <Slider Grid.Column="1"
                                        x:Name="OptimizeSlider"
                                        Value="{Binding OptimizeTargetTris, Mode=TwoWay}"
                                        Minimum="{Binding OptimizeSliderMin}"
                                        Maximum="{Binding OptimizeSliderMax}"
                                        TickFrequency="{Binding OptimizeSliderTick}"
                                        IsSnapToTickEnabled="{Binding IsOptimizeSliderSnapping}"
                                        ValueChanged="OnOptimizeSliderValueChanged"
                                        Thumb.DragCompleted="OnOptimizeSliderDragCompleted"
                                        Visibility="{Binding IsTexturePreviewMode, Converter={StaticResource InverseBooleanToVisibility}}"
                                        ToolTip="Target triangle count after decimation. Drag left = more aggressive reduction. The preview re-runs when you release the slider; Confirm to lock it in or Cancel to restore the original mesh." />

                                <!-- Texture-optimize preview: four concrete
                                     resolution choices, each labelled with the
                                     file size it produces (filled in as the
                                     background passes finish). Selecting one
                                     hot-swaps the viewer preview. -->
                                <ItemsControl Grid.Column="1"
                                              ItemsSource="{Binding TextureDimOptions}"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding IsTexturePreviewMode, Converter={StaticResource BooleanToVisibility}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton GroupName="FosTextureDim"
                                                         IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                         Checked="OnTextureDimChecked"
                                                         Margin="0,0,14,0"
                                                         VerticalContentAlignment="Center"
                                                         ToolTip="Cap every texture at this resolution. Higher = sharper up close, heavier to stream.">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SizeText}"
                                                               FontSize="10"
                                                               Opacity="0.65" />
                                                </StackPanel>
                                            </RadioButton>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="10,0,0,0">
                                    <ctrl:DotMatrixLoader LoaderStyle="HelixGlow"
                                                          DotSize="4"
                                                          DotSpacing="2"
                                                          Margin="0,0,8,0"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding IsOptimizePreviewDecimating, Converter={StaticResource BooleanToVisibility}}">
                                        <ctrl:DotMatrixLoader.DotColor>
                                            <SolidColorBrush Color="#FFC857" />
                                        </ctrl:DotMatrixLoader.DotColor>
                                    </ctrl:DotMatrixLoader>
                                    <TextBlock Text="{Binding OptimizePreviewStats}"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Action cluster — initial state: 3-button bar.
                             Hidden once we enter preview mode. -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding IsOptimizationHintActionable, Converter={StaticResource BooleanToVisibility}}">
                            <ui:Button Appearance="Primary"
                                       Padding="14,6"
                                       Margin="0,0,6,0"
                                       Click="OnAutoOptimizeBanner"
                                       ToolTip="Optimize with a live preview — heavy meshes get a decimate slider, texture-heavy files get their textures compressed. Confirm or Cancel afterwards.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Sparkle24" FontSize="14" Margin="0,0,6,0" />
                                    <TextBlock Text="Optimize" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Appearance="Secondary"
                                       Padding="14,6"
                                       Margin="0,0,6,0"
                                       Click="OnOpenOptimizeTabBanner"
                                       ToolTip="Switch to the Optimize tab for finer control over decimation, textures, and collision.">
                                <TextBlock Text="Open Optimize tab" />
                            </ui:Button>
                            <ui:Button Appearance="Transparent"
                                       Padding="14,6"
                                       Click="OnDismissOptimizeBanner"
                                       ToolTip="Dismiss this banner — convert anyway.">
                                <TextBlock Text="Ignore Warning" />
                            </ui:Button>
                        </StackPanel>

                        <!-- Action cluster — preview state: Confirm + Cancel.
                             Cancel restores the original mesh from before
                             preview began; Confirm locks in the current
                             slider position as the new working file. -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding IsOptimizationHintPreviewActionable, Converter={StaticResource BooleanToVisibility}}">
                            <ui:Button Appearance="Primary"
                                       Padding="14,6"
                                       Margin="0,0,6,0"
                                       Click="OnConfirmOptimizeBanner"
                                       ToolTip="Lock in this decimation as the new working model. Convert will produce a YDR from this version.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Check24" FontSize="14" Margin="0,0,6,0" />
                                    <TextBlock Text="Confirm" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Appearance="Secondary"
                                       Padding="14,6"
                                       Click="OnCancelOptimizeBanner"
                                       ToolTip="Throw away the preview and restore the original mesh.">
                                <TextBlock Text="Cancel" />
                            </ui:Button>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding IsOptimizing, Converter={StaticResource BooleanToVisibility}}">
                            <ctrl:DotMatrixLoader LoaderStyle="HelixGlow"
                                                  DotSize="6"
                                                  DotSpacing="3"
                                                  Margin="0,0,8,0">
                                <ctrl:DotMatrixLoader.DotColor>
                                    <SolidColorBrush Color="#FFC857" />
                                </ctrl:DotMatrixLoader.DotColor>
                            </ctrl:DotMatrixLoader>
                            <TextBlock Text="Optimizing..."
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- State 1: empty drop zone -->
                <Border Grid.Row="1"
                        Visibility="{Binding HasModel, Converter={StaticResource InverseBooleanToVisibility}}"
                        Background="Transparent"
                        Cursor="Hand"
                        MouseLeftButtonUp="OnDropZoneClick">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0.9" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1.0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <!-- Soft dashed dropzone outline — neutral, not a hard
                             accent box. Reads as an intentional "drop here"
                             target instead of an unfinished blue frame. -->
                        <Rectangle RadiusX="14" RadiusY="14"
                                   Stroke="{DynamicResource ControlElevationBorderBrush}"
                                   StrokeThickness="1.5"
                                   StrokeDashArray="5 5"
                                   Opacity="0.5"
                                   Margin="2" />
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/Branding/FiveOS.png"
                               Width="140" Height="140"
                               Opacity="0.85"
                               Margin="0,0,0,20"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Drop your 3D model here"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="or click to browse"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Opacity="0.7"
                                   Margin="0,0,0,24" />
                        <ItemsControl HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".obj" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".glb" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".gltf" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".fbx" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".dae" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".ply" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".stl" FontSize="11" FontFamily="Consolas" />
                            </Border>
                        </ItemsControl>
                    </StackPanel>
                    </Grid>
                </Border>

                <!-- State 2: 3D viewport (WebView2 + three.js).
                     Hidden during the success screen AND during model
                     loading because WebView2's HwndHost always renders on
                     top of WPF (airspace) — an overlay positioned z-above
                     would be covered by the live viewer frame, so we
                     collapse the host instead. See IsViewportVisible. -->
                <Grid Grid.Row="1"
                      x:Name="ViewportRoot"
                      Visibility="{Binding IsViewportVisible, Converter={StaticResource BooleanToVisibility}}">
                    <Border CornerRadius="8"
                            ClipToBounds="True"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                        <wv2:WebView2 x:Name="Viewport" />
                    </Border>
                </Grid>

                <!-- Model-loading overlay: sibling of ViewportRoot (NOT a
                     child) so WebView2 collapses out of the way while this
                     paints. Same DotMatrixLoader the splash uses, for a
                     consistent in-app loading look. -->
                <Border Grid.Row="1"
                        CornerRadius="8"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        Visibility="{Binding IsModelLoading, Converter={StaticResource BooleanToVisibility}}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <ctrl:DotMatrixLoader LoaderStyle="HelixGlow"
                                              DotSize="9"
                                              DotSpacing="5"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,18">
                            <ctrl:DotMatrixLoader.DotColor>
                                <SolidColorBrush Color="#5BAEFF" />
                            </ctrl:DotMatrixLoader.DotColor>
                        </ctrl:DotMatrixLoader>
                        <TextBlock Text="Loading model"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Opacity="0.85" />
                        <TextBlock Text="{Binding SourceFileName}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Center"
                                   Opacity="0.5"
                                   Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="360" />
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════
                     LAYERS PANEL — slides in beside the viewport from
                     the right. Placed in column 1 so the WebView2
                     viewport (column 0) shrinks to fit when open;
                     avoids the airspace conflict that an absolute-
                     positioned overlay would have.
                     ═══════════════════════════════════════════════════ -->
                <!-- ─── Right-side dock container ───
                     Hosts the Layers panel on top and the Prop Pack panel
                     directly under it, C4D-style. Both share the column's
                     width (280 px expanded, 32 px collapsed). Visibility
                     follows IsLayersPanelOpen so Ctrl+L still hides the
                     whole dock; the Pack panel additionally requires Pack
                     mode to be on AND the Layers panel not to be collapsed
                     (a 32-px-wide pack panel is unreadable). -->
                <Grid Grid.Column="1"
                      Grid.Row="1"
                      Visibility="{Binding IsLayersPanelOpen, Converter={StaticResource BooleanToVisibility}}">
                    <Grid.Style>
                        <!-- Lock the dock width so the Pack panel's TextBox
                             doesn't blow the column wider than the Layers
                             panel. Mirrors the LayersPanel width style. -->
                        <Style TargetType="Grid">
                            <!-- Cap width so the viewport keeps room when the
                                 window is narrow; MinWidth lets the dock shrink
                                 instead of clipping the 3D view. -->
                            <Setter Property="Width" Value="280" />
                            <Setter Property="MinWidth" Value="160" />
                            <Setter Property="MaxWidth" Value="320" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLayersPanelCollapsed}" Value="True">
                                    <Setter Property="Width" Value="32" />
                                    <Setter Property="MinWidth" Value="32" />
                                    <Setter Property="MaxWidth" Value="32" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                <Border x:Name="LayersPanel"
                        Grid.Row="0"
                        Margin="8,0,0,0"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        HorizontalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- ─── Expanded header ───
                             Hidden when collapsed; the X button on the
                             right collapses the panel (rather than closing
                             it outright). Ctrl+L / View menu / rail still
                             toggle IsLayersPanelOpen for full hide. -->
                        <Border Grid.Row="0"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                Padding="14,12"
                                Visibility="{Binding IsLayersPanelCollapsed, Converter={StaticResource InverseBooleanToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Grid.Column="0"
                                               Symbol="Layer24"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Opacity="0.85" />
                                <TextBlock Grid.Column="1"
                                           Text="Layers"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                                <ui:Button Grid.Column="2"
                                           Appearance="Transparent"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Command="{Binding ToggleLayersPanelCollapsedCommand}"
                                           ToolTip="Collapse layers panel">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ChevronRight24" FontSize="14" />
                                    </ui:Button.Icon>
                                </ui:Button>
                            </Grid>
                        </Border>

                        <!-- ─── Collapsed strip ───
                             A thin vertical dock tab with just the panel
                             icon + a rotated "Layers" label. Whole strip
                             is hit-testable; click anywhere re-expands. -->
                        <Border Grid.Row="0" Grid.RowSpan="3"
                                Background="Transparent"
                                Cursor="Hand"
                                MouseLeftButtonUp="OnLayersCollapsedStripClick"
                                ToolTip="Expand layers panel"
                                Visibility="{Binding IsLayersPanelCollapsed, Converter={StaticResource BooleanToVisibility}}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Margin="0,10,0,0">
                                <ui:SymbolIcon Symbol="ChevronLeft24"
                                               FontSize="13"
                                               Opacity="0.7"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,6" />
                                <ui:SymbolIcon Symbol="Layer24"
                                               FontSize="16"
                                               Opacity="0.85"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                <TextBlock Text="Layers"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Opacity="0.7"
                                           HorizontalAlignment="Center">
                                    <TextBlock.LayoutTransform>
                                        <RotateTransform Angle="90" />
                                    </TextBlock.LayoutTransform>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Parts list -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding IsLayersPanelCollapsed, Converter={StaticResource InverseBooleanToVisibility}}">
                            <ItemsControl ItemsSource="{Binding ModelParts}"
                                          Padding="6">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4"
                                                Padding="6,4"
                                                Margin="0,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <!-- Per-row context menu. Opens on right-click anywhere
                                                 on the row. Tag={Binding} carries the ModelPart down
                                                 to each handler. -->
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Rename..."
                                                              Tag="{Binding}"
                                                              Click="OnLayerRename">
                                                        <MenuItem.Icon>
                                                            <ui:SymbolIcon Symbol="Edit24" FontSize="14" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Textures">
                                                        <MenuItem.Icon>
                                                            <ui:SymbolIcon Symbol="Image24" FontSize="14" />
                                                        </MenuItem.Icon>
                                                        <MenuItem Header="Optimize"
                                                                  Tag="{Binding}"
                                                                  Click="OnLayerOptimizeTextures" />
                                                        <MenuItem Header="Change textures..."
                                                                  Tag="{Binding}"
                                                                  Click="OnLayerChangeTextures" />
                                                    </MenuItem>
                                                    <MenuItem Header="Optimize Mesh..."
                                                              Tag="{Binding}"
                                                              Click="OnLayerOptimizeMesh">
                                                        <MenuItem.Icon>
                                                            <ui:SymbolIcon Symbol="Shapes24" FontSize="14" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <!-- Visual material preset: drives the RAGE shader written
                                                         into the YDR for this part (glass / emissive variants)
                                                         and, for glass, the per-poly collision material so the
                                                         engine plays shatter VFX when the part is shot. -->
                                                    <MenuItem Header="Material">
                                                        <MenuItem.Icon>
                                                            <ui:SymbolIcon Symbol="Sparkle24" FontSize="14" />
                                                        </MenuItem.Icon>
                                                        <MenuItem Header="Standard"
                                                                  Tag="{Binding}"
                                                                  IsCheckable="True"
                                                                  IsChecked="{Binding MaterialPreset, Converter={StaticResource MaterialPresetIs}, ConverterParameter=Standard, Mode=OneWay}"
                                                                  Click="OnLayerMaterialStandard"
                                                                  ToolTip="Default lit shader — what FiveOS picks today." />
                                                        <MenuItem Header="Glass"
                                                                  Tag="{Binding}"
                                                                  IsCheckable="True"
                                                                  IsChecked="{Binding MaterialPreset, Converter={StaticResource MaterialPresetIs}, ConverterParameter=Glass, Mode=OneWay}"
                                                                  Click="OnLayerMaterialGlass"
                                                                  ToolTip="Transparent + reflective glass shader. Auto-sets collision to GLASS_SHOOT_THROUGH so bullets pass and the engine plays glass-shatter VFX + sound on hit." />
                                                        <MenuItem Header="Emissive"
                                                                  Tag="{Binding}"
                                                                  IsCheckable="True"
                                                                  IsChecked="{Binding MaterialPreset, Converter={StaticResource MaterialPresetIs}, ConverterParameter=Emissive, Mode=OneWay}"
                                                                  Click="OnLayerMaterialEmissive"
                                                                  ToolTip="Always-glowing emissive shader. The glow color is the diffuse texture color × 1." />
                                                        <MenuItem Header="Emissive Strong"
                                                                  Tag="{Binding}"
                                                                  IsCheckable="True"
                                                                  IsChecked="{Binding MaterialPreset, Converter={StaticResource MaterialPresetIs}, ConverterParameter=EmissiveStrong, Mode=OneWay}"
                                                                  Click="OnLayerMaterialEmissiveStrong"
                                                                  ToolTip="Bright always-glowing emissive (multiplier 16) — neon signs, light bulbs." />
                                                        <MenuItem Header="Emissive Night"
                                                                  Tag="{Binding}"
                                                                  IsCheckable="True"
                                                                  IsChecked="{Binding MaterialPreset, Converter={StaticResource MaterialPresetIs}, ConverterParameter=EmissiveNight, Mode=OneWay}"
                                                                  Click="OnLayerMaterialEmissiveNight"
                                                                  ToolTip="Glows only at night — street lights, illuminated signs that switch on after dusk." />
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <!-- Visibility toggle: stacked Eye / EyeOff icons gated by
                                                     IsVisible. Stacking them in-template (one per row) avoids
                                                     the WPF gotcha where a Style.Setter holding a UIElement
                                                     shares the *same instance* across all rows — only the last
                                                     row would get the icon and the rest go blank. -->
                                                <ui:Button Grid.Column="0"
                                                           Appearance="Transparent"
                                                           Width="28" Height="28"
                                                           Padding="0"
                                                           Click="OnLayerVisibilityToggle"
                                                           Tag="{Binding}"
                                                           ToolTip="Toggle visibility — hidden parts are excluded from the converted YDR.">
                                                    <Grid>
                                                        <ui:SymbolIcon Symbol="Eye24"
                                                                       FontSize="14"
                                                                       Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibility}}" />
                                                        <ui:SymbolIcon Symbol="EyeOff24"
                                                                       FontSize="14"
                                                                       Opacity="0.55"
                                                                       Visibility="{Binding IsVisible, Converter={StaticResource InverseBooleanToVisibility}}" />
                                                    </Grid>
                                                </ui:Button>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Margin="6,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <!-- Tiny chip showing the non-Standard material preset.
                                                         Collapsed for Standard so the row stays clean.
                                                         Right-click the row → Material → ... to change it. -->
                                                    <Border Padding="4,1"
                                                            CornerRadius="2"
                                                            Margin="0,0,5,0"
                                                            Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                            BorderThickness="1"
                                                            VerticalAlignment="Center"
                                                            ToolTip="Material preset — right-click to change">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding MaterialPreset, Converter={StaticResource MaterialPresetIs}, ConverterParameter=Glass}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MaterialPreset, Converter={StaticResource MaterialPresetIs}, ConverterParameter=Emissive}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MaterialPreset, Converter={StaticResource MaterialPresetIs}, ConverterParameter=EmissiveStrong}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MaterialPreset, Converter={StaticResource MaterialPresetIs}, ConverterParameter=EmissiveNight}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding MaterialPreset}"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                    </Border>
                                                <TextBlock
                                                           Text="{Binding Name}"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           FontFamily="Consolas"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Name}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Opacity" Value="1.0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                                    <Setter Property="Opacity" Value="0.45" />
                                                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                </StackPanel>
                                                <!-- Delete button: hover-only to keep the panel clean.
                                                     Wrapped in a Grid whose Opacity flips on row hover —
                                                     binding Opacity directly on the ui:Button would clash
                                                     with the Wpf.Ui control style. -->
                                                <Grid Grid.Column="2">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Opacity" Value="0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                                    <Setter Property="Opacity" Value="0.85" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <ui:Button Appearance="Transparent"
                                                               Width="28" Height="28"
                                                               Padding="0"
                                                               Click="OnLayerDelete"
                                                               Tag="{Binding}"
                                                               ToolTip="Remove this part — drops it from the panel and from the converted YDR. Reload the model to bring it back.">
                                                        <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                                                    </ui:Button>
                                                </Grid>
                                            </Grid>

                                            <!-- Inline mesh-optimize slider. Hidden until the user
                                                 picks "Optimize Mesh..." from the row's context menu;
                                                 the row expands in place and shows tri count slider
                                                 + projected reduction + Confirm/Cancel. Same UX as
                                                 the top-of-tab optimize banner, scoped to one part. -->
                                            <Border CornerRadius="4"
                                                    Padding="8,8,8,6"
                                                    Margin="0,4,0,0"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                    Visibility="{Binding IsMeshSliderOpen, Converter={StaticResource BooleanToVisibility}}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding MeshOptimizeStatsDisplay}"
                                                               FontSize="11"
                                                               Opacity="0.85"
                                                               Margin="0,0,0,6" />
                                                    <Slider Minimum="{Binding MeshSliderMin}"
                                                            Maximum="{Binding MeshSliderMax}"
                                                            Value="{Binding MeshTargetTris, Mode=TwoWay}"
                                                            TickFrequency="{Binding MeshSliderTick}"
                                                            IsSnapToTickEnabled="False"
                                                            IsEnabled="{Binding IsMeshOptimizing, Converter={StaticResource InverseBoolean}}"
                                                            ToolTip="Target triangle count for this part. Drag left to decimate more aggressively. The preview re-runs each time you release the slider." />
                                                    <Grid Margin="0,6,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="{Binding IsMeshOptimizing, Converter={StaticResource BooleanToVisibility}}">
                                                            <ProgressBar IsIndeterminate="True" Width="80" Height="4" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                            <TextBlock Text="Decimating..." FontSize="11" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <ui:Button Grid.Column="1"
                                                                   Content="Cancel"
                                                                   Appearance="Secondary"
                                                                   Padding="10,4"
                                                                   FontSize="11"
                                                                   Margin="0,0,6,0"
                                                                   Tag="{Binding}"
                                                                   IsEnabled="{Binding IsMeshOptimizing, Converter={StaticResource InverseBoolean}}"
                                                                   Click="OnLayerCancelOptimizeMesh"
                                                                   ToolTip="Close this panel and restore the part's original mesh." />
                                                        <ui:Button Grid.Column="2"
                                                                   Content="Apply"
                                                                   Appearance="Primary"
                                                                   Padding="10,4"
                                                                   FontSize="11"
                                                                   Tag="{Binding}"
                                                                   IsEnabled="{Binding IsMeshOptimizing, Converter={StaticResource InverseBoolean}}"
                                                                   Click="OnLayerConfirmOptimizeMesh"
                                                                   ToolTip="Lock in the current slider position — this part now exports with the reduced mesh." />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Footer: Split-into-separate-YDRs action + hint -->
                        <Border Grid.Row="2"
                                BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                Padding="10,8"
                                Visibility="{Binding IsLayersPanelCollapsed, Converter={StaticResource InverseBooleanToVisibility}}">
                            <StackPanel>
                                <ui:Button Content="Split into separate YDRs"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Center"
                                           Appearance="Secondary"
                                           Padding="8,6"
                                           Margin="0,0,0,6"
                                           Click="OnSplitLayersToYdrs"
                                           IsEnabled="{Binding IsConverting, Converter={StaticResource InverseBoolean}}"
                                           ToolTip="Convert each visible layer to its own YDR and add them all to the prop pack. Runs one engine pass per layer.">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="BranchFork24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <TextBlock FontSize="10"
                                           Opacity="0.6"
                                           TextWrapping="Wrap"
                                           Text="Default Convert merges all visible layers into one YDR. Split exports each layer separately into the pack." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══════════════════════════════════════════════════
                     PROP PACK panel — docked under Layers on the right
                     ═══════════════════════════════════════════════════
                     Visible when Pack mode is on AND the Layers dock
                     isn't collapsed (32 px is unreadable for this panel).
                     Layout is vertical to fit the 280 px dock width:
                     header → Pack name field → button row → entries. -->
                <Border x:Name="PackPanel"
                        Grid.Row="1"
                        Margin="8,8,0,0"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        Padding="12,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsPackPanelVisible}" Value="True" />
                                        <Condition Binding="{Binding IsLayersPanelCollapsed}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <!-- Header row: icon + label + staged count -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0"
                                           Symbol="BoxMultiple24"
                                           FontSize="16"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="Prop Pack"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       FontSize="10"
                                       Opacity="0.55"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding PackSession.Count, Mode=OneWay, FallbackValue=0}" />
                                <Run Text="staged" />
                            </TextBlock>
                        </Grid>

                        <!-- Pack name field -->
                        <TextBlock Text="Pack name"
                                   FontSize="10"
                                   Opacity="0.6"
                                   Margin="0,0,0,2" />
                        <ui:TextBox Text="{Binding PackSession.PackName, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="props_pack"
                                    MaxLength="64"
                                    FontFamily="Consolas"
                                    Margin="0,0,0,8"
                                    ToolTip="Becomes the FiveM resource folder name when you click Finalize. Lowercase + underscores only; the builder sanitises automatically." />

                        <!-- Furniture catalog defaults. Applied to new entries
                             the moment they're added; per-row values still
                             take precedence. Drives the housing/ catalog
                             snippets emitted at finalize time. -->
                        <TextBlock Text="Default category"
                                   FontSize="10"
                                   Opacity="0.6"
                                   Margin="0,0,0,2" />
                        <ComboBox SelectedValue="{Binding PackSession.DefaultCategory}"
                                  ItemsSource="{x:Static svc:HousingCategory.All}"
                                  Margin="0,0,0,6"
                                  ToolTip="Where new entries land in housing-script furniture menus. ps-housing's seven slots get mapped automatically; loaf/nolag/qs emit the canonical name." />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Default price"
                                           FontSize="10"
                                           Opacity="0.6"
                                           Margin="0,0,0,2" />
                                <ui:TextBox Text="{Binding PackSession.DefaultPrice, UpdateSourceTrigger=LostFocus}"
                                            ToolTip="Default in-game price. Some scripts (qbx_properties) ignore this; others write it into Config.Furnitures." />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Default type"
                                           FontSize="10"
                                           Opacity="0.6"
                                           Margin="0,0,0,2" />
                                <ComboBox SelectedValue="{Binding PackSession.DefaultType}"
                                          SelectedValuePath="Tag"
                                          ToolTip="Storage / Wardrobe props get wired to ox_inventory stash and clothing storage in ps-housing &amp; nolag. None = plain decoration.">
                                    <ComboBoxItem Content="None"     Tag="{x:Static svc:FurnitureType.None}" />
                                    <ComboBoxItem Content="Storage"  Tag="{x:Static svc:FurnitureType.Storage}" />
                                    <ComboBoxItem Content="Wardrobe" Tag="{x:Static svc:FurnitureType.Wardrobe}" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Action buttons — split column so Finalize stays
                             the visually heavier primary even at narrow width. -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0"
                                       Content="Clear"
                                       Appearance="Secondary"
                                       Padding="12,6"
                                       Click="OnClearPack"
                                       IsEnabled="{Binding PackSession.HasEntries}"
                                       ToolTip="Drop every staged prop. The pack name is kept; the staging files are deleted." />
                            <ui:Button Grid.Column="2"
                                       Content="Finalize Pack"
                                       Appearance="Primary"
                                       Padding="12,6"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Stretch"
                                       Click="OnFinalizePack"
                                       IsEnabled="{Binding PackSession.HasEntries}"
                                       ToolTip="Compile every staged prop into a single FiveM resource (stream/*.ydr + fxmanifest.lua) and deliver it the same way single-prop convert does.">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="Checkmark24" />
                                </ui:Button.Icon>
                            </ui:Button>
                        </Grid>

                        <!-- Empty-state placeholder + entry list. -->
                        <Border BorderThickness="1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                CornerRadius="6"
                                MinHeight="46"
                                MaxHeight="280">
                            <Grid>
                                <TextBlock Text="Convert props with Pack mode on to stage them here."
                                           Margin="10,10"
                                           Opacity="0.55"
                                           TextWrapping="Wrap"
                                           FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PackSession.HasEntries}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding PackSession.HasEntries, Converter={StaticResource BooleanToVisibility}}">
                                    <ItemsControl ItemsSource="{Binding PackSession.Entries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="8,6">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Top: archetype name (read-only, drives the
                                                         on-disk filename), size, remove button. -->
                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="{Binding AssetName}"
                                                               FontFamily="Consolas"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"
                                                               ToolTip="{Binding FileSummary}" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                                               Text="{Binding SizeDisplay}"
                                                               FontSize="10"
                                                               Opacity="0.6"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0,4,0" />
                                                    <ui:Button Grid.Row="0" Grid.Column="2"
                                                               Appearance="Transparent"
                                                               Padding="4"
                                                               Click="OnRemovePackEntry"
                                                               ToolTip="Remove this prop from the pack.">
                                                        <ui:Button.Icon>
                                                            <ui:SymbolIcon Symbol="Dismiss20" />
                                                        </ui:Button.Icon>
                                                    </ui:Button>
                                                    <!-- Bottom: per-entry catalog overrides. Label is
                                                         what the housing-script menu shows; category
                                                         drives which bucket the prop lands in; price
                                                         is what's written to the catalog snippets. -->
                                                    <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,4,28,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="4" />
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="4" />
                                                            <ColumnDefinition Width="58" />
                                                        </Grid.ColumnDefinitions>
                                                        <ui:TextBox Grid.Column="0"
                                                                    Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                                    PlaceholderText="Display name"
                                                                    FontSize="11"
                                                                    Padding="6,2"
                                                                    ToolTip="Shown in the housing-script furniture menu." />
                                                        <ComboBox Grid.Column="2"
                                                                  SelectedValue="{Binding Category}"
                                                                  ItemsSource="{x:Static svc:HousingCategory.All}"
                                                                  FontSize="11"
                                                                  ToolTip="Which housing-script category this prop lands in." />
                                                        <ui:TextBox Grid.Column="4"
                                                                    Text="{Binding Price, UpdateSourceTrigger=LostFocus}"
                                                                    FontSize="11"
                                                                    Padding="6,2"
                                                                    HorizontalContentAlignment="Right"
                                                                    ToolTip="In-game price written into the catalog snippets." />
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
                </Grid>
            </Grid>
        </Grid>

                    <!-- ═══════════════════════════════════════════════════
                         FOOTER: prop name + convert action
                         ═══════════════════════════════════════════════════ -->
                    <Border Grid.Row="2"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            Padding="16,12">
                        <!-- Horizontal scroll when the window is too narrow for
                             prop-name + Pack/Convert — never clip the footer. -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      Padding="0">
                        <Grid MinWidth="520">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="180" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: asset name input. Label flips to "Weapon
                                 model name" in weapon mode because the field
                                 becomes the <Model> tag in weaponarchetypes.meta
                                 — it has to match what the YDR is named on
                                 disk. -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Prop name"
                                           FontSize="11"
                                           Opacity="0.7"
                                           Margin="0,0,0,4" />
                                <ui:TextBox Text="{Binding PropName, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="auto from filename"
                                            MaxLength="64"
                                            FontFamily="Consolas"
                                            ToolTip="The asset name that becomes scene.ydr / scene.ybn / scene.ytyp on export. This is also the model hash used by CreateObject in scripts and by archetype lookups in .ymap entities. Lowercase, no spaces, no special chars (the export sanitises automatically). Defaults to the source filename." />
                            </StackPanel>

                            <!-- Right: convert button or progress, plus an
                                 update badge that appears below when the
                                 background update check finds a newer build. -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Pack-mode toggle. When on, the Convert
                                         button label flips to "Add to Pack" and
                                         each conversion accumulates into the
                                         pack panel above the footer instead of
                                         producing a single-asset .zip. -->
                                    <ToggleButton x:Name="PackModeToggle"
                                                  IsChecked="{Binding IsPackMode, Mode=TwoWay}"
                                                  Padding="14,12"
                                                  Margin="0,0,8,0"
                                                  FontSize="13"
                                                  FontWeight="SemiBold"
                                                  Visibility="{Binding IsPropMode, Converter={StaticResource BooleanToVisibility}}"
                                                  ToolTip="Pack mode — convert several props in a row and finalise them into a single FiveM resource.">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="BoxMultiple24" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                            <TextBlock Text="Pack" VerticalAlignment="Center" />
                                            <Border Margin="8,0,0,0"
                                                    Padding="6,1"
                                                    CornerRadius="6"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                    Visibility="{Binding PackSession.HasEntries, Converter={StaticResource BooleanToVisibility}}">
                                                <TextBlock Text="{Binding PackSession.Count, FallbackValue=0}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </ToggleButton>

                                    <Grid>
                                        <ui:Button x:Name="ConvertButton"
                                                   Content="{Binding ConvertButtonLabel}"
                                                   Appearance="Primary"
                                                   Padding="32,12"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   IsEnabled="{Binding CanConvert}"
                                                   Click="OnConvert"
                                                   ToolTip="Ctrl+Enter"
                                                   Visibility="{Binding IsConverting, Converter={StaticResource InverseBooleanToVisibility}}">
                                            <ui:Button.Icon>
                                                <ui:SymbolIcon Symbol="ArrowRight24" />
                                            </ui:Button.Icon>
                                        </ui:Button>
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsConverting, Converter={StaticResource BooleanToVisibility}}">
                                            <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,12,0" VerticalAlignment="Center" />
                                            <TextBlock Text="Converting..." VerticalAlignment="Center" FontSize="13" />
                                            <ui:Button Content="Cancel"
                                                       Appearance="Danger"
                                                       Margin="12,0,0,0"
                                                       Padding="16,6"
                                                       VerticalAlignment="Center"
                                                       Click="OnCancelConvert"
                                                       ToolTip="Stop the conversion and terminate the engine process." />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        </ScrollViewer>
                    </Border>

                    <!-- ═══════════════════════════════════════════════════
                         SUCCESS overlay (covers tab content when
                         ShowSuccessScreen). Lives inside the tab so it
                         doesn't block the other two tabs.
                         ═══════════════════════════════════════════════════ -->
                    <Border Grid.Row="0" Grid.RowSpan="3"
                            Background="{DynamicResource ApplicationBackgroundBrush}"
                            Visibility="{Binding ShowSuccessScreen, Converter={StaticResource BooleanToVisibility}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
                            <Border Width="96" Height="96"
                                    CornerRadius="48"
                                    Background="#1B4CAF50"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,16">
                                <TextBlock Text="✓"
                                           FontSize="64"
                                           FontWeight="Light"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#4CAF50" />
                            </Border>
                            <TextBlock Text="Done. Your prop is ready."
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16" />
                            <TextBlock Text="Saved to:"
                                       FontSize="12"
                                       Opacity="0.7"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding ResultZipPath}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,24" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:Button Content="Open folder"
                                           Appearance="Primary"
                                           Margin="0,0,8,0"
                                           Padding="20,8"
                                           Click="OnOpenFolder"
                                           ToolTip="Open the output folder in Windows Explorer — your resource is ready to copy into a FiveM server's resources/ folder.">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="FolderOpen24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Content="How to install"
                                           Appearance="Secondary"
                                           Margin="0,0,8,0"
                                           Padding="20,8"
                                           Click="OnHelpInstall"
                                           ToolTip="Walkthrough of how to drop this resource into a FiveM server, add it to server.cfg, and place the prop via CodeWalker." />
                                <ui:Button Content="Back to model"
                                           Appearance="Secondary"
                                           Margin="0,0,8,0"
                                           Padding="20,8"
                                           Click="OnBackToModel"
                                           ToolTip="Return to your loaded model to tweak it (layers, transform, materials) and export again — keeps everything exactly as it was.">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ArrowLeft24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Content="Convert another"
                                           Appearance="Secondary"
                                           Padding="20,8"
                                           Click="OnConvertAnother"
                                           ToolTip="Clear the current model and start fresh with a new one — keeps the current settings as defaults." />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
                </Grid>

                <!-- ════ OPTIMIZE VIEW (hosts the txAdmin Optimizer as a mode
                     card — see OptimizeView.xaml) ════ -->
                <Grid Visibility="{Binding IsOptimizeView, Converter={StaticResource BooleanToVisibility}}">
                    <ContentControl Content="{Binding OptimizeVm}" />
                </Grid>

                <!-- ════ MODS → RPF VIEW ════ -->
                <Grid Visibility="{Binding IsRpfView, Converter={StaticResource BooleanToVisibility}}">
                    <ContentControl Content="{Binding RpfVm}" />
                </Grid>

                <!-- ════ VEHICLES VIEW (hosts the Carcols Fixer mode too — its
                     pane binds MainViewModel.CarcolsVm from inside VehiclesView
                     so scan state survives tab switches) ════ -->
                <Grid Visibility="{Binding IsVehiclesView, Converter={StaticResource BooleanToVisibility}}">
                    <ContentControl Content="{Binding VehiclesVm}" />
                </Grid>

                <!-- (Image → 3D was its own view; it's now folded into the
                     3D → Prop source picker as the "AI" tab — opens
                     AiGeneratorWindow on demand and the generated .glb
                     auto-loads into the viewer.) -->

                <!-- ════ EMOTES VIEW ════
                     One unified workspace (the former Pose → Emote), which
                     also absorbs animation import: the Library's "Import
                     Animation" button retargets a .glb/.fbx clip onto the
                     GTA skeleton and lands it on the timeline. Owns its own
                     WebView2 with lazy init keyed off visibility, so the
                     ~40 MB Edge process doesn't spin up until first shown. -->
                <Grid Visibility="{Binding IsEmotesView, Converter={StaticResource BooleanToVisibility}}">
                    <local:PoseToEmoteView x:Name="EmotesWorkspace" />
                </Grid>

                <!-- ════ PLUGIN HOST ════
                     Renders the active third-party plugin's view. Mutually
                     exclusive with the built-in views — IsPluginActive
                     forces every IsXView flag false above so this Grid
                     ends up alone on top. -->
                <Grid Visibility="{Binding IsPluginActive, Converter={StaticResource BooleanToVisibility}}">
                    <ContentControl Content="{Binding ActivePluginView}" />
                </Grid>

                </Grid>
                <!-- /Grid.Row=1 view-swap inner container -->

            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             SETTINGS OVERLAY
             Full-page. Toggled by the gear icon. Sits on top of the TabControl
             row so the active tab is preserved underneath. Click Back (or press
             Esc) to dismiss.
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        Padding="20,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Click="OnSettingsClose"
                                   Appearance="Transparent"
                                   Width="32" Height="32"
                                   Padding="0"
                                   Margin="0,0,12,0"
                                   ToolTip="Back (Esc)">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="16" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <TextBlock Grid.Column="1"
                                   Text="Settings"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- SettingsView is created lazily on first open in code-behind
                     (EnsureSettingsPage). Materialising it eagerly here would
                     fire SettingsView.Loaded at app startup, which kicks off a
                     cache-size scan and slows the splash. -->
                <ContentControl Grid.Row="1" x:Name="SettingsHost" />
            </Grid>
        </Border>

        <!-- ───────── C4D-style Coordinate Manager strip ─────────
             Shared across tabs. Left side: status text from the active
             workflow. Right side: live readout of the loaded model's
             position / rotation / scale — same bindings the TRANSFORM
             sidebar uses, mirrored down here in the same one-row layout
             Cinema 4D's Coordinate Manager ships with. Hidden when no
             model is loaded so the strip stays a simple status bar. -->
        <Border Grid.Row="3"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           FontSize="12"
                           Opacity="0.85"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <!-- (Update badge moved to the title bar's top-right corner.) -->

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasModel, Converter={StaticResource BooleanToVisibility}}">
                    <!-- Position -->
                    <TextBlock Text="P"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Opacity="0.55"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="X" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformPosX, StringFormat={}{0:0.000}}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Y" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformPosY, StringFormat={}{0:0.000}}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Z" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformPosZ, StringFormat={}{0:0.000}}" />

                    <Border Style="{StaticResource C4DPaletteSeparator}" Margin="12,2" />

                    <!-- Rotation (degrees) -->
                    <TextBlock Text="R"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Opacity="0.55"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="X" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               MinWidth="48"
                               Text="{Binding TransformRotX, StringFormat={}{0:0.0}°}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Y" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               MinWidth="48"
                               Text="{Binding TransformRotY, StringFormat={}{0:0.0}°}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Z" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               MinWidth="48"
                               Text="{Binding TransformRotZ, StringFormat={}{0:0.0}°}" />

                    <Border Style="{StaticResource C4DPaletteSeparator}" Margin="12,2" />

                    <!-- Per-axis scale -->
                    <TextBlock Text="S"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Opacity="0.55"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="X" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformScaleX, StringFormat={}{0:0.000}}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Y" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformScaleY, StringFormat={}{0:0.000}}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Z" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformScaleZ, StringFormat={}{0:0.000}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
