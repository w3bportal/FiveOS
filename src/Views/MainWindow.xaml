                                  Visibility="{Binding IsEmotesView, Converter={StaticResource BooleanToVisibility}}"
                                  ToolTip="New — load a rigged .glb / .fbx into Emotes">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" Foreground="#FFE0C070" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="GTA Male"
                                  Style="{StaticResource C4DMenuCommandNew}"
                                  Click="OnFileEmoteGtaMale"
                                  Visibility="{Binding IsEmotesView, Converter={StaticResource BooleanToVisibility}}"
                                  ToolTip="New — freemode male skeleton preset">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Person24" FontSize="14" Foreground="#FFE0C070" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="GTA Female"
                                  Style="{StaticResource C4DMenuCommandNew}"
                                  Click="OnFileEmoteGtaFemale"
                                  Visibility="{Binding IsEmotesView, Converter={StaticResource BooleanToVisibility}}"
                                  ToolTip="New — freemode female skeleton preset">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Person24" FontSize="14" Foreground="#FFE0C070" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="IMPORT"
                                  Style="{StaticResource C4DMenuSectionHeader}"
                                  Visibility="{Binding IsEmotesView, Converter={StaticResource BooleanToVisibility}}" />
                        <MenuItem Header="Video → Emote"
                                  Style="{StaticResource C4DMenuCommandNew}"
                                  Click="OnFileEmoteVideoToEmote"
                                  Visibility="{Binding IsEmotesView, Converter={StaticResource BooleanToVisibility}}"
                                  ToolTip="New — FiveOS Motion: turn a video into an editable emote">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Video24" FontSize="14" Foreground="#FFE0C070" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator Style="{StaticResource C4DMenuSeparator}" />
                        <MenuItem Header="CONFIGURE"
                                  Style="{StaticResource C4DMenuSectionHeader}" />
                        <MenuItem Header="{loc:Loc Menu.OpenOutput}"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnFileOpenOutput"
                                  ToolTip="Open the default output folder">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource C4DMenuSeparator}" />
                        <MenuItem Header="QUIT"
                                  Style="{StaticResource C4DMenuSectionHeader}" />
                        <MenuItem Header="{loc:Loc Menu.Exit}"
                                  Style="{StaticResource C4DMenuCommand}"
                                  InputGestureText="Alt+F4"
                                  Click="OnFileExit">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Power24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ── Edit ── -->
                    <MenuItem Header="{loc:Loc Menu.Edit}"
                              Style="{StaticResource C4DTopLevelMuted}">
                        <MenuItem Header="HISTORY"
                                  Style="{StaticResource C4DMenuSectionHeader}" />
                        <MenuItem Header="{loc:Loc Menu.Undo}"
                                  Style="{StaticResource C4DMenuCommand}"
                                  InputGestureText="Ctrl+Z"
                                  Command="{Binding UndoCommand}"
                                  ToolTip="Undo">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="ArrowUndo24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{loc:Loc Menu.Redo}"
                                  Style="{StaticResource C4DMenuCommand}"
                                  InputGestureText="Ctrl+Y"
                                  Command="{Binding RedoCommand}"
                                  ToolTip="Redo">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="ArrowRedo24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ── View (Assets) ── -->
                    <MenuItem Header="{loc:Loc Menu.View}"
                              Style="{StaticResource C4DTopLevelMuted}"
                              Visibility="{Binding ShowAssetsViewMenu, Converter={StaticResource BooleanToVisibility}}">
                        <MenuItem Header="DISPLAY"
                                  Style="{StaticResource C4DMenuSectionHeader}" />
                        <MenuItem Header="{loc:Loc Menu.ShowReferencePed}"
                                  Style="{StaticResource C4DMenuCommand}"
                                  InputGestureText="Ctrl+R"
                                  IsCheckable="True"
                                  IsChecked="{Binding ShowReferencePed, Mode=TwoWay}"
                                  Click="OnViewToggleReference"
                                  ToolTip="Show a scale-reference ped next to the prop">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Person24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{loc:Loc Menu.ChooseReference}"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnViewChooseReference">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{loc:Loc Menu.ResetDefault}"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnViewResetReference">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="ArrowReset24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource C4DMenuSeparator}" />
                        <MenuItem Header="PANELS"
                                  Style="{StaticResource C4DMenuSectionHeader}" />
                        <MenuItem Header="{loc:Loc Menu.LayersPanel}"
                                  Style="{StaticResource C4DMenuCommand}"
                                  InputGestureText="Ctrl+L"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsLayersPanelOpen, Mode=TwoWay}"
                                  ToolTip="Show / hide the per-part layers panel">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Layer24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ── Pack ── group/pack operations, mirrors the Layers
                         outliner: groups export as one pack, loose layers
                         export separately. -->
                    <MenuItem Header="Pack"
                              Style="{StaticResource C4DTopLevelGold}"
                              Visibility="{Binding IsPropsView, Converter={StaticResource BooleanToVisibility}}"
                              SubmenuOpened="OnPackMenuOpened">
                        <MenuItem Header="New group"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnOutlinerNewGroup"
                                  ToolTip="Create an empty group — grouped layers export together as one pack.">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="FolderAdd24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="PackMenuAddModels"
                                  Header="Add model(s) to group…"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnOutlinerAddModels"
                                  ToolTip="Pick model files — they convert automatically into the selected group (loose layers when no group is selected).">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Add24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource C4DMenuSeparator}" />
                        <MenuItem x:Name="PackMenuGroupSelected"
                                  Header="Group selected layers"
                                  Style="{StaticResource C4DMenuCommand}"
                                  InputGestureText="Ctrl+G"
                                  Click="OnPackMenuGroupSelected"
                                  ToolTip="Move the selected layers into a new pack.">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Folder24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="PackMenuRename"
                                  Header="Rename group"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnPackMenuRename"
                                  ToolTip="Rename the selected group — the exported pack uses this name." />
                        <MenuItem x:Name="PackMenuUngroup"
                                  Header="Ungroup"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnPackMenuUngroup"
                                  ToolTip="Dissolve the selected group — its layers become loose and export separately.">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource C4DMenuSeparator}" />
                        <MenuItem x:Name="PackMenuExportGroup"
                                  Header="Export selected group"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnPackMenuExportGroup"
                                  ToolTip="Build just the selected group into one pack resource.">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Archive24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="PackMenuExportAll"
                                  Header="Export all layers"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnFinalizePack"
                                  ToolTip="Every group builds into one pack; every loose layer exports as its own resource. Hidden layers are skipped.">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Box24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource C4DMenuSeparator}" />
                        <MenuItem x:Name="PackMenuClear"
                                  Header="Clear all layers"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnClearPack"
                                  ToolTip="Remove every staged layer and group (files on disk are not touched).">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ── Settings ── -->
                    <MenuItem Header="{loc:Loc Menu.Settings}"
                              Style="{StaticResource C4DTopLevelMuted}"
                              Click="OnSettingsOpen"
                              ToolTip="API keys, output folders, language and other preferences." />

                    <!-- ── Help ── -->
                    <MenuItem Header="{loc:Loc Menu.Help}"
                              Style="{StaticResource C4DTopLevelGold}">
                        <MenuItem Header="{loc:Loc Menu.CheckUpdates}"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnHelpCheckForUpdates"
                                  ToolTip="Compare your build to the latest release on github.com/w3bportal/FiveOS.">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource C4DMenuSeparator}" />
                        <MenuItem Header="{loc:Loc Menu.About}"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnHelpAbout">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Info24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <!-- Layout tabs — former left rail, C4D-style top-right. -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch">
                    <Border Tag="Assets"
                            ToolTip="Assets — props and animated props"
                            MouseLeftButtonUp="OnRailItemClick">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource LayoutTab}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Is3DView}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{loc:Loc Rail.Assets}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LayoutTabLabel}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Is3DView}" Value="True">
                                            <Setter Property="FontStyle" Value="Italic" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <Border Tag="Optimize"
                            ToolTip="Optimize — shrink existing FiveM assets"
                            MouseLeftButtonUp="OnInnerToggleClick">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource LayoutTab}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOptimizeView}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{loc:Loc Rail.Optimize}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LayoutTabLabel}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOptimizeView}" Value="True">
                                            <Setter Property="FontStyle" Value="Italic" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <Border Tag="Emotes"
                            Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}"
                            ToolTip="Emotes — pose and convert animation clips"
                            MouseLeftButtonUp="OnRailItemClick">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource LayoutTab}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmotesView}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{loc:Loc Rail.Emotes}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LayoutTabLabel}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEmotesView}" Value="True">
                                            <Setter Property="FontStyle" Value="Italic" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <Border Tag="Vehicles"
                            Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}"
                            ToolTip="Vehicles — Car Pack"
                            MouseLeftButtonUp="OnRailItemClick">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource LayoutTab}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsVehiclesView}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{loc:Loc Rail.Vehicles}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LayoutTabLabel}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVehiclesView}" Value="True">
                                            <Setter Property="FontStyle" Value="Italic" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <Border Tag="Rpf"
                            Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}"
                            ToolTip="RPF — pack a resource folder into an OPEN .rpf"
                            MouseLeftButtonUp="OnRailItemClick">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource LayoutTab}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRpfView}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{loc:Loc Rail.Rpf}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LayoutTabLabel}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRpfView}" Value="True">
                                            <Setter Property="FontStyle" Value="Italic" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <ItemsControl ItemsSource="{Binding EnabledPluginRailEntries}"
                                  VerticalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Tag="{Binding RailTag}"
                                        ToolTip="{Binding Name}"
                                        MouseLeftButtonUp="OnRailItemClick">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource LayoutTab}">
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource StringEquals}">
                                                            <Binding Path="DataContext.ActivePluginId" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                            <Binding Path="Id" />
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" MaxWidth="100">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource LayoutTabLabel}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource StringEquals}">
                                                                <Binding Path="DataContext.ActivePluginId" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                <Binding Path="Id" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="FontStyle" Value="Italic" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <!-- Workspace views (hidden while Settings is open so WebView2
                 airspace clears). -->
            <Grid Visibility="{Binding IsSettingsOpen, Converter={StaticResource InverseBooleanToVisibility}}">

                <!-- The actual view-swap container. -->
                <Grid>

                <!-- ════ DASHBOARD (landing screen) ════ -->
                <Grid Visibility="{Binding IsDashboard, Converter={StaticResource BooleanToVisibility}}">
                    <Grid.Resources>
                        <Style x:Key="DashTile" TargetType="Border">
                            <Setter Property="Width" Value="238" />
                            <Setter Property="Height" Value="158" />
                            <Setter Property="Margin" Value="9" />
                            <Setter Property="Padding" Value="18,16" />
                            <Setter Property="CornerRadius" Value="10" />
                            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Resources>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24,28">
                            <TextBlock Text="{loc:Loc Dashboard.Welcome}"
                                       FontSize="30" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="{loc:Loc Dashboard.Subtitle}"
                                       FontSize="14" Opacity="0.6" HorizontalAlignment="Center" Margin="0,4,0,26" />
                            <WrapPanel HorizontalAlignment="Center" MaxWidth="796">
                                <Border Style="{StaticResource DashTile}" Tag="Props" MouseLeftButtonUp="OnDashboardCardClick">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="Cube24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.PropsTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.PropsDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashTile}" Tag="Optimize" MouseLeftButtonUp="OnDashboardCardClick">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="Sparkle24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.OptimizeTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.OptimizeDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashTile}" Tag="TxAdmin" MouseLeftButtonUp="OnDashboardCardClick"
                                        Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="Server24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.TxAdminTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.TxAdminDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashTile}" Tag="Emotes" MouseLeftButtonUp="OnDashboardCardClick"
                                        Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="EmojiHand24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.EmotesTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.EmotesDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashTile}" Tag="Vehicles" MouseLeftButtonUp="OnDashboardCardClick"
                                        Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="VehicleCar24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.VehiclesTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.VehiclesDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashTile}" Tag="Rpf" MouseLeftButtonUp="OnDashboardCardClick"
                                        Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="Archive24" FontSize="26" />
                                        <TextBlock Text="{loc:Loc Dashboard.RpfTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,4" />
                                        <TextBlock Text="{loc:Loc Dashboard.RpfDesc}" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ════ 3D → PROP VIEW ════ -->
                <Grid Visibility="{Binding IsPropsView, Converter={StaticResource BooleanToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="160" />
                        <!-- Sidebar + viewport -->
                        <RowDefinition Height="Auto" />
                        <!-- Splitter (drag to resize the timeline; animated modes only) -->
                        <RowDefinition x:Name="PropAnimTimelineRow" Height="0" />
                        <!-- Animated keys timeline (height toggled + persisted in code-behind) -->
                        <RowDefinition Height="Auto" />
                        <!-- Footer (prop name + convert) -->
                    </Grid.RowDefinitions>

                    <!-- Drag to resize the animated-keys timeline against the
                         viewport. Hidden (and its Auto row collapses to 0)
                         outside animated-prop mode, where there is no timeline. -->
                    <GridSplitter Grid.Row="1"
                                  Height="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="{DynamicResource ControlElevationBorderBrush}"
                                  ShowsPreview="False"
                                  ResizeBehavior="PreviousAndNext"
                                  Cursor="SizeNS"
                                  Visibility="{Binding IsAnimatedPropsView, Converter={StaticResource BooleanToVisibility}}"
                                  DragCompleted="OnPropAnimTimelineSplitterDragCompleted" />

                    <Grid Grid.Row="0" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="LeftSidebarColumn" Width="280" MinWidth="160" MaxWidth="420" />
                            <!-- Sidebar (drag the splitter to resize) -->
                            <ColumnDefinition Width="4" />
                            <!-- Splitter -->
                            <ColumnDefinition Width="*" MinWidth="160" />
                            <!-- Viewport -->
                        </Grid.ColumnDefinitions>
                        <GridSplitter Grid.Column="1"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="{DynamicResource ControlElevationBorderBrush}"
                                      ShowsPreview="False"
                                      ResizeBehavior="PreviousAndNext"
                                      Cursor="SizeWE"
                                      DragCompleted="OnSidebarSplitterDragCompleted" />

            <!-- ───────── Left sidebar ───────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="LeftInspectorPanels"
                                Margin="0,0,0,16"
                                local:PanelLayout.IsHost="True"
                                local:PanelLayout.OrderKey="props-left">

                        <!-- ─── SOURCE ─── -->
                        <Border local:PanelLayout.Id="source"
                                Background="Transparent"
                                Padding="0,0,0,4">
                        <StackPanel>
                        <DockPanel Margin="10,14,16,8">
                            <Border DockPanel.Dock="Left"
                                    Width="14" Height="18"
                                    Margin="0,0,4,0"
                                    Background="Transparent"
                                    Cursor="SizeAll"
                                    local:PanelLayout.DragHandle="True"
                                    ToolTip="Drag to reorder panel"
                                    VerticalAlignment="Center">
                                <TextBlock Text="⠿" FontSize="12" Opacity="0.4"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ui:SymbolIcon DockPanel.Dock="Right"
                                           Style="{StaticResource HelpIconStyle}"
                                           ToolTip="Where the 3D model comes from. Drop an .fbx/.glb/.obj/.dae/.stl on the viewport, click 'Open model…', or paste a Sketchfab URL. Once loaded, the file shows up as a card here." />
                            <TextBlock Text="SOURCE"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Loaded-file card. Hidden until a model has been
                             picked from either the File or Sketchfab tab. -->
                        <Border Margin="16,0,16,8"
                                Padding="12,10"
                                CornerRadius="6"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                Visibility="{Binding HasModel, Converter={StaticResource BooleanToVisibility}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding SourceFileName}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding SourcePath}" />
                                <ui:Button Grid.Row="0" Grid.Column="1"
                                           Click="OnClearSource"
                                           Appearance="Transparent"
                                           Width="22" Height="22"
                                           Padding="0"
                                           Margin="6,0,-4,0"
                                           VerticalAlignment="Center"
                                           ToolTip="Remove this model and load another">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                            Orientation="Horizontal"
                                            Margin="0,4,0,0">
                                    <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            CornerRadius="3"
                                            Padding="6,1">
                                        <TextBlock Text="{Binding SourceFileFormat}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="White" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Two ways to add a model: pick a file, or paste
                             a Sketchfab URL. The picked source ends up in the
                             card above either way. -->
                        <TabControl Margin="16,0,16,0"
                                    Style="{StaticResource UnderlineTabControl}">
                            <TabItem Header="File" FontSize="12" Padding="10,4"
                                     ToolTip="Open a 3D model from disk. Supports .fbx, .glb, .gltf, .obj, .dae, .ply, .stl.">

                                <StackPanel Margin="0,8,0,0">
                                    <ui:Button HorizontalAlignment="Stretch"
                                               Content="Open model..."
                                               Appearance="Secondary"
                                               Click="OnFileOpen"
                                               ToolTip="Browse to a 3D model file. Same as dragging the file onto the viewport.">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Cube24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <TextBlock Text="…or drop a file onto the viewport."
                                               FontSize="10"
                                               Opacity="0.55"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Sketchfab" FontSize="12" Padding="10,4"
                                     ToolTip="Pull a 3D model directly from Sketchfab by URL. Requires a Sketchfab API token configured in Settings → Integrations.">
                                <StackPanel Margin="0,8,0,0">
                                    <ui:TextBox x:Name="SketchfabUrlBox"
                                                PlaceholderText="https://sketchfab.com/3d-models/..."
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                KeyDown="OnSketchfabUrlKeyDown"
                                                ToolTip="Paste the full Sketchfab model URL here, then press Enter or click Import. The model must be marked downloadable on Sketchfab." />
                                    <ui:Button Margin="0,8,0,0"
                                               HorizontalAlignment="Stretch"
                                               Content="Import from URL"
                                               Appearance="Secondary"
                                               Click="OnSketchfabSidebarImport"
                                               ToolTip="Download the model at the URL above and load it into the viewer.">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="ArrowDownload24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <TextBlock FontSize="10"
                                               Opacity="0.55"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Text="Model must be marked downloadable. Requires a Sketchfab API token in Settings." />
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="AI" FontSize="12" Padding="10,4"
                                     ToolTip="Generate a 3D model from a reference image using an AI provider (Meshy, etc.), then load it straight into the viewer. Requires a provider API key in Settings.">
                                <StackPanel Margin="0,8,0,0">
                                    <ui:Button HorizontalAlignment="Stretch"
                                               Content="Generate from image..."
                                               Appearance="Secondary"
                                               Click="OnOpenAiGenerator"
                                               ToolTip="Open the image-to-3D generator. Pick an image, choose a provider, get a model back.">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Image24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <TextBlock FontSize="10"
                                               Opacity="0.55"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Text="Generate a 3D model with Meshy or another AI provider, then load it straight into the viewer. Requires an API key in Settings." />
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                        </StackPanel>
                        </Border>

                        <!-- ─── GEOMETRY ─── (only meaningful with a model
                             loaded; pre-load the rows showed dashes and
                             pushed every other section down without
                             telling the user anything). -->
                        <Border local:PanelLayout.Id="geometry"
                                Background="Transparent"
                                Padding="0,0,0,4"
                                Visibility="{Binding HasModel, Converter={StaticResource BooleanToVisibility}}">
                        <StackPanel>
                            <DockPanel Margin="10,14,16,8">
                                <Border DockPanel.Dock="Left"
                                        Width="14" Height="18"
                                        Margin="0,0,4,0"
                                        Background="Transparent"
                                        Cursor="SizeAll"
                                        local:PanelLayout.DragHandle="True"
                                        ToolTip="Drag to reorder panel"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="⠿" FontSize="12" Opacity="0.4"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ui:SymbolIcon DockPanel.Dock="Right"
                                               Style="{StaticResource HelpIconStyle}"
                                               ToolTip="Vertex and triangle counts for the loaded model. FiveM targets keep these low — under ~10,000 tris and ~8 MB source per static prop is a healthy ceiling. Generate LODs in the ASSETS section if your high-detail mesh is heavier than that." />
                                <TextBlock Text="GEOMETRY"
                                           FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                            <Grid Margin="16,0,16,0" Style="{StaticResource StatRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Vertices" FontSize="12" Opacity="0.7" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding VertsDisplay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas"
                                           Visibility="{Binding IsModelLoading, Converter={StaticResource InverseBooleanToVisibility}}" />
                                <Border Grid.Column="1"
                                        Style="{StaticResource Skeleton}"
                                        Width="80" Height="13"
                                        Visibility="{Binding IsModelLoading, Converter={StaticResource BooleanToVisibility}}" />
                            </Grid>
                            <Grid Margin="16,0,16,0" Style="{StaticResource StatRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Triangles" FontSize="12" Opacity="0.7" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TrisDisplay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas"
                                           Visibility="{Binding IsModelLoading, Converter={StaticResource InverseBooleanToVisibility}}" />
                                <Border Grid.Column="1"
                                        Style="{StaticResource Skeleton}"
                                        Width="64" Height="13"
                                        Visibility="{Binding IsModelLoading, Converter={StaticResource BooleanToVisibility}}" />
                            </Grid>
                        </StackPanel>
                        </Border>

                        <!-- ─── ORIENTATION ─── Always open (no Expander).
                             Advanced sidebar — Hidden in Beginner. Shown at
                             Standard and Advanced. -->
                        <Border local:PanelLayout.Id="orientation"
                                Background="Transparent"
                                Padding="0,0,0,4"
                                Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}"
                                ToolTip="GTA/RAGE expects Z-up. Most glTF/OBJ assets are Y-up; FBX is mixed (Blender exports Y-up, Maya/Max usually Z-up). 'Auto-detect' reads the FBX header and falls back to Y-up. Override if your prop ships sideways in-game.">
                        <StackPanel Margin="10,8,16,0">
                            <DockPanel Margin="0,0,0,8">
                                <Border DockPanel.Dock="Left"
                                        Width="14" Height="18"
                                        Margin="0,0,4,0"
                                        Background="Transparent"
                                        Cursor="SizeAll"
                                        local:PanelLayout.DragHandle="True"
                                        ToolTip="Drag to reorder panel"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="⠿" FontSize="12" Opacity="0.4"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="ORIENTATION"
                                           FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                            <TextBlock Text="Up axis" Style="{StaticResource FieldLabel}" />
                            <ComboBox SelectedIndex="{Binding UpAxisIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      ToolTip="Which axis your source model treats as 'up'. RAGE expects Z-up; the exporter rotates Y-up sources by -90° on X. Auto-detect reads the FBX header (most reliable for game-pipeline FBX) and falls back to Y-up for glTF/OBJ. Override only if your prop ships sideways in-game.">
                                <ComboBoxItem Content="Auto-detect" ToolTip="Read FBX UpAxis metadata; fall back to Y-up. Right answer for ~95% of files." />
                                <ComboBoxItem Content="Y is up" ToolTip="Force Y-up interpretation — apply the -90°X rotation. Use for Blender FBX, glTF, OBJ." />
                                <ComboBoxItem Content="Z is up" ToolTip="Force Z-up interpretation — no rotation. Use for Maya / 3ds Max FBX." />
                            </ComboBox>
                        </StackPanel>
                        </Border>

                        <!-- ─── COLLISION ─── (prop only — weapons use
                             per-bone hit detection from the gun_root
                             skeleton, not scene-level collision meshes) -->
                        <Border local:PanelLayout.Id="collision"
                                Background="Transparent"
                                Padding="0,0,0,4"
                                Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                        <StackPanel Visibility="{Binding IsPropMode, Converter={StaticResource BooleanToVisibility}}">
                        <DockPanel Margin="10,14,16,8">
                            <Border DockPanel.Dock="Left"
                                    Width="14" Height="18"
                                    Margin="0,0,4,0"
                                    Background="Transparent"
                                    Cursor="SizeAll"
                                    local:PanelLayout.DragHandle="True"
                                    ToolTip="Drag to reorder panel"
                                    VerticalAlignment="Center">
                                <TextBlock Text="⠿" FontSize="12" Opacity="0.4"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ui:SymbolIcon DockPanel.Dock="Right"
                                           Style="{StaticResource HelpIconStyle}"
                                           ToolTip="Physical collision for the prop. Without this RAGE treats your prop as a phantom — players walk through it. The bound ships either embedded in the YDR (one file, recommended) or as a sibling .ybn. Pick the surface material so footsteps, bullet impacts, and bullet penetration use the right sound/effect set." />
                            <TextBlock Text="COLLISION"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Margin="16,0,16,0">
                            <ui:ToggleSwitch IsChecked="{Binding IncludeCollision}"
                                             Content="Generate collision mesh"
                                             Margin="0,0,0,8"
                                             ToolTip="Build a polygon-accurate BoundComposite > GeometryBVH from the loaded mesh. Off = no collision; the prop will be a phantom (players walk through it, bullets pass through, vehicles roll over it as if it isn't there). On is the default — turn off only if you're shipping collision separately." />
                            <ui:ToggleSwitch IsChecked="{Binding EmbedCollision}"
                                             Content="Embed in YDR (no .ybn)"
                                             IsEnabled="{Binding IsCollisionEmbeddable}"
                                             ToolTip="Attach the BoundComposite to Drawable.Bound so the YDR ships visual + collision in one file. Recommended for .ymap-placed static props (RAGE loads the bound from the same drawable resource it pulled for the visual). Off ships a sibling scene.ybn — useful if you want to swap in a Sollumz-built .ybn later."
                                             Margin="0,0,0,8" />
                            <TextBlock Text="Collision material" Style="{StaticResource FieldLabel}" />
                            <ComboBox SelectedValue="{Binding CollisionMaterial}"
                                      SelectedValuePath="Content"
                                      HorizontalAlignment="Stretch"
                                      IsEnabled="{Binding IncludeCollision}"
                                      ToolTip="Surface material — drives footstep / impact / penetration sounds and visual effects. CONCRETE for buildings and roads, METAL for vehicles and railings, WOOD for crates and trees, GRASS / DIRT / SAND for terrain, GLASS for windows (smashable), FOLIAGE for vegetation (bullets pass through).">
                                <ComboBoxItem Content="CONCRETE" />
                                <ComboBoxItem Content="METAL" />
                                <ComboBoxItem Content="WOOD" />
                                <ComboBoxItem Content="PLASTIC" />
                                <ComboBoxItem Content="GLASS" />
                                <ComboBoxItem Content="RUBBER" />
                                <ComboBoxItem Content="GRASS" />
                                <ComboBoxItem Content="DIRT" />
                                <ComboBoxItem Content="SAND" />
                                <ComboBoxItem Content="ROCK" />
                                <ComboBoxItem Content="FOLIAGE" />
                            </ComboBox>
                        </StackPanel>
                        </StackPanel>
                        </Border>

                        <!-- ─── GLASS ─── only when a layer is Material → Glass -->
                        <Border local:PanelLayout.Id="glass"
                                Background="Transparent"
                                Padding="0,0,0,4"
                                Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                        <StackPanel Visibility="{Binding ShowGlassSettings, Converter={StaticResource BooleanToVisibility}}">
                        <DockPanel Margin="10,14,16,8">
                            <Border DockPanel.Dock="Left"
                                    Width="14" Height="18"
                                    Margin="0,0,4,0"
                                    Background="Transparent"
                                    Cursor="SizeAll"
                                    local:PanelLayout.DragHandle="True"
                                    ToolTip="Drag to reorder panel"
                                    VerticalAlignment="Center">
                                <TextBlock Text="⠿" FontSize="12" Opacity="0.4"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ui:SymbolIcon DockPanel.Dock="Right"
                                           Style="{StaticResource HelpIconStyle}"
                                           ToolTip="How glass/window/mirror parts export. Appearance sets see-through vs reflective; Breakable makes the glass shatter (VFX + sound) and lets bullets pass when shot. Applies to any part FiveOS detects as glass, or that you tag Glass in the layers panel." />
                            <TextBlock Text="GLASS"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Margin="16,0,16,0">
                            <TextBlock Text="Appearance" Style="{StaticResource FieldLabel}" />
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="See-through" FontSize="11" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <Slider Grid.Column="1" Minimum="0" Maximum="1"
                                        Value="{Binding GlassOpacity}"
                                        VerticalAlignment="Center"
                                        ToolTip="Slide toward See-through for clear glass, toward Reflective for a shiny mirror-like surface (reflects the environment / sky). Applies to every glass part on export." />
                                <TextBlock Grid.Column="2" Text="Reflective" FontSize="11" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </Grid>
                            <ui:ToggleSwitch IsChecked="{Binding BreakableGlass}"
                                             Content="Breakable glass (shatters when shot)"
                                             Margin="0,8,0,0"
                                             ToolTip="Glass parts get GLASS_SHOOT_THROUGH collision — bullets pass through and the engine plays the glass-shatter VFX + sound on hit. Off keeps glass solid. Shatter-on-shot, not a physically-fragmenting .yft fragment." />
                        </StackPanel>
                        </StackPanel>
                        </Border>

                        <!-- ─── ASSETS ─── -->
                        <!-- Hidden in weapon mode: ytyp doesn't apply to
                             weapons (they're spawned via give-weapon, not
                             placed in maps), and we always extract textures
                             for weapons since the YTD pairs with the YDR
                             via weaponarchetypes.meta. -->
                        <Border local:PanelLayout.Id="assets"
                                Background="Transparent"
                                Padding="0,0,0,4"
                                Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                        <StackPanel Visibility="{Binding IsPropMode, Converter={StaticResource BooleanToVisibility}}">
                        <DockPanel Margin="10,18,16,8">
                            <Border DockPanel.Dock="Left"
                                    Width="14" Height="18"
                                    Margin="0,0,4,0"
                                    Background="Transparent"
                                    Cursor="SizeAll"
                                    local:PanelLayout.DragHandle="True"
                                    ToolTip="Drag to reorder panel"
                                    VerticalAlignment="Center">
                                <TextBlock Text="⠿" FontSize="12" Opacity="0.4"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ui:SymbolIcon DockPanel.Dock="Right"
                                           Style="{StaticResource HelpIconStyle}"
                                           ToolTip="Files the exporter generates alongside the .ydr. The .ytyp registers the archetype so the prop can be placed in .ymap files; texture extraction bakes embedded textures from the source FBX/GLB into the YDR's TextureDictionary. LOD generation produces medium/low/very-low detail versions of the mesh so the engine streams a coarser silhouette at distance." />
                            <TextBlock Text="ASSETS"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Margin="16,0,16,0">
                            <ui:ToggleSwitch IsChecked="{Binding IncludeYtyp}"
                                             Content="Generate .ytyp metadata"
                                             Margin="0,0,0,8"
                                             ToolTip="Write a .ytyp file that registers your prop as a placeable archetype. Without this you can spawn the model from script (CreateObject) but it can't be placed in a .ymap via CodeWalker." />
                            <ui:ToggleSwitch IsChecked="{Binding ExtractTextures}"
                                             Content="Extract embedded textures"
                                             Margin="0,0,0,8"
                                             ToolTip="Pull diffuse + normal maps from your source FBX/GLB (embedded or sidecar PNGs), encode them as DDS, and bake them into the YDR's TextureDictionary. Turn off only if you're shipping a separate .ytd dictionary." />
                            <ui:ToggleSwitch IsChecked="{Binding AnimatedProp}"
                                             Content="Animated prop (rig + animation)"
                                             Margin="0,0,0,8"
                                             Visibility="{Binding IsAnimatedPropsView, Converter={StaticResource InverseBooleanToVisibility}}"
                                             ToolTip="If your model ships a rig AND an animation clip, export it as an ANIMATED prop: the engine attaches a skeleton, rigidly binds each part to a bone, writes a matching .ycd, and sets the ytyp's Auto Start Anim flag so a placed prop plays on its own. Falls back to a normal static prop when there's no animation. Rigid binding animates WHOLE parts, so it suits mechanical models whose moving pieces are separate meshes — verify the motion on your FiveM server." />

                            <!-- Auto-spin sub-options: only relevant when
                                 Animated prop is on (static Props tab). On the
                                 Animated workspace the keys timeline owns motion. -->
                            <StackPanel Margin="16,0,0,8"
                                        Visibility="{Binding AnimatedProp, Converter={StaticResource BooleanToVisibility}}">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAnimatedPropsView}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ui:ToggleSwitch IsChecked="{Binding AutoSpin}"
                                                 Content="Auto-spin (no animation in file)"
                                                 Margin="0,0,0,6"
                                                 ToolTip="Model has no animation baked in? Generate one: FiveOS puts a rotation bone at the model's centre and spins it 360° on loop. Ideal for gears, fans, wheels, signs, turntables — no pre-animated file needed." />
                                <StackPanel Visibility="{Binding AutoSpin, Converter={StaticResource BooleanToVisibility}}">
                                    <Grid Margin="0,2,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Spin axis" VerticalAlignment="Center" Opacity="0.7" />
                                        <ComboBox Grid.Column="1" SelectedIndex="{Binding SpinAxisIndex}"
                                                  HorizontalAlignment="Left" Width="150"
                                                  ToolTip="Which axis the prop turns around. Z = vertical (fans, turntables); X / Y = horizontal (wheels, rollers).">
                                            <ComboBoxItem Content="X (horizontal)" />
                                            <ComboBoxItem Content="Y (horizontal)" />
                                            <ComboBoxItem Content="Z (vertical)" />
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Secs / rev" VerticalAlignment="Center" Opacity="0.7" />
                                        <ui:NumberBox Grid.Column="1" Value="{Binding SpinSeconds, Mode=TwoWay}"
                                                      Minimum="0.2" Maximum="120" SmallChange="0.5" LargeChange="1"
                                                      HorizontalAlignment="Left" Width="150"
                                                      ToolTip="Seconds for one full turn. Lower = faster spin." />
                                    </Grid>
                                    <ui:ToggleSwitch IsChecked="{Binding SpinReverse}"
                                                     Content="Reverse direction"
                                                     Margin="0,0,0,4" />
                                </StackPanel>
                            </StackPanel>

                            <ui:ToggleSwitch IsChecked="{Binding GenerateLods}"
                                             Content="Generate LODs (med / low / vlow)"
                                             Margin="0,0,0,8"
                                             ToolTip="Deep-clone the High mesh three times and decimate each via quadric-edge-collapse to populate Med (50%), Low (20%), and VLow (5%) tier slots in the YDR. RAGE then streams a coarser silhouette as the camera moves away. Adds ~30-50% to the YDR size; worth it for any prop visible from across the map, overkill for small clutter." />
                            <!-- Per-tier LOD draw distances (m). Hidden until
                                 Generate LODs is on — the four NumberBoxes
                                 are dead weight otherwise. High renders
                                 0 → High, Med renders High → Med, etc. Past
                                 VLow the prop disappears entirely; that
                                 value also drives the .ytyp's archetype cull
                                 radius. -->
                            <StackPanel Visibility="{Binding GenerateLods, Converter={StaticResource BooleanToVisibility}}">
                                <TextBlock Text="LOD distances (m)"
                                           Opacity="0.6"
                                           Margin="0,4,0,4"
                                           FontSize="11" />
                                <Grid Margin="0,0,0,4"
                                      ToolTip="Distance (m) at which the engine STOPS rendering the High tier and switches to Med. Defaults to 60 m. Drop this lower for small props; raise it for landmarks where the high-poly silhouette matters at distance.">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="High" Width="48"
                                               VerticalAlignment="Center" Opacity="0.8" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding LodDistHigh}"
                                                  Minimum="5" Maximum="2000"
                                                  SmallChange="10" LargeChange="50"
                                                  MaxDecimalPlaces="0"
                                                  ClearButtonEnabled="False" />
                                </Grid>
                                <Grid Margin="0,0,0,4"
                                      ToolTip="Distance (m) at which the engine switches from Med to Low. Defaults to 120 m. Only meaningful when 'Generate LODs' is on.">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Med" Width="48"
                                               VerticalAlignment="Center" Opacity="0.8" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding LodDistMed}"
                                                  Minimum="5" Maximum="2000"
                                                  SmallChange="10" LargeChange="50"
                                                  MaxDecimalPlaces="0"
                                                  ClearButtonEnabled="False" />
                                </Grid>
                                <Grid Margin="0,0,0,4"
                                      ToolTip="Distance (m) at which the engine switches from Low to VLow. Defaults to 250 m. Only meaningful when 'Generate LODs' is on.">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Low" Width="48"
                                               VerticalAlignment="Center" Opacity="0.8" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding LodDistLow}"
                                                  Minimum="5" Maximum="2000"
                                                  SmallChange="10" LargeChange="50"
                                                  MaxDecimalPlaces="0"
                                                  ClearButtonEnabled="False" />
                                </Grid>
                                <Grid Margin="0,0,0,4"
                                      ToolTip="Outer draw distance (m). Past this distance the prop disappears entirely — RAGE culls the whole entity. Also written to the .ytyp's archetype-level cull radius so the engine drops the prop from streaming at the same point the drawable stops rendering. Defaults to 500 m.">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="VLow" Width="48"
                                               VerticalAlignment="Center" Opacity="0.8" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding LodDistVlow}"
                                                  Minimum="5" Maximum="2000"
                                                  SmallChange="10" LargeChange="50"
                                                  MaxDecimalPlaces="0"
                                                  ClearButtonEnabled="False" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        </StackPanel>
                        </Border>

                        <!-- ─── TRANSFORM ─── Always open (no Expander).
                             Sidebar coords; live-mirrored from the viewer
                             gizmo. Hidden until a model is loaded. -->
                        <Border local:PanelLayout.Id="transform"
                                Background="Transparent"
                                Padding="0,0,0,4"
                                Visibility="{Binding HasModel, Converter={StaticResource BooleanToVisibility}}"
                                ToolTip="Position / rotation / scale the prop is exported with. Mirrors the gizmo in the 3D viewport — drag the gizmo handles or type values here. Position is preview-only (the prop always exports at the origin so it spawns cleanly wherever placed in a .ymap); rotation and scale ARE baked into the exported geometry.">
                        <StackPanel Margin="10,8,16,0">
                            <DockPanel Margin="0,0,0,8">
                                <Border DockPanel.Dock="Left"
                                        Width="14" Height="18"
                                        Margin="0,0,4,0"
                                        Background="Transparent"
                                        Cursor="SizeAll"
                                        local:PanelLayout.DragHandle="True"
                                        ToolTip="Drag to reorder panel"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="⠿" FontSize="12" Opacity="0.4"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="TRANSFORM"
                                           FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="POS" FontSize="10" FontWeight="SemiBold" Opacity="0.6" VerticalAlignment="Center"
                                           ToolTip="Position offset in metres. Preview-only — the prop always exports at the origin (0, 0, 0) so it spawns cleanly wherever placed in a .ymap. Scroll-wheel over a field to nudge; Shift+wheel for bigger steps." />
                                <ui:NumberBox Grid.Column="1" Value="{Binding TransformPosX}" SmallChange="0.01" LargeChange="0.1" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Position X (preview only, not baked into export)." />
                                <ui:NumberBox Grid.Column="3" Value="{Binding TransformPosY}" SmallChange="0.01" LargeChange="0.1" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Position Y (preview only, not baked into export)." />
                                <ui:NumberBox Grid.Column="5" Value="{Binding TransformPosZ}" SmallChange="0.01" LargeChange="0.1" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Position Z (preview only, not baked into export)." />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ROT" FontSize="10" FontWeight="SemiBold" Opacity="0.6" VerticalAlignment="Center"
                                           ToolTip="Euler angles in degrees (XYZ order). Baked into the exported drawable so the prop ships in this orientation. Scroll-wheel for 1° steps, Shift+wheel for 15°." />
                                <ui:NumberBox Grid.Column="1" Value="{Binding TransformRotX}" SmallChange="1" LargeChange="15" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="1" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Rotation X (pitch) in degrees — baked into the export." />
                                <ui:NumberBox Grid.Column="3" Value="{Binding TransformRotY}" SmallChange="1" LargeChange="15" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="1" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Rotation Y (yaw) in degrees — baked into the export." />
                                <ui:NumberBox Grid.Column="5" Value="{Binding TransformRotZ}" SmallChange="1" LargeChange="15" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="1" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Rotation Z (roll) in degrees — baked into the export." />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="SCL" FontSize="10" FontWeight="SemiBold" Opacity="0.6" VerticalAlignment="Center"
                                           ToolTip="Per-axis scale factor. 1.0 = source size on that axis. Baked into the exported drawable — turn off the gizmo's Uniform-scale toggle to stretch along a single axis. Scroll-wheel for 0.01 steps." />
                                <ui:NumberBox Grid.Column="1" Value="{Binding TransformScaleX}" SmallChange="0.01" LargeChange="0.1" Minimum="0.001" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Scale X — baked into the export." />
                                <ui:NumberBox Grid.Column="3" Value="{Binding TransformScaleY}" SmallChange="0.01" LargeChange="0.1" Minimum="0.001" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Scale Y — baked into the export." />
                                <ui:NumberBox Grid.Column="5" Value="{Binding TransformScaleZ}" SmallChange="0.01" LargeChange="0.1" Minimum="0.001" SpinButtonPlacementMode="Hidden" MaxDecimalPlaces="3" PreviewMouseWheel="TransformNumberBox_PreviewMouseWheel" ToolTip="Scale Z — baked into the export." />
                            </Grid>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:Button Grid.Column="0"
                                           HorizontalAlignment="Stretch"
                                           Appearance="Secondary"
                                           Content="Reset"
                                           Command="{Binding ResetTransformCommand}"
                                           ToolTip="Reset position, rotation, and scale to their defaults." />
                                <ui:Button Grid.Column="2"
                                           HorizontalAlignment="Stretch"
                                           Appearance="Secondary"
                                           Content="Snap to Ground"
                                           Click="OnSnapToGround"
                                           ToolTip="Drop the model so its bounding-box bottom sits flush with Y=0 (the grid plane = the ground plane after the export's Y-up→Z-up swap). Honors current rotation and scale.">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ArrowDown24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                            </Grid>
                        </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ───────── Center viewport ───────── -->
            <Grid x:Name="PropsCenterGrid" Grid.Column="2" Margin="16,8,16,8">
                <Grid.ColumnDefinitions>
                    <!-- Layers dock (left) -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Viewport -->
                    <ColumnDefinition Width="*" />
                    <!-- Layers dock (right) -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <!-- Optimization-health banner. Auto-height so it
                         disappears entirely when not visible. We can't
                         z-overlay WebView2 (airspace), so the banner has
                         to push the viewport down via row layout. -->
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ═══════════════════════════════════════════════════
                     OPTIMIZATION HEALTH BANNER
                     ═══════════════════════════════════════════════════ -->
                <Border Grid.Row="0" Grid.Column="1"
                        Margin="0,0,0,8"
                        CornerRadius="6"
                        BorderThickness="1"
                        Padding="14,10"
                        Visibility="{Binding IsOptimizationHintVisible, Converter={StaticResource BooleanToVisibility}}">
                    <Border.Style>
                        <!-- Yellow for Warn, red-tinted for Fail. Both
                             stay readable in light + dark themes. -->
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#22FFC857" />
                            <Setter Property="BorderBrush" Value="#88FFC857" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OptimizationHintIsFail}" Value="True">
                                    <Setter Property="Background" Value="#22FF6060" />
                                    <Setter Property="BorderBrush" Value="#88FF6060" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon Grid.Column="0"
                                       Symbol="Warning24"
                                       FontSize="22"
                                       VerticalAlignment="Center"
                                       Margin="2,0,12,0"
                                       Foreground="#FFC857">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Foreground" Value="#FFC857" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OptimizationHintIsFail}" Value="True">
                                            <Setter Property="Foreground" Value="#FF7060" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding OptimizationHintTitle}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding OptimizationHintBody}"
                                       FontSize="11"
                                       Opacity="0.8"
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding IsOptimizationHintPreviewing, Converter={StaticResource InverseBooleanToVisibility}}" />

                            <!-- Preview-mode slider + projected stats. The
                                 user drags freely; releasing the slider
                                 (debounced in code-behind) triggers the
                                 actual decimate + viewer reload. The
                                 model is never modified on disk until
                                 they click Confirm. -->
                            <Grid Margin="0,4,0,0"
                                  Visibility="{Binding IsOptimizationHintPreviewing, Converter={StaticResource BooleanToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- Shared preview slider: tri target for the
                                     decimate preview, max texture resolution
                                     (power-of-two, tick-snapped) for the
                                     texture-optimize preview. -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding OptimizeSliderLabel}"
                                           FontSize="11"
                                           Opacity="0.75"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <Slider Grid.Column="1"
                                        x:Name="OptimizeSlider"
                                        Value="{Binding OptimizeTargetTris, Mode=TwoWay}"
                                        Minimum="{Binding OptimizeSliderMin}"
                                        Maximum="{Binding OptimizeSliderMax}"
                                        TickFrequency="{Binding OptimizeSliderTick}"
                                        IsSnapToTickEnabled="{Binding IsOptimizeSliderSnapping}"
                                        ValueChanged="OnOptimizeSliderValueChanged"
                                        Thumb.DragCompleted="OnOptimizeSliderDragCompleted"
                                        Visibility="{Binding IsTexturePreviewMode, Converter={StaticResource InverseBooleanToVisibility}}"
                                        ToolTip="Target triangle count after decimation. Drag left = more aggressive reduction. The preview re-runs when you release the slider; Confirm to lock it in or Cancel to restore the original mesh." />

                                <!-- Texture-optimize preview: four concrete
                                     resolution choices, each labelled with the
                                     file size it produces (filled in as the
                                     background passes finish). Selecting one
                                     hot-swaps the viewer preview. -->
                                <ItemsControl Grid.Column="1"
                                              ItemsSource="{Binding TextureDimOptions}"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding IsTexturePreviewMode, Converter={StaticResource BooleanToVisibility}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton GroupName="FosTextureDim"
                                                         IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                         Checked="OnTextureDimChecked"
                                                         Margin="0,0,14,0"
                                                         VerticalContentAlignment="Center"
                                                         ToolTip="Cap every texture at this resolution. Higher = sharper up close, heavier to stream.">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SizeText}"
                                                               FontSize="10"
                                                               Opacity="0.65" />
                                                </StackPanel>
                                            </RadioButton>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="10,0,0,0">
                                    <ctrl:DotMatrixLoader LoaderStyle="HelixGlow"
                                                          DotSize="4"
                                                          DotSpacing="2"
                                                          Margin="0,0,8,0"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding IsOptimizePreviewDecimating, Converter={StaticResource BooleanToVisibility}}">
                                        <ctrl:DotMatrixLoader.DotColor>
                                            <SolidColorBrush Color="#FFC857" />
                                        </ctrl:DotMatrixLoader.DotColor>
                                    </ctrl:DotMatrixLoader>
                                    <TextBlock Text="{Binding OptimizePreviewStats}"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Action cluster — initial state: 3-button bar.
                             Hidden once we enter preview mode. -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding IsOptimizationHintActionable, Converter={StaticResource BooleanToVisibility}}">
                            <ui:Button Appearance="Primary"
                                       Padding="14,6"
                                       Margin="0,0,6,0"
                                       Click="OnAutoOptimizeBanner"
                                       ToolTip="Optimize with a live preview — heavy meshes get a decimate slider, texture-heavy files get their textures compressed. Confirm or Cancel afterwards.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Sparkle24" FontSize="14" Margin="0,0,6,0" />
                                    <TextBlock Text="Optimize" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Appearance="Secondary"
                                       Padding="14,6"
                                       Margin="0,0,6,0"
                                       Click="OnOpenOptimizeTabBanner"
                                       ToolTip="Switch to the Optimize tab for finer control over decimation, textures, and collision.">
                                <TextBlock Text="Open Optimize tab" />
                            </ui:Button>
                            <ui:Button Appearance="Transparent"
                                       Padding="14,6"
                                       Click="OnDismissOptimizeBanner"
                                       ToolTip="Dismiss this banner — convert anyway.">
                                <TextBlock Text="Ignore Warning" />
                            </ui:Button>
                        </StackPanel>

                        <!-- Action cluster — preview state: Confirm + Cancel.
                             Cancel restores the original mesh from before
                             preview began; Confirm locks in the current
                             slider position as the new working file. -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding IsOptimizationHintPreviewActionable, Converter={StaticResource BooleanToVisibility}}">
                            <ui:Button Appearance="Primary"
                                       Padding="14,6"
                                       Margin="0,0,6,0"
                                       Click="OnConfirmOptimizeBanner"
                                       ToolTip="Lock in this decimation as the new working model. Convert will produce a YDR from this version.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Check24" FontSize="14" Margin="0,0,6,0" />
                                    <TextBlock Text="Confirm" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Appearance="Secondary"
                                       Padding="14,6"
                                       Click="OnCancelOptimizeBanner"
                                       ToolTip="Throw away the preview and restore the original mesh.">
                                <TextBlock Text="Cancel" />
                            </ui:Button>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding IsOptimizing, Converter={StaticResource BooleanToVisibility}}">
                            <ctrl:DotMatrixLoader LoaderStyle="HelixGlow"
                                                  DotSize="6"
                                                  DotSpacing="3"
                                                  Margin="0,0,8,0">
                                <ctrl:DotMatrixLoader.DotColor>
                                    <SolidColorBrush Color="#FFC857" />
                                </ctrl:DotMatrixLoader.DotColor>
                            </ctrl:DotMatrixLoader>
                            <TextBlock Text="Optimizing..."
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Grid.Column="1">
                <!-- State 1: empty drop zone -->
                <Border Visibility="{Binding HasModel, Converter={StaticResource InverseBooleanToVisibility}}"
                        Background="Transparent"
                        Cursor="Hand"
                        MouseLeftButtonUp="OnDropZoneClick">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0.9" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1.0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <!-- Soft dashed dropzone outline — neutral, not a hard
                             accent box. Reads as an intentional "drop here"
                             target instead of an unfinished blue frame. -->
                        <Rectangle RadiusX="14" RadiusY="14"
                                   Stroke="{DynamicResource ControlElevationBorderBrush}"
                                   StrokeThickness="1.5"
                                   StrokeDashArray="5 5"
                                   Opacity="0.5"
                                   Margin="2" />
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/Branding/FiveOS.png"
                               Width="140" Height="140"
                               Opacity="0.85"
                               Margin="0,0,0,20"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Drop your 3D model here"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="or click to browse"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Opacity="0.7"
                                   Margin="0,0,0,24" />
                        <ItemsControl HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".obj" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".glb" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".gltf" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".fbx" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".dae" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".ply" FontSize="11" FontFamily="Consolas" />
                            </Border>
                            <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="8,3" Margin="3,0">
                                <TextBlock Text=".stl" FontSize="11" FontFamily="Consolas" />
                            </Border>
                        </ItemsControl>
                    </StackPanel>
                    </Grid>
                </Border>

                <!-- State 2: 3D viewport (WebView2 + three.js).
                     Hidden during the success screen AND during model
                     loading because WebView2's HwndHost always renders on
                     top of WPF (airspace) — an overlay positioned z-above
                     would be covered by the live viewer frame, so we
                     collapse the host instead. See IsViewportVisible. -->
                <Grid x:Name="ViewportRoot"
                      Visibility="{Binding IsViewportVisible, Converter={StaticResource BooleanToVisibility}}">
                    <Border CornerRadius="8"
                            ClipToBounds="True"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                        <wv2:WebView2 x:Name="Viewport" />
                    </Border>
                </Grid>

                <!-- Model-loading overlay: sibling of ViewportRoot (NOT a
                     child) so WebView2 collapses out of the way while this
                     paints. Same DotMatrixLoader the splash uses, for a
                     consistent in-app loading look. -->
                <Border CornerRadius="8"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        Visibility="{Binding IsModelLoading, Converter={StaticResource BooleanToVisibility}}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <ctrl:DotMatrixLoader LoaderStyle="HelixGlow"
                                              DotSize="9"
                                              DotSpacing="5"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,18">
                            <ctrl:DotMatrixLoader.DotColor>
                                <SolidColorBrush Color="#5BAEFF" />
                            </ctrl:DotMatrixLoader.DotColor>
                        </ctrl:DotMatrixLoader>
                        <TextBlock Text="Loading model"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Opacity="0.85" />
                        <TextBlock Text="{Binding SourceFileName}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Center"
                                   Opacity="0.5"
                                   Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="360" />
                    </StackPanel>
                </Border>
                </Grid>

                <!-- ═══════════════════════════════════════════════════
                     LAYERS / PANELS sidebar — docks left or right of the
                     viewport. Drag the PANELS header to move the whole
                     sidebar; side is saved in settings.
                     ═══════════════════════════════════════════════════ -->
                <Border x:Name="LayersPanel"
                        Grid.Column="{Binding LayersDockColumn}"
                        Grid.Row="1"
                        Margin="{Binding LayersPanelMargin}"
                        Width="{Binding LayersPanelWidth}"
                        MinWidth="280"
                        MaxWidth="560"
                        CornerRadius="2"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding IsLayersPanelOpen, Converter={StaticResource BooleanToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLayersPanelCollapsed}" Value="True">
                                    <Setter Property="Width" Value="32" />
                                    <Setter Property="MinWidth" Value="32" />
                                    <Setter Property="MaxWidth" Value="32" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Drag the viewport-facing edge to widen / narrow. -->
                        <Border Grid.Row="0" Grid.RowSpan="2"
                                x:Name="PanelsResizeThumb"
                                Width="8"
                                HorizontalAlignment="{Binding PanelsResizeThumbAlign}"
                                Cursor="SizeWE"
                                Visibility="{Binding IsLayersPanelCollapsed, Converter={StaticResource InverseBooleanToVisibility}}"
                                MouseLeftButtonDown="OnPanelsResizeDown"
                                MouseMove="OnPanelsResizeMove"
                                MouseLeftButtonUp="OnPanelsResizeUp"
                                LostMouseCapture="OnPanelsResizeLostCapture"
                                ToolTip="Drag to widen or narrow this sidebar">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                            <Setter Property="Opacity" Value="0.45" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <Border x:Name="PanelsDockHeader"
                                Grid.Row="0"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                Padding="6,5"
                                Background="Transparent"
                                Cursor="SizeAll"
                                Visibility="{Binding IsLayersPanelCollapsed, Converter={StaticResource InverseBooleanToVisibility}}"
                                MouseLeftButtonDown="OnPanelsDockHeaderDown"
                                MouseMove="OnPanelsDockHeaderMove"
                                MouseLeftButtonUp="OnPanelsDockHeaderUp"
                                LostMouseCapture="OnPanelsDockHeaderLostCapture"
                                ToolTip="Drag header to dock left/right. Drag the highlighted edge to resize.">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="⠿"
                                           FontSize="14"
                                           Opacity="0.55"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                                <ui:SymbolIcon Grid.Column="1"
                                               Symbol="Layer24"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Opacity="0.75"
                                               IsHitTestVisible="False" />
                                <TextBlock Grid.Column="2"
                                           Text="PANELS"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           Opacity="0.65"
                                           IsHitTestVisible="False"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <ui:Button Grid.Column="3"
                                           Appearance="Transparent"
                                           Width="22" Height="22"
                                           Padding="0"
                                           Command="{Binding ToggleLayersPanelCollapsedCommand}"
                                           ToolTip="Collapse panels">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ChevronRight24" FontSize="12" />
                                    </ui:Button.Icon>
                                </ui:Button>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Grid.RowSpan="3"
                                Background="Transparent"
                                Cursor="Hand"
                                MouseLeftButtonUp="OnLayersCollapsedStripClick"
                                ToolTip="Expand layers panel"
                                Visibility="{Binding IsLayersPanelCollapsed, Converter={StaticResource BooleanToVisibility}}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Margin="0,10,0,0">
                                <ui:SymbolIcon Symbol="ChevronLeft24"
                                               FontSize="13"
                                               Opacity="0.7"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,6" />
                                <ui:SymbolIcon Symbol="Layer24"
                                               FontSize="16"
                                               Opacity="0.85"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                <TextBlock Text="Layers"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Opacity="0.7"
                                           HorizontalAlignment="Center">
                                    <TextBlock.LayoutTransform>
                                        <RotateTransform Angle="90" />
                                    </TextBlock.LayoutTransform>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Simple linear flow: model → textures → yes/no → convert/pack -->
                        <Grid Grid.Row="1"
                              x:Name="PackPanel"
                              Margin="0"
                              Visibility="{Binding IsLayersPanelCollapsed, Converter={StaticResource InverseBooleanToVisibility}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Layers tree fills the top -->
                            <ScrollViewer Grid.Row="0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="10,8,10,4">
                                <StackPanel>
                                <TextBlock Text="LAYERS"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Opacity="0.5"
                                           Margin="0,0,0,6" />

                                <Border BorderThickness="0"
                                        Background="Transparent"
                                        Padding="0"
                                        Margin="0,0,0,8">
                                    <TreeView x:Name="OutlinerTree"
                                              ItemsSource="{Binding OutlinerRoots}"
                                              BorderThickness="0"
                                              Background="Transparent"
                                              AllowDrop="True"
                                              Drop="OnOutlinerFileDrop"
                                              DragOver="OnOutlinerFileDragOver"
                                              PreviewMouseLeftButtonDown="OnOutlinerPreviewMouseDown"
                                              PreviewMouseRightButtonDown="OnOutlinerPreviewMouseRightDown"
                                              PreviewMouseMove="OnOutlinerMouseMove"
                                              PreviewMouseLeftButtonUp="OnOutlinerMouseUp"
                                              LostMouseCapture="OnOutlinerLostCapture"
                                              MouseDoubleClick="OnOutlinerDoubleClick"
                                              PreviewKeyDown="OnOutlinerKeyDown"
                                              SelectedItemChanged="OnOutlinerSelectedItemChanged"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <TreeView.ContextMenu>
                                            <ContextMenu x:Name="OutlinerContextMenu"
                                                         Opened="OnOutlinerContextMenuOpened" />
                                        </TreeView.ContextMenu>
                                        <TreeView.Template>
                                            <ControlTemplate TargetType="TreeView">
                                                <ItemsPresenter />
                                            </ControlTemplate>
                                        </TreeView.Template>
                                        <TreeView.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                                            <!-- C4D Object Manager expander: small bordered box with
                                                 a + (collapsed) or − (expanded). -->
                                            <Style x:Key="OutlinerExpandToggleStyle" TargetType="ToggleButton">
                                                <Setter Property="Focusable" Value="False" />
                                                <Setter Property="Width" Value="14" />
                                                <Setter Property="Height" Value="14" />
                                                <Setter Property="Margin" Value="0,0,3,0" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent">
                                                                <Border Width="11" Height="11"
                                                                        CornerRadius="1"
                                                                        BorderThickness="1"
                                                                        BorderBrush="{DynamicResource FiveOSTrackBrush}"
                                                                        Background="{DynamicResource FiveOSPanelDeepBrush}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                                    <Grid>
                                                                        <Rectangle Width="5" Height="1"
                                                                                   Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" />
                                                                        <Rectangle x:Name="VBar"
                                                                                   Width="1" Height="5"
                                                                                   Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Border>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="VBar" Property="Visibility" Value="Collapsed" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                            <HierarchicalDataTemplate DataType="{x:Type svc:PropPackTreeNode}"
                                                                      ItemsSource="{Binding Children}">
                                                <!-- Photoshop-style layer row:
                                                     eye · icon chip · name · status/detail.
                                                     Queue rows dim + show a status chip; hidden
                                                     layers dim behind an eye-off. -->
                                                <Grid MinHeight="21" Background="Transparent">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEyeOn}" Value="False">
                                                                    <Setter Property="Opacity" Value="0.45" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20" />
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Eye on EVERY layer: parts = viewport+export, staged
                                                         and queued layers = include-in-export, groups =
                                                         whole-group toggle. -->
                                                    <ui:Button Grid.Column="0"
                                                               Appearance="Transparent"
                                                               Width="18" Height="18"
                                                               Padding="0"
                                                               VerticalAlignment="Center"
                                                               Click="OnOutlinerEyeToggle"
                                                               Tag="{Binding}"
                                                               ToolTip="Toggle visibility — hidden parts are left out of the export, hidden layers are skipped when their group builds.">
                                                        <Grid>
                                                            <ui:SymbolIcon Symbol="Eye24"
                                                                           FontSize="11"
                                                                           Visibility="{Binding IsEyeOn, Converter={StaticResource BooleanToVisibility}}" />
                                                            <ui:SymbolIcon Symbol="EyeOff24"
                                                                           FontSize="11"
                                                                           Opacity="0.45"
                                                                           Visibility="{Binding IsEyeOn, Converter={StaticResource InverseBooleanToVisibility}}" />
                                                        </Grid>
                                                    </ui:Button>

                                                    <!-- Flat C4D-style object icon: green for objects,
                                                         accent for group folders. -->
                                                    <ui:SymbolIcon Grid.Column="1"
                                                                   Symbol="{Binding Icon}"
                                                                   FontSize="12"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center">
                                                        <ui:SymbolIcon.Style>
                                                            <Style TargetType="ui:SymbolIcon">
                                                                <Setter Property="Foreground" Value="#7DBB63" />
                                                                <Setter Property="Opacity" Value="0.95" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPack}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource FiveOSAccentBrightBrush}" />
                                                                        <Setter Property="Opacity" Value="1" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:SymbolIcon.Style>
                                                    </ui:SymbolIcon>

                                                    <!-- Name — double-click a group to rename inline -->
                                                    <Grid Grid.Column="2" Margin="6,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="11.5"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Visibility="{Binding IsRenaming, Converter={StaticResource InverseBooleanToVisibility}}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsGroupRow}" Value="True">
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBox Text="{Binding Name, Mode=OneWay}"
                                                                 FontSize="12"
                                                                 Padding="4,1"
                                                                 MinHeight="22"
                                                                 VerticalAlignment="Center"
                                                                 Tag="{Binding}"
                                                                 Visibility="{Binding IsRenaming, Converter={StaticResource BooleanToVisibility}}"
                                                                 IsVisibleChanged="OnGroupRenameBoxVisible"
                                                                 Loaded="OnGroupRenameBoxLoaded"
                                                                 KeyDown="OnGroupRenameKeyDown"
                                                                 LostFocus="OnGroupRenameLostFocus" />
                                                    </Grid>

                                                    <!-- Right side: queue status chip, else the detail badge -->
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,4,0">
                                                        <Border CornerRadius="8"
                                                                Padding="7,2"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding IsQueueItem, Converter={StaticResource BooleanToVisibility}}"
                                                                ToolTip="{Binding QueueItem.Error}">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding QueueItem.IsRunning}" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource FiveOSAccentSoftBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="9.5" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="queued" />
                                                                        <Setter Property="Opacity" Value="0.75" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding QueueItem.IsRunning}" Value="True">
                                                                                <Setter Property="Text" Value="converting…" />
                                                                                <Setter Property="Foreground" Value="{DynamicResource FiveOSAccentBrightBrush}" />
                                                                                <Setter Property="Opacity" Value="1" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding QueueItem.IsFailed}" Value="True">
                                                                                <Setter Property="Text" Value="failed" />
                                                                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                                                <Setter Property="Opacity" Value="1" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding QueueItem.IsDone}" Value="True">
                                                                                <Setter Property="Text" Value="done" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <TextBlock Text="{Binding Detail}"
                                                                   FontSize="10"
                                                                   Opacity="0.5"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding IsQueueItem, Converter={StaticResource InverseBooleanToVisibility}}" />
                                                    </StackPanel>
                                                </Grid>
                                            </HierarchicalDataTemplate>
                                        </TreeView.Resources>
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <Setter Property="Padding" Value="2,1" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TreeViewItem">
                                                            <StackPanel Background="Transparent">
                                                                <!-- Full-row Photoshop selection: solid fill +
                                                                     3px accent bar on the left edge. -->
                                                                <Border x:Name="Bd"
                                                                        Background="Transparent"
                                                                        BorderThickness="1"
                                                                        BorderBrush="Transparent"
                                                                        CornerRadius="4"
                                                                        Padding="{TemplateBinding Padding}"
                                                                        SnapsToDevicePixels="True">
                                                                    <Grid Background="Transparent">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border x:Name="SelBar"
                                                                                Grid.Column="0"
                                                                                Width="3"
                                                                                CornerRadius="1"
                                                                                Margin="0,3,3,3"
                                                                                Background="{DynamicResource FiveOSAccentBrush}"
                                                                                Opacity="0"
                                                                                SnapsToDevicePixels="True" />
                                                                        <ToggleButton x:Name="Expander"
                                                                                      Grid.Column="1"
                                                                                      ClickMode="Press"
                                                                                      VerticalAlignment="Center"
                                                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                                      Style="{StaticResource OutlinerExpandToggleStyle}" />
                                                                        <ContentPresenter x:Name="PART_Header"
                                                                                          Grid.Column="2"
                                                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                          VerticalAlignment="Center"
                                                                                          ContentSource="Header" />
                                                                    </Grid>
                                                                </Border>
                                                                <!-- C4D-style hierarchy guide: a vertical line
                                                                     runs through the indent of expanded branches. -->
                                                                <Grid x:Name="ItemsHost" Visibility="Collapsed">
                                                                    <Border Width="1"
                                                                            Background="{DynamicResource FiveOSTrackBrush}"
                                                                            Opacity="0.55"
                                                                            HorizontalAlignment="Left"
                                                                            Margin="12,0,0,2"
                                                                            SnapsToDevicePixels="True" />
                                                                    <ItemsPresenter Margin="18,0,0,0" />
                                                                </Grid>
                                                            </StackPanel>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsExpanded" Value="True">
                                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                                                </Trigger>
                                                                <Trigger Property="HasItems" Value="False">
                                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource FiveOSHoverBrush}" />
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource FiveOSAccentSoftBrush}" />
                                                                    <Setter TargetName="SelBar" Property="Opacity" Value="1" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource FiveOSAccentBrush}" />
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource FiveOSAccentSoftBrush}" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                    </TreeView>
                                </Border>

                                <!-- Housing fields when a stream prop is selected -->
                                <StackPanel Visibility="{Binding SelectedPackEntry, Converter={StaticResource NullToVisibility}}"
                                            Margin="0,0,0,8">
                                    <ui:TextBox Text="{Binding SelectedPackEntry.Label, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="Menu label"
                                                FontSize="12"
                                                Padding="8,5"
                                                MinHeight="28"
                                                Margin="0,0,0,6" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  SelectedValue="{Binding SelectedPackEntry.Category}"
                                                  ItemsSource="{x:Static svc:HousingCategory.All}"
                                                  FontSize="11"
                                                  MinHeight="28" />
                                        <ui:TextBox Grid.Column="2"
                                                    Text="{Binding SelectedPackEntry.Price, UpdateSourceTrigger=LostFocus}"
                                                    FontSize="11"
                                                    Padding="4,4"
                                                    MinHeight="28"
                                                    HorizontalContentAlignment="Right" />
                                        <ComboBox Grid.Column="4"
                                                  SelectedValue="{Binding SelectedPackEntry.Type}"
                                                  SelectedValuePath="Tag"
                                                  FontSize="11"
                                                  MinHeight="28">
                                            <ComboBoxItem Content="None" Tag="{x:Static svc:FurnitureType.None}" />
                                            <ComboBoxItem Content="Storage" Tag="{x:Static svc:FurnitureType.Storage}" />
                                            <ComboBoxItem Content="Wardrobe" Tag="{x:Static svc:FurnitureType.Wardrobe}" />
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>

                                <!-- Mesh optimize strip for selected part -->
                                <Border CornerRadius="4"
                                        Padding="8,8,8,6"
                                        Margin="0,0,0,10"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        Visibility="{Binding SelectedModelPart.IsMeshSliderOpen, Converter={StaticResource BooleanToVisibility}, FallbackValue=Collapsed}">
                                    <StackPanel DataContext="{Binding SelectedModelPart}">
                                        <TextBlock Text="{Binding MeshOptimizeStatsDisplay}"
                                                   FontSize="11"
                                                   Opacity="0.85"
                                                   Margin="0,0,0,6" />
                                        <Slider Minimum="{Binding MeshSliderMin}"
                                                Maximum="{Binding MeshSliderMax}"
                                                Value="{Binding MeshTargetTris, Mode=TwoWay}"
                                                TickFrequency="{Binding MeshSliderTick}"
                                                IsSnapToTickEnabled="False"
                                                IsEnabled="{Binding IsMeshOptimizing, Converter={StaticResource InverseBoolean}}" />
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsMeshOptimizing, Converter={StaticResource BooleanToVisibility}}">
                                                <ProgressBar IsIndeterminate="True" Width="80" Height="4" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="Decimating..." FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <ui:Button Grid.Column="1"
                                                       Content="Cancel"
                                                       Appearance="Secondary"
                                                       Padding="10,4"
                                                       FontSize="11"
                                                       Margin="0,0,6,0"
                                                       Tag="{Binding}"
                                                       IsEnabled="{Binding IsMeshOptimizing, Converter={StaticResource InverseBoolean}}"
                                                       Click="OnLayerCancelOptimizeMesh" />
                                            <ui:Button Grid.Column="2"
                                                       Content="Apply"
                                                       Appearance="Primary"
                                                       Padding="10,4"
                                                       FontSize="11"
                                                       Tag="{Binding}"
                                                       IsEnabled="{Binding IsMeshOptimizing, Converter={StaticResource InverseBoolean}}"
                                                       Click="OnLayerConfirmOptimizeMesh" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Photoshop footer strip: new group · add models · count · delete -->
                            <Border Grid.Row="1"
                                    BorderThickness="0,1,0,0"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Padding="8,4"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                <DockPanel LastChildFill="False">
                                    <ui:Button DockPanel.Dock="Left"
                                               Appearance="Transparent"
                                               Width="28" Height="26"
                                               Padding="0"
                                               Click="OnOutlinerNewGroup"
                                               ToolTip="New group — grouped layers export together as one pack.">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="FolderAdd24" FontSize="14" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button DockPanel.Dock="Left"
                                               Appearance="Transparent"
                                               Width="28" Height="26"
                                               Padding="0"
                                               Margin="2,0,0,0"
                                               Click="OnOutlinerAddModels"
                                               ToolTip="Add model(s) — they convert automatically and appear as layers. Drop files on a group to add straight into it.">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Add24" FontSize="14" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button DockPanel.Dock="Right"
                                               Appearance="Transparent"
                                               Width="28" Height="26"
                                               Padding="0"
                                               Click="OnOutlinerDeleteSelected"
                                               ToolTip="Delete selected layers / groups.">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding PackSession.ItemCountDisplay}"
                                               FontSize="10"
                                               Opacity="0.45"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>

                            <!-- Textures pinned to the bottom -->
                            <Border Grid.Row="2"
                                    BorderThickness="0,1,0,0"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Padding="10,10,10,8"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <StackPanel>
                                <TextBlock Text="TEXTURES"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Opacity="0.5"
                                           Margin="0,0,0,4" />
                                <TextBlock FontSize="11"
                                           Opacity="0.5"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"
                                           Text="Base is the original. Add more, then choose embed or one-prop-per-texture below." />

                                <StackPanel Visibility="{Binding ModelTexturesLoading, Converter={StaticResource BooleanToVisibility}}">
                                    <TextBlock Text="Loading…" FontSize="11" Opacity="0.45" Margin="0,0,0,8" />
                                </StackPanel>

                                <TextBlock FontSize="11"
                                           Opacity="0.4"
                                           Margin="0,0,0,8"
                                           Text="No textures yet — load a model."
                                           Visibility="{Binding ShowModelTexturesEmpty, Converter={StaticResource BooleanToVisibility}}" />

                                <ListBox ItemsSource="{Binding ModelTextures}"
                                         SelectedItem="{Binding SelectedTexture, Mode=TwoWay}"
                                         SelectionChanged="OnTextureLibrarySelectionChanged"
                                         Margin="0,0,0,8"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         IsEnabled="{Binding HasModel}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,4" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Row"
                                                                Padding="6,4"
                                                                Background="Transparent"
                                                                BorderThickness="2,0,0,0"
                                                                BorderBrush="Transparent"
                                                                CornerRadius="4"
                                                                Cursor="Hand">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Row" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Row" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                                                <Setter TargetName="Row" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ModelTextureItem}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="40" Height="40"
                                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                        ClipToBounds="True"
                                                        CornerRadius="3">
                                                    <Grid>
                                                        <ui:SymbolIcon Symbol="Image24" FontSize="14" Opacity="0.35"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        <Image Source="{Binding Path, Converter={StaticResource PathToImageSource}, ConverterParameter=76}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="8,0,4,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Detail}" FontSize="10" Opacity="0.5" Margin="0,2,0,0"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <ui:Button Grid.Column="2"
                                                           Appearance="Transparent"
                                                           Padding="2"
                                                           Width="22" Height="22"
                                                           VerticalAlignment="Center"
                                                           Click="OnRemoveLibraryTexture"
                                                           Visibility="{Binding CanRemove, Converter={StaticResource BooleanToVisibility}}"
                                                           ToolTip="Remove">
                                                    <ui:Button.Icon>
                                                        <ui:SymbolIcon Symbol="Dismiss20" FontSize="12" />
                                                    </ui:Button.Icon>
                                                </ui:Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <ui:Button Appearance="Secondary"
                                           Content="Add texture…"
                                           Padding="10,8"
                                           FontSize="12"
                                           HorizontalAlignment="Stretch"
                                           Margin="0,0,0,14"
                                           Click="OnAddTextureExtras"
                                           IsEnabled="{Binding HasModel}"
                                           ToolTip="Add an image. Click a row to preview it on the model.">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ImageAdd24" />
                                    </ui:Button.Icon>
                                </ui:Button>

                                <ui:ToggleSwitch IsChecked="{Binding PackTextureVariants}"
                                                 Content="Different model per texture"
                                                 Margin="0,0,0,4"
                                                 IsEnabled="{Binding HasModel}"
                                                 ToolTip="On: each added texture becomes its own prop in a pack. Off: embed into this one model." />
                                <TextBlock Text="{Binding SimplePrimaryButtonHint}"
                                           FontSize="11"
                                           Opacity="0.5"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

                    <!-- ═══════════════════════════════════════════════════
                         ANIMATED KEYS TIMELINE
                         Scrub / insert / delete rotation keys; convert
                         samples them into the prop .ycd.
                         ═══════════════════════════════════════════════════ -->
                    <Border Grid.Row="2"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            Visibility="{Binding IsAnimatedPropsView, Converter={StaticResource BooleanToVisibility}}">
                        <Grid Margin="12,8,12,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Transport -->
                            <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="True">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:Button Appearance="Transparent"
                                               Padding="8,4"
                                               Margin="0,0,4,0"
                                               Click="OnPropAnimPlayToggle"
                                               ToolTip="Play / pause timeline preview">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon x:Name="PropAnimPlayIcon" Symbol="Play24" FontSize="14" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Appearance="Transparent"
                                               Padding="8,4"
                                               Margin="0,0,4,0"
                                               Click="OnPropAnimStop"
                                               ToolTip="Stop and return playhead to start">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Stop24" FontSize="14" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <Border Width="1" Height="18" Margin="6,0,10,0"
                                            Background="{DynamicResource ControlElevationBorderBrush}" />
                                    <ui:Button Content="Add key"
                                               Appearance="Secondary"
                                               Padding="10,4"
                                               Margin="0,0,6,0"
                                               FontSize="12"
                                               Command="{Binding AddPropAnimKeyCommand}"
                                               ToolTip="Insert a key at the playhead using the current gizmo rotation (K)" />
                                    <ui:Button Content="Delete key"
                                               Appearance="Transparent"
                                               Padding="10,4"
                                               Margin="0,0,6,0"
                                               FontSize="12"
                                               Command="{Binding DeletePropAnimKeyCommand}"
                                               ToolTip="Remove the key nearest the playhead" />
                                    <ui:Button Content="Reset"
                                               Appearance="Transparent"
                                               Padding="10,4"
                                               FontSize="12"
                                               Command="{Binding ClearPropAnimKeysCommand}"
                                               ToolTip="Reset to a default 0→360° spin on the current axis" />
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="Duration" Opacity="0.65" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <ui:NumberBox Value="{Binding PropAnimDuration, Mode=TwoWay}"
                                                  Minimum="0.2" Maximum="120" SmallChange="0.5"
                                                  Width="72" FontSize="12"
                                                  ToolTip="Timeline length in seconds" />
                                </StackPanel>
                                <TextBlock Text="{Binding PropAnimPlayheadLabel}"
                                           FontSize="11"
                                           Opacity="0.75"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas" />
                            </DockPanel>

                            <!-- Ruler + key lane -->
                            <Border Grid.Row="1"
                                    CornerRadius="4"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Background="#FF1A1A1A"
                                    ClipToBounds="True">
                                <Canvas x:Name="PropAnimTimelineCanvas"
                                        Background="Transparent"
                                        MouseLeftButtonDown="OnPropAnimTimelineDown"
                                        MouseMove="OnPropAnimTimelineMove"
                                        MouseLeftButtonUp="OnPropAnimTimelineUp"
                                        MouseLeave="OnPropAnimTimelineUp"
                                        SizeChanged="OnPropAnimTimelineSizeChanged">
                                    <ctrl:TimelineRenderLayer x:Name="PropAnimTimelineLayer"
                                                              Width="{Binding ActualWidth, ElementName=PropAnimTimelineCanvas}"
                                                              Height="{Binding ActualHeight, ElementName=PropAnimTimelineCanvas}" />
                                </Canvas>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ═══════════════════════════════════════════════════
                         FOOTER: prop name + convert action
                         Temporarily hidden — use Ctrl+Enter / File → Convert;
                         status + P/R/S stay on the window bottom strip.
                         ═══════════════════════════════════════════════════ -->
                    <Border Grid.Row="3"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            Padding="16,10"
                            ClipToBounds="True"
                            Visibility="Collapsed">
                        <DockPanel LastChildFill="True">
                            <!-- Pack + Convert stay fully visible on the right. -->
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Bottom"
                                        Margin="12,0,0,0">
                                    <ToggleButton x:Name="PackModeToggle"
                                                  IsChecked="{Binding IsPackMode, Mode=TwoWay}"
                                                  Padding="12,10"
                                                  Margin="0,0,8,0"
                                                  FontSize="13"
                                                  FontWeight="SemiBold"
                                                  Visibility="{Binding IsPropMode, Converter={StaticResource BooleanToVisibility}}"
                                                  ToolTip="Pack mode — convert several props in a row and finalise them into a single FiveM resource.">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="BoxMultiple24" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                            <TextBlock Text="Pack" VerticalAlignment="Center" />
                                            <Border Margin="8,0,0,0"
                                                    Padding="6,1"
                                                    CornerRadius="6"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                    Visibility="{Binding PackSession.HasEntries, Converter={StaticResource BooleanToVisibility}}">
                                                <TextBlock Text="{Binding PackSession.Count, FallbackValue=0}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </ToggleButton>

                                    <Grid>
                                        <ui:Button x:Name="ConvertButton"
                                                   Content="{Binding SimplePrimaryButtonLabel}"
                                                   Appearance="Primary"
                                                   Padding="18,10"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   IsEnabled="{Binding CanConvert}"
                                                   Click="OnSimplePrimaryAction"
                                                   ToolTip="Ctrl+Enter"
                                                   Visibility="{Binding IsConverting, Converter={StaticResource InverseBooleanToVisibility}}">
                                            <ui:Button.Icon>
                                                <ui:SymbolIcon Symbol="ArrowRight24" />
                                            </ui:Button.Icon>
                                        </ui:Button>
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsConverting, Converter={StaticResource BooleanToVisibility}}">
                                            <ProgressBar IsIndeterminate="True" Width="140" Height="4" Margin="0,0,12,0" VerticalAlignment="Center" />
                                            <TextBlock Text="Converting..." VerticalAlignment="Center" FontSize="13" />
                                            <ui:Button Content="Cancel"
                                                       Appearance="Danger"
                                                       Margin="12,0,0,0"
                                                       Padding="14,6"
                                                       VerticalAlignment="Center"
                                                       Click="OnCancelConvert"
                                                       ToolTip="Stop the conversion and terminate the engine process." />
                                        </StackPanel>
                                    </Grid>
                            </StackPanel>

                            <StackPanel VerticalAlignment="Bottom" MinWidth="120">
                                <TextBlock Text="Prop name"
                                           FontSize="11"
                                           Opacity="0.7"
                                           Margin="0,0,0,4" />
                                <ui:TextBox Text="{Binding PropName, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="auto from filename"
                                            MaxLength="64"
                                            FontFamily="Consolas"
                                            ToolTip="The asset name that becomes scene.ydr / scene.ybn / scene.ytyp on export. This is also the model hash used by CreateObject in scripts and by archetype lookups in .ymap entities. Lowercase, no spaces, no special chars (the export sanitises automatically). Defaults to the source filename." />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════════
                         SUCCESS overlay (covers tab content when
                         ShowSuccessScreen). Lives inside the tab so it
                         doesn't block the other two tabs.
                         ═══════════════════════════════════════════════════ -->
                    <Border Grid.Row="0" Grid.RowSpan="3"
                            Background="{DynamicResource ApplicationBackgroundBrush}"
                            Visibility="{Binding ShowSuccessScreen, Converter={StaticResource BooleanToVisibility}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
                            <Border Width="96" Height="96"
                                    CornerRadius="48"
                                    Background="#1B4CAF50"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,16">
                                <TextBlock Text="✓"
                                           FontSize="64"
                                           FontWeight="Light"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#4CAF50" />
                            </Border>
                            <TextBlock Text="Done. Your prop is ready."
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16" />
                            <TextBlock Text="Saved to:"
                                       FontSize="12"
                                       Opacity="0.7"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding ResultZipPath}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,24" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:Button Content="Open folder"
                                           Appearance="Primary"
                                           Margin="0,0,8,0"
                                           Padding="20,8"
                                           Click="OnOpenFolder"
                                           ToolTip="Open the output folder in Windows Explorer — your resource is ready to copy into a FiveM server's resources/ folder.">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="FolderOpen24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Content="How to install"
                                           Appearance="Secondary"
                                           Margin="0,0,8,0"
                                           Padding="20,8"
                                           Click="OnHelpInstall"
                                           ToolTip="Walkthrough of how to drop this resource into a FiveM server, add it to server.cfg, and place the prop via CodeWalker." />
                                <ui:Button Content="Back to model"
                                           Appearance="Secondary"
                                           Margin="0,0,8,0"
                                           Padding="20,8"
                                           Click="OnBackToModel"
                                           ToolTip="Return to your loaded model to tweak it (layers, transform, materials) and export again — keeps everything exactly as it was.">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ArrowLeft24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Content="Convert another"
                                           Appearance="Secondary"
                                           Padding="20,8"
                                           Click="OnConvertAnother"
                                           ToolTip="Clear the current model and start fresh with a new one — keeps the current settings as defaults." />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
                </Grid>

                <!-- ════ OPTIMIZE VIEW (hosts the txAdmin Optimizer as a mode
                     card — see OptimizeView.xaml) ════ -->
                <Grid Visibility="{Binding IsOptimizeView, Converter={StaticResource BooleanToVisibility}}">
                    <ContentControl Content="{Binding OptimizeVm}" />
                </Grid>

                <!-- ════ MODS → RPF VIEW ════ -->
                <Grid Visibility="{Binding IsRpfView, Converter={StaticResource BooleanToVisibility}}">
                    <ContentControl Content="{Binding RpfVm}" />
                </Grid>

                <Grid Visibility="{Binding IsVehiclesView, Converter={StaticResource BooleanToVisibility}}">
                    <ContentControl x:Name="VehiclesHost" Content="{Binding VehiclesVm}" />
                </Grid>

                <!-- (Image → 3D was its own view; it's now folded into the
                     3D → Prop source picker as the "AI" tab — opens
                     AiGeneratorWindow on demand and the generated .glb
                     auto-loads into the viewer.) -->

                <!-- ════ EMOTES VIEW ════
                     One unified workspace (the former Pose → Emote), which
                     also absorbs animation import: the Library's "Import
                     Animation" button retargets a .glb/.fbx clip onto the
                     GTA skeleton and lands it on the timeline. Owns its own
                     WebView2 with lazy init keyed off visibility, so the
                     ~40 MB Edge process doesn't spin up until first shown. -->
                <Grid Visibility="{Binding IsEmotesView, Converter={StaticResource BooleanToVisibility}}">
                    <local:PoseToEmoteView x:Name="EmotesWorkspace" />
                </Grid>

                <!-- ════ PLUGIN HOST ════
                     Renders the active third-party plugin's view. Mutually
                     exclusive with the built-in views — IsPluginActive
                     forces every IsXView flag false above so this Grid
                     ends up alone on top. -->
                <Grid Visibility="{Binding IsPluginActive, Converter={StaticResource BooleanToVisibility}}">
                    <ContentControl Content="{Binding ActivePluginView}" />
                </Grid>

                </Grid>
                <!-- /view-swap container -->

                </Grid>
                <!-- /workspace views (hidden while Settings open) -->

                <!-- Settings pane — fills the content column; rail stays visible. -->
                <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                        Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibility}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                Padding="20,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:Button Grid.Column="0"
                                           Click="OnSettingsClose"
                                           Appearance="Transparent"
                                           Width="32" Height="32"
                                           Padding="0"
                                           Margin="0,0,12,0"
                                           ToolTip="Back (Esc)">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="16" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <TextBlock Grid.Column="1"
                                           Text="Settings"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- SettingsView is created lazily on first open in code-behind
                             (EnsureSettingsPage). Materialising it eagerly here would
                             fire SettingsView.Loaded at app startup, which kicks off a
                             cache-size scan and slows the splash. -->
                        <ContentControl Grid.Row="1" x:Name="SettingsHost" />
                    </Grid>
                </Border>
        </Grid>

        <!-- ───────── C4D-style Coordinate Manager strip ─────────
             Shared across tabs. Left side: status text from the active
             workflow. Right side: live readout of the loaded model's
             position / rotation / scale — same bindings the TRANSFORM
             sidebar uses, mirrored down here in the same one-row layout
             Cinema 4D's Coordinate Manager ships with. Hidden when no
             model is loaded so the strip stays a simple status bar. -->
        <Border Grid.Row="4"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           FontSize="12"
                           Opacity="0.85"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <!-- (Update badge moved to the title bar's top-right corner.) -->

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasModel, Converter={StaticResource BooleanToVisibility}}">
                    <!-- Position -->
                    <TextBlock Text="P"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Opacity="0.55"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="X" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformPosX, StringFormat={}{0:0.000}}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Y" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformPosY, StringFormat={}{0:0.000}}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Z" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformPosZ, StringFormat={}{0:0.000}}" />

                    <Border Style="{StaticResource C4DPaletteSeparator}" Margin="12,2" />

                    <!-- Rotation (degrees) -->
                    <TextBlock Text="R"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Opacity="0.55"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="X" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               MinWidth="48"
                               Text="{Binding TransformRotX, StringFormat={}{0:0.0}°}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Y" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               MinWidth="48"
                               Text="{Binding TransformRotY, StringFormat={}{0:0.0}°}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Z" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               MinWidth="48"
                               Text="{Binding TransformRotZ, StringFormat={}{0:0.0}°}" />

                    <Border Style="{StaticResource C4DPaletteSeparator}" Margin="12,2" />

                    <!-- Per-axis scale -->
                    <TextBlock Text="S"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Opacity="0.55"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="X" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformScaleX, StringFormat={}{0:0.000}}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Y" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformScaleY, StringFormat={}{0:0.000}}" />
                    <TextBlock Style="{StaticResource C4DCoordLabel}" Text="Z" />
                    <TextBlock Style="{StaticResource C4DCoordValue}"
                               Text="{Binding TransformScaleZ, StringFormat={}{0:0.000}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
