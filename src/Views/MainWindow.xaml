<ui:FluentWindow x:Class="FiveOS.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:FiveOS.ViewModels"
                 xmlns:local="clr-namespace:FiveOS.Views"
                 xmlns:ctrl="clr-namespace:FiveOS.Views.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 xmlns:loc="clr-namespace:FiveOS.Markup"
                 xmlns:svc="clr-namespace:FiveOS.Services"
                 xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                 mc:Ignorable="d"
                 Title="FiveOS"
                 Icon="pack://application:,,,/Assets/Branding/FiveOS.ico"
                 Height="940" Width="1520"
                 MinHeight="480" MinWidth="720"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen"
                 WindowState="Maximized"
                 AllowDrop="True"
                 Drop="OnFileDropped"
                 DragOver="OnDragOver"
                 PreviewDrop="OnFileDropped"
                 PreviewDragOver="OnDragOver"
                 PreviewKeyDown="OnWindowKeyDown"
                 d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.InputBindings>
        <!-- Undo/redo shortcuts. Ctrl+Y is the Windows-standard redo;
             Ctrl+Shift+Z is also accepted for muscle-memory parity with
             Mac / Adobe / VS Code. -->
        <KeyBinding Key="Z" Modifiers="Control"
                    Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control"
                    Command="{Binding RedoCommand}" />
        <KeyBinding Key="Z" Modifiers="Control+Shift"
                    Command="{Binding RedoCommand}" />
        <KeyBinding Key="R" Modifiers="Control"
                    Command="{Binding ToggleReferencePedCommand}" />
        <KeyBinding Key="L" Modifiers="Control"
                    Command="{Binding ToggleLayersPanelCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <!-- Tiny "section header" for sidebar: small caps, dimmed, letter-spaced. -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="Margin" Value="16,18,16,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>

        <!-- Inline label above a control. -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- Stat card row used in the GEOMETRY section. -->
        <Style x:Key="StatRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <!-- ─── Skeleton loading ───
             A horizontal-shimmer placeholder for content that's loading.
             x:Shared="False" forces a fresh brush per consumer so each
             skeleton's animation runs independently (animations require
             unfrozen brushes; without x:Shared the brush is reused and
             only the first instance animates). -->
        <LinearGradientBrush x:Key="SkeletonShimmerBrush"
                             x:Shared="False"
                             StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#15FFFFFF" Offset="0.0" />
            <GradientStop Color="#3AFFFFFF" Offset="0.5" />
            <GradientStop Color="#15FFFFFF" Offset="1.0" />
            <LinearGradientBrush.Transform>
                <TranslateTransform X="-1" />
            </LinearGradientBrush.Transform>
        </LinearGradientBrush>

        <Style x:Key="Skeleton" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{StaticResource SkeletonShimmerBrush}" />
            <Setter Property="MinHeight" Value="14" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation
                                Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.Transform).(TranslateTransform.X)"
                                From="-1" To="2"
                                Duration="0:0:1.4" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- ─── Underlined horizontal tab look ───
             A flat tab header (no pill / no panel border) with a 2-px
             accent underline that animates in on hover and stays solid
             when selected. Used by both the top-level TabControl and the
             sidebar File/Sketchfab TabControl so they look uniform. -->
        <Style x:Key="UnderlineTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="2" />
                            </Grid.RowDefinitions>
                            <ContentPresenter Grid.Row="0"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                            <Border Grid.Row="1"
                                    x:Name="Underline"
                                    Background="{DynamicResource SystemAccentColorBrush}"
                                    Opacity="0"
                                    HorizontalAlignment="Stretch"
                                    SnapsToDevicePixels="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Order matters: IsMouseOver runs first so
                                 IsSelected wins when both are true. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Reorderable variant: same look as UnderlineTabItem but injects
             a vertical-dots "grip" handle in front of the header text when
             the parent window's IsTabEditMode is true. Used by the top-level
             tab strip; the inner File/Sketchfab strip keeps the plain style. -->
        <Style x:Key="ReorderableUnderlineTabItem" TargetType="TabItem"
               BasedOn="{StaticResource UnderlineTabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="2" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}">
                                <!-- Grip dots: ⠿ (Braille pattern dots-12345678).
                                     Hidden until edit mode flips on. -->
                                <TextBlock x:Name="Grip"
                                           Text="⠿"
                                           FontSize="14"
                                           Margin="0,0,6,0"
                                           Opacity="0.55"
                                           Visibility="Collapsed"
                                           VerticalAlignment="Center" />
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  TextElement.FontSize="{TemplateBinding FontSize}"
                                                  TextElement.FontWeight="{TemplateBinding FontWeight}" />
                            </StackPanel>
                            <Border Grid.Row="1"
                                    x:Name="Underline"
                                    Background="{DynamicResource SystemAccentColorBrush}"
                                    Opacity="0"
                                    HorizontalAlignment="Stretch"
                                    SnapsToDevicePixels="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsTabEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter TargetName="Grip" Property="Visibility" Value="Visible" />
                                <Setter Property="Cursor" Value="SizeAll" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UnderlineTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource UnderlineTabItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- Header strip with a hairline divider so the
                                 underline sits directly on top of it. -->
                            <Border Grid.Row="0"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                                <TabPanel x:Name="HeaderPanel"
                                          IsItemsHost="True"
                                          Background="Transparent"
                                          KeyboardNavigation.TabIndex="1" />
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="{TemplateBinding Padding}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Activity-rail ListBoxItem ───
             Win11-style nav pill: rounded background, accent left bar
             when selected, hover/selected colors that match the rest
             of the app. Icon + label live inside the item template
             (in the XAML below) — keeping that structure means the
             SymbolIcon's font inheritance isn't broken by a Button
             content presenter wrapping it. -->
        <!-- Plain Border-based rail item (replaces the ListBoxItem template
             so wpf-ui's theme can't slip in a sharp left-edge accent). The
             owning Border supplies its own selected-state DataTrigger
             inline. -->
        <!-- C4D-style left palette button: square, flat, 2-px bottom accent
             when selected. The corner-radius is intentionally 2 px so the
             icons line up edge-to-edge like Cinema 4D's tool palette. -->
        <Style x:Key="RailItem" TargetType="Border">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="6,2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LayoutTab" TargetType="Border">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,1,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LayoutTabLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="FontStyle" Value="Normal" />
        </Style>

        <!-- C4D-style top command-palette button. Tiny flat icon, 2-px
             radius, ghost background, blue-ish hover. The whole bar reads
             as a strip of icons separated by tone — exactly how C4D's
             command palette renders above its viewport. -->
        <Style x:Key="C4DPaletteButton" TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- 1-px vertical separator used between command-palette groups. -->
        <Style x:Key="C4DPaletteSeparator" TargetType="Border">
            <Setter Property="Width" Value="1" />
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="Background" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <!-- C4D-style coordinate field: tiny axis label + read-only numeric
             box, monospace. Used in the bottom Coordinate Manager strip. -->
        <Style x:Key="C4DCoordLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,4,0" />
        </Style>
        <Style x:Key="C4DCoordValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>

        <!-- Legacy RailButton (kept for any leftover callers; new rail uses RailListItem). -->
        <Style x:Key="RailButton" TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ───────── Title bar ───────── -->
        <Grid Grid.Row="0"
              Background="{DynamicResource ApplicationBackgroundBrush}"
              MinHeight="40">
            <!-- Caption buttons / drag region. Title + logo drawn as an
                 overlay so we can size the mark like C4D (TitleBar.Icon
                 is clamped too small). -->
            <ui:TitleBar Title=""
                         ShowMaximize="True"
                         ShowMinimize="True"
                         ShowClose="True" />

            <!-- C4D-style: larger logo + "App vX - [document] - Main".
                 Logo / title click returns to the dashboard (GoHome). -->
            <Button HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    Padding="4,2"
                    Panel.ZIndex="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Command="{Binding GoHomeCommand}"
                    ToolTip="Home — dashboard"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/Assets/Branding/FiveOS.png"
                           Width="28" Height="28"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center" />
                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}"
                               Margin="10,0,0,0"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </StackPanel>
            </Button>

            <!-- Update badge — sits left of caption buttons (~138px). -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,138,0"
                        Panel.ZIndex="2"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <ui:Button x:Name="UpdateBadgeButton"
                           Margin="0,0,10,0"
                           Padding="10,2"
                           FontSize="11"
                           Appearance="Info"
                           Click="OnUpdateBadgeClick"
                           ToolTip="A newer FiveOS is available — click to see what's new and install it."
                           Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibility}}"
                           Content="{Binding UpdateBadgeLabel}">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="ArrowDownload24" />
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="#FF1A1A1A"
                BorderThickness="0,0,0,1"
                BorderBrush="#FF363636">
            <DockPanel Height="32" LastChildFill="True">
                <!-- Undo / Redo — C4D-style icon pair left of the document tabs.
                     Universal: routes to Assets form history or Emotes pose/timeline. -->
                <Border DockPanel.Dock="Left"
                        Margin="6,3,6,3"
                        VerticalAlignment="Center"
                        BorderBrush="#FF4D4D4D"
                        BorderThickness="1"
                        CornerRadius="3"
                        Background="#FF262626">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="28" Height="24"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                Cursor="Hand"
                                Command="{Binding UndoCommand}"
                                ToolTip="Undo (Ctrl+Z)"
                                Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="2,0,0,2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#FF3D3D3D" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.35" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <ui:SymbolIcon Symbol="ArrowUndo24" FontSize="13"
                                           Foreground="#FFBFBFBF" />
                        </Button>
                        <Rectangle Width="1" Fill="#FF4D4D4D" Margin="0,3" />
                        <Button Width="28" Height="24"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                Cursor="Hand"
                                Command="{Binding RedoCommand}"
                                ToolTip="Redo (Ctrl+Y)"
                                Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="0,2,2,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#FF3D3D3D" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.35" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <ui:SymbolIcon Symbol="ArrowRedo24" FontSize="13"
                                           Foreground="#FFBFBFBF" />
                        </Button>
                    </StackPanel>
                </Border>

                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Padding="2,0,8,0">
                    <!-- Tabs + "+" share one row so the plus stays glued to
                         the last tab (C4D), not pinned to the window edge. -->
                    <StackPanel Orientation="Horizontal">
                        <ItemsControl ItemsSource="{Binding WorkspaceDocs.Documents}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:WorkspaceDocument}">
                                    <Border MinWidth="88" MaxWidth="200" Height="28"
                                            Margin="0,4,2,0"
                                            CornerRadius="3,3,0,0"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="OnWorkspaceTabClick"
                                            ToolTip="{Binding DisplayTitle}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0,0,0,2" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource StringEquals}">
                                                                <Binding Path="DataContext.WorkspaceDocs.ActiveDocumentId"
                                                                         RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                <Binding Path="Id" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="#FF2B2B2B" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF333333" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <DockPanel Margin="10,0,4,0">
                                            <ui:Button DockPanel.Dock="Right"
                                                       Appearance="Transparent"
                                                       Width="22" Height="22"
                                                       Padding="0"
                                                       VerticalAlignment="Center"
                                                       Click="OnWorkspaceCloseTab"
                                                       ToolTip="Close tab — unsaved work will be lost">
                                                <ui:Button.Icon>
                                                    <ui:SymbolIcon Symbol="Dismiss16" FontSize="10" Opacity="0.7" />
                                                </ui:Button.Icon>
                                            </ui:Button>
                                            <TextBlock Text="{Binding DisplayTitle}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ui:Button Appearance="Transparent"
                                   Width="28" Height="26"
                                   Padding="0"
                                   Margin="2,3,4,0"
                                   VerticalAlignment="Center"
                                   Click="OnWorkspaceNewTab"
                                   ToolTip="New tab">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Add24" FontSize="14" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="6,0,8,0"
                MinHeight="28">
            <Grid>
                <Menu Background="Transparent"
                      HorizontalAlignment="Left"
                      FontSize="12"
                      Padding="0"
                      VerticalAlignment="Center">
                    <!-- ── File ── -->
                    <MenuItem Header="{loc:Loc Menu.File}"
                              Style="{StaticResource C4DTopLevelMuted}">
                        <MenuItem Header="Dashboard"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Command="{Binding GoHomeCommand}"
                                  ToolTip="Back to the home tile screen">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Home24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Welcome screen"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnShowWelcome"
                                  ToolTip="Recent files and quick launcher">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Sparkle24" FontSize="14" />
