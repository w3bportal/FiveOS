                                <ui:SymbolIcon Symbol="DocumentMultiple24" FontSize="14" Foreground="#FFE0C070" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="EXPORT"
                                  Style="{StaticResource C4DMenuSectionHeader}"
                                  Visibility="{Binding Is3DView, Converter={StaticResource BooleanToVisibility}}" />
                        <MenuItem Header="Convert…"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnConvert"
                                  Visibility="{Binding Is3DView, Converter={StaticResource BooleanToVisibility}}"
                                  IsEnabled="{Binding CanConvert}"
                                  ToolTip="Export the loaded prop">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="ArrowExportUp24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Clear Model"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnClearSource"
                                  Visibility="{Binding Is3DView, Converter={StaticResource BooleanToVisibility}}"
                                  ToolTip="Unload the current model">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <!-- Optimize -->
                        <MenuItem Header="ADD"
                                  Style="{StaticResource C4DMenuSectionHeader}"
                                  Visibility="{Binding IsOptimizeView, Converter={StaticResource BooleanToVisibility}}" />
                        <MenuItem Header="Add Files…"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnMenuOptimizeAddFiles"
                                  Visibility="{Binding IsOptimizeView, Converter={StaticResource BooleanToVisibility}}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="DocumentAdd24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Add Folder…"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnMenuOptimizeAddFolder"
                                  Visibility="{Binding IsOptimizeView, Converter={StaticResource BooleanToVisibility}}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="FolderAdd24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <!-- Vehicles -->
                        <MenuItem Header="BROWSE"
                                  Style="{StaticResource C4DMenuSectionHeader}"
                                  Visibility="{Binding IsVehiclesView, Converter={StaticResource BooleanToVisibility}}" />
                        <MenuItem Header="Browse…"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnMenuVehiclesBrowse"
                                  Visibility="{Binding IsVehiclesView, Converter={StaticResource BooleanToVisibility}}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Output…"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnMenuVehiclesBrowseOutput"
                                  Visibility="{Binding IsVehiclesView, Converter={StaticResource BooleanToVisibility}}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Folder24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <!-- RPF -->
                        <MenuItem Header="CONVERT"
                                  Style="{StaticResource C4DMenuSectionHeader}"
                                  Visibility="{Binding IsRpfView, Converter={StaticResource BooleanToVisibility}}" />
                        <MenuItem Header="Browse Input…"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnMenuRpfBrowseInput"
                                  Visibility="{Binding IsRpfView, Converter={StaticResource BooleanToVisibility}}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Browse Output…"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnMenuRpfBrowseOutput"
                                  Visibility="{Binding IsRpfView, Converter={StaticResource BooleanToVisibility}}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Folder24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Convert"
                                  Style="{StaticResource C4DMenuCommand}"
                                  Click="OnMenuRpfConvert"
                                  Visibility="{Binding IsRpfView, Converter={StaticResource BooleanToVisibility}}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="ArrowSync24" FontSize="14" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <!-- Emotes -->
                        <MenuItem Header="OPEN"
                                  Style="{StaticResource C4DMenuSectionHeader}"
                                  Visibility="{Binding IsEmotesView, Converter={StaticResource BooleanToVisibility}}" />
                        <MenuItem Header="Open Rig…"
                                  Style="{StaticResource C4DMenuCommandNew}"
