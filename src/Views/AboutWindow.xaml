<ui:FluentWindow x:Class="FiveOS.Views.AboutWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="About FiveOS"
                 Height="540" Width="600"
                 MinHeight="420" MinWidth="480"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True">

    <Window.Resources>

        <Style x:Key="UnderlineTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="2" />
                            </Grid.RowDefinitions>
                            <ContentPresenter Grid.Row="0"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                            <Border Grid.Row="1"
                                    x:Name="Underline"
                                    Background="{DynamicResource SystemAccentColorBrush}"
                                    Opacity="0"
                                    HorizontalAlignment="Stretch"
                                    SnapsToDevicePixels="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UnderlineTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource UnderlineTabItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                                <TabPanel x:Name="HeaderPanel"
                                          IsItemsHost="True"
                                          Background="Transparent" />
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="About FiveOS"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <TabControl Grid.Row="1"
                    Style="{StaticResource UnderlineTabControl}"
                    Margin="20,0,20,0">

            <TabItem Header="About" FontSize="13" Padding="14,8">
                <StackPanel Margin="0,28,0,0"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/Branding/FiveOS.png"
                           Width="64" Height="64"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />
                    <TextBlock Text="FiveOS"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="VersionText"
                               Text="v0.0.0"
                               FontSize="13"
                               Opacity="0.7"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,8" />

                    <Button x:Name="CheckUpdateButton"
                            Content="Check for updates"
                            Click="OnCheckForUpdates"
                            HorizontalAlignment="Center"
                            Padding="14,5"
                            FontSize="12" />
                    <TextBlock x:Name="UpdateStatusText"
                               Text=""
                               FontSize="11"
                               Opacity="0.6"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,6,0,16" />

                    <TextBlock Text="All in One FiveM Modding Tool."
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />

                    <ui:Button x:Name="DonateButton"
                               Content="♥  Support FiveOS"
                               Appearance="Primary"
                               HorizontalAlignment="Center"
                               Padding="20,7"
                               FontSize="12"
                               Margin="0,0,0,4"
                               Click="OnDonate"
                               ToolTip="FiveOS is free. If it saves you time, chip in via PayPal — totally optional." />
                    <TextBlock Text="Free to use — © 2026 FiveOS. Donations are optional and appreciated."
                               FontSize="10.5" Opacity="0.55"
                               HorizontalAlignment="Center" Margin="0,0,0,16" />
                    <TextBlock x:Name="AuthorText"
                               Text="By: FiveOS"
                               FontSize="12"
                               Opacity="0.85"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,4,0,0"
                               HorizontalAlignment="Center">
                        <Hyperlink x:Name="WebLink" Click="OnWebLink">
                            <Run x:Name="WebLinkText" Text="https://github.com/w3bportal/FiveOS" />
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0"
                               HorizontalAlignment="Center">
                        <Hyperlink x:Name="DiscordLink" Click="OnDiscordLink">
                            <Run x:Name="DiscordLinkText" Text="Discord community" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </TabItem>

            <TabItem Header="Credits" FontSize="13" Padding="14,8">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock x:Name="CreditsIntroText"
                                   FontSize="12"
                                   Opacity="0.75"
                                   TextWrapping="Wrap" />
                        <Grid Margin="0,6,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       x:Name="CreditsStatusText"
                                       FontSize="11"
                                       Opacity="0.55"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Text="Loading…" />
                            <ui:Button Grid.Column="1"
                                       Content="Refresh"
                                       Appearance="Secondary"
                                       Padding="14,4"
                                       FontSize="11"
                                       Click="OnRefreshCredits"
                                       ToolTip="Re-fetch the credits list from the FiveOS server. Useful if you contributed and want to verify your name shows up." />
                        </Grid>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="CreditsHost" />
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <ui:Button Grid.Row="2"
                   Content="Close"
                   Appearance="Primary"
                   HorizontalAlignment="Center"
                   Padding="32,8"
                   Margin="0,12,0,16"
                   Click="OnOk" />
    </Grid>
</ui:FluentWindow>
