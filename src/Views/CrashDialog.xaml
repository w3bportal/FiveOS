<ui:FluentWindow x:Class="FiveOS.Views.CrashDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:FiveOS.Markup"
                 Title="{loc:Loc Crash.Title}"
                 Height="540" Width="640"
                 MinHeight="360" MinWidth="500"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{loc:Loc Crash.Title}"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <!-- Header: error icon + headline + summary -->
        <Grid Grid.Row="1" Margin="20,4,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="44" Height="44"
                    CornerRadius="22"
                    VerticalAlignment="Top"
                    Margin="0,2,14,0"
                    Background="#33D13438"
                    BorderThickness="1"
                    BorderBrush="#55D13438">
                <ui:SymbolIcon Symbol="ErrorCircle24"
                               FontSize="24"
                               Foreground="#FFD13438"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <TextBlock x:Name="HeadlineText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="SummaryText"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Opacity="0.8"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <!-- Log area -->
        <Border Grid.Row="2"
                Margin="20,0,20,12"
                CornerRadius="6"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="12,6"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{loc:Loc Crash.LogHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Opacity="0.75"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   x:Name="LogStatsText"
                                   FontSize="10"
                                   FontFamily="Consolas"
                                   Opacity="0.55"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              x:Name="LogScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Padding="12,8">
                    <TextBox x:Name="LogTextBox"
                             IsReadOnly="True"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="11"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Action row -->
        <Grid Grid.Row="3" Margin="20,0,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0"
                       x:Name="CopyButton"
                       Appearance="Secondary"
                       Padding="14,6"
                       Margin="0,0,8,0"
                       Click="OnCopy"
                       ToolTip="Copy the full crash log to clipboard so you can paste it into a Discord report or GitHub issue.">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Copy24" FontSize="14" Margin="0,0,6,0" />
                    <TextBlock x:Name="CopyButtonText" Text="{loc:Loc Crash.CopyLog}" />
                </StackPanel>
            </ui:Button>

            <ui:Button Grid.Column="1"
                       x:Name="SaveButton"
                       Appearance="Secondary"
                       Padding="14,6"
                       Click="OnSave"
                       ToolTip="Save the crash log to a .txt file on disk. Attach this file when reporting the bug — it has the full call stack and FiveOS state at crash time.">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Save24" FontSize="14" Margin="0,0,6,0" />
                    <TextBlock Text="{loc:Loc Crash.SaveLog}" />
                </StackPanel>
            </ui:Button>

            <ui:Button Grid.Column="3"
                       Content="{loc:Loc Crash.Close}"
                       Appearance="Primary"
                       Padding="22,6"
                       Click="OnClose" />
        </Grid>
    </Grid>
</ui:FluentWindow>
