<ui:FluentWindow x:Class="FiveOS.Views.ExportPackDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Export pack"
                 Width="420"
                 SizeToContent="Height"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Export pack" ShowMaximize="False" ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="16,4,16,0">
            <TextBlock Text="Pack name" FontSize="12" Opacity="0.8" Margin="0,0,0,6" />
            <ui:TextBox x:Name="NameBox" FontFamily="Consolas" FontSize="13" />
            <TextBlock x:Name="CountText"
                       Text=""
                       FontSize="11"
                       Opacity="0.55"
                       Margin="0,6,0,0" />

            <TextBlock Text="Pack type" FontSize="12" Opacity="0.8" Margin="0,14,0,6" />
            <RadioButton x:Name="TypeRegular"
                         GroupName="PackType"
                         IsChecked="True"
                         Margin="0,0,0,2">
                <StackPanel Margin="4,0,0,0">
                    <TextBlock Text="Regular prop pack" FontSize="12.5" />
                    <TextBlock Text="Spawnable props only — stream files + fxmanifest."
                               FontSize="11" Opacity="0.55" TextWrapping="Wrap" />
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="TypeFurniture"
                         GroupName="PackType"
                         Margin="0,6,0,0">
                <StackPanel Margin="4,0,0,0">
                    <TextBlock Text="Furniture pack (nolag_properties)" FontSize="12.5" />
                    <TextBlock Text="Also writes the nolag_properties furniture catalog — per-prop label, category and price come from each layer."
                               FontSize="11" Opacity="0.55" TextWrapping="Wrap" />
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,12,12">
            <ui:Button Content="Cancel" Appearance="Secondary" Padding="16,5" Margin="0,0,8,0" Click="OnCancel" />
            <ui:Button Content="Export" Appearance="Primary" Padding="16,5" Click="OnExport" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
