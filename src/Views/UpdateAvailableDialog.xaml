<ui:FluentWindow x:Class="FiveOS.Views.UpdateAvailableDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Update available"
                 Width="500"
                 SizeToContent="Height"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Update available"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="20,12,20,0" Orientation="Horizontal">
            <ui:SymbolIcon Symbol="ArrowDownload24"
                           FontSize="30"
                           Margin="0,2,14,0"
                           VerticalAlignment="Top"
                           Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
            <StackPanel>
                <TextBlock x:Name="HeadlineText"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Text="FiveOS 0.0.0 is available" />
                <TextBlock x:Name="CurrentText"
                           FontSize="12"
                           Opacity="0.7"
                           Margin="0,4,0,0"
                           Text="You're running v0.0.0. FiveOS restarts automatically after updating." />
            </StackPanel>
        </StackPanel>

        <Border x:Name="InfoPanel"
                Grid.Row="2"
                Visibility="Collapsed"
                Margin="20,14,20,0"
                Padding="14,10"
                CornerRadius="6"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <StackPanel>
                <TextBlock x:Name="NotesText"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Opacity="0.9"
                           Text="" />
                <ui:HyperlinkButton x:Name="ReleasePageLink"
                                    Margin="-8,6,0,0"
                                    FontSize="12"
                                    Content="View release page"
                                    Click="OnReleasePage" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" Margin="16,18,16,16">
            <ui:Button x:Name="ShowInfoButton"
                       HorizontalAlignment="Left"
                       Appearance="Secondary"
                       Padding="16,6"
                       Content="Show Info"
                       Click="OnShowInfo"
                       ToolTip="See what changed in this release." />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="SkipButton"
                           Appearance="Secondary"
                           Padding="16,6"
                           Margin="0,0,10,0"
                           Content="Skip"
                           Click="OnSkip"
                           ToolTip="Don't ask again for this version. The update badge stays in the corner if you change your mind." />
                <ui:Button x:Name="UpdateButton"
                           Appearance="Primary"
                           Padding="20,6"
                           Content="Update"
                           Click="OnUpdate"
                           ToolTip="Download and install now — FiveOS restarts automatically." />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
