<ui:FluentWindow x:Class="FiveOS.Views.SketchfabUrlDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Import from Sketchfab"
                 Height="420" Width="520"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Import from Sketchfab"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="20,8,20,0">
            <TextBlock Text="Paste a Sketchfab model URL. The model must be marked downloadable on Sketchfab."
                       TextWrapping="Wrap"
                       Opacity="0.85"
                       FontSize="12"
                       Margin="0,0,0,12" />

            <TextBlock Text="Sketchfab URL" FontSize="11" Opacity="0.7" Margin="0,0,0,4" />
            <ui:TextBox x:Name="UrlBox"
                        PlaceholderText="https://sketchfab.com/3d-models/..."
                        FontFamily="Consolas"
                        FontSize="12"
                        ToolTip="Full Sketchfab model URL — the page URL of the model you want. The dialog fetches metadata (poly count, license, downloadable flag) as soon as you paste so you can decide before downloading." />

            <!-- Validation result card. Hidden until we have something. -->
            <Border x:Name="InfoCard"
                    Margin="0,16,0,0"
                    Padding="14"
                    CornerRadius="6"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    Visibility="Collapsed">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   x:Name="InfoName"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <!-- Quality pill: green for optimized, amber for
                             heavy, red for "this will hurt your server's
                             FPS". Hidden when the API didn't surface
                             tri/vert counts. -->
                        <Border Grid.Column="1"
                                x:Name="QualityPill"
                                CornerRadius="9"
                                Padding="10,2"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Visibility="Collapsed">
                            <TextBlock x:Name="QualityText"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                    <TextBlock x:Name="InfoAuthor" FontSize="12" Opacity="0.7" Margin="0,2,0,0" />
                    <TextBlock x:Name="InfoLicense" FontSize="11" Opacity="0.7" Margin="0,6,0,0" TextWrapping="Wrap" />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   x:Name="InfoGeometry"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   Opacity="0.85"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Column="1"
                                   x:Name="InfoSize"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   Opacity="0.6" />
                    </Grid>
                    <!-- Inline warning when the model is heavy/bad. Stays
                         empty (collapsed) for excellent/good models so we
                         don't nag on cleanly-authored assets. -->
                    <TextBlock x:Name="QualityWarning"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Status / progress -->
            <TextBlock x:Name="StatusText"
                       Margin="0,16,0,0"
                       FontSize="12"
                       Opacity="0.85"
                       TextWrapping="Wrap" />
            <ProgressBar x:Name="DownloadProgress"
                         Maximum="1"
                         Height="3"
                         Margin="0,6,0,0"
                         Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,16,16">
            <ui:Button x:Name="CancelButton"
                       Content="Cancel"
                       Appearance="Secondary"
                       Padding="20,6"
                       Margin="0,0,8,0"
                       Click="OnCancel"
                       ToolTip="Close without downloading. The 3D Model tab stays on whatever was already loaded." />
            <ui:Button x:Name="LoadButton"
                       Content="Load model"
                       Appearance="Primary"
                       Padding="20,6"
                       Click="OnLoad"
                       ToolTip="Download the model from Sketchfab and open it in the 3D Model viewer. Requires a Sketchfab API token (Settings → API keys)." />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
