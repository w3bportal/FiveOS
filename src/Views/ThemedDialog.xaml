<ui:FluentWindow x:Class="FiveOS.Views.ThemedDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="FiveOS"
                 MinWidth="400" MaxWidth="560"
                 SizeToContent="WidthAndHeight"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" x:Name="TitleBarCtl" Title="FiveOS"
                     ShowMaximize="False" ShowMinimize="False" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,10,24,6">
            <ui:SymbolIcon x:Name="IconCtl" Symbol="Info24" FontSize="30"
                           Margin="0,2,18,0" VerticalAlignment="Top" />
            <TextBlock x:Name="MessageCtl" TextWrapping="Wrap" MaxWidth="420"
                       FontSize="13.5" LineHeight="20" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,16,16">
            <ui:Button x:Name="SecondaryBtn" Content="No" Appearance="Secondary"
                       Padding="18,6" Margin="0,0,8,0" Click="OnSecondary" Visibility="Collapsed" />
            <ui:Button x:Name="CloseBtn" Content="Cancel" Appearance="Secondary"
                       Padding="18,6" Margin="0,0,8,0" Click="OnClose" Visibility="Collapsed" />
            <ui:Button x:Name="PrimaryBtn" Content="OK" Appearance="Primary"
                       Padding="20,6" Click="OnPrimary" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
