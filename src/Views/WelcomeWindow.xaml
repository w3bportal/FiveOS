<Window x:Class="FiveOS.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Welcome to FiveOS"
        Width="900" Height="560"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        KeyDown="OnKeyDown">

    <Window.Resources>
        <Style x:Key="ToolRow" TargetType="Border">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RecentRow" TargetType="Border">
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="Margin" Value="2,0,0,10" />
        </Style>
        <!-- Plain close button (no wpf-ui TitleBar). -->
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <TextBlock Text="&#10005;" FontSize="13" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E5484D" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header (drag to move) + close -->
            <Grid Grid.Row="0" Margin="24,18,12,10" Background="Transparent"
                  MouseLeftButtonDown="OnHeaderDrag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/Branding/FiveOS.png" Width="36" Height="36"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Welcome to FiveOS" FontSize="19" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="VersionText" FontSize="11.5"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>
                <Button Style="{StaticResource CloseBtn}" HorizontalAlignment="Right"
                        VerticalAlignment="Top" Click="OnClose" ToolTip="Close (Esc)" />
            </Grid>

            <!-- Body: quick tools | recent files -->
            <Grid Grid.Row="1" Margin="24,4,24,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <TextBlock Text="OPEN A TOOL" Style="{StaticResource ColHeader}" />

                    <Border Style="{StaticResource ToolRow}" Tag="Assets" MouseLeftButtonUp="OnTile">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Cube24" FontSize="21" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Assets" FontSize="13.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="Props and Animated — FiveM-ready exports"
                                           FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolRow}" Tag="Optimize" MouseLeftButtonUp="OnTile">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Sparkle24" FontSize="21" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Optimize" FontSize="13.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="Shrink meshes &amp; textures to keep servers smooth"
                                           FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolRow}" Tag="Rpf" MouseLeftButtonUp="OnTile"
                            Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Archive24" FontSize="21" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="RPF" FontSize="13.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="Pack a resource into a single .rpf archive"
                                           FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolRow}" Tag="Emotes" MouseLeftButtonUp="OnTile"
                            Visibility="{Binding LevelStandardPlus, Converter={StaticResource BooleanToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="EmojiHand24" FontSize="21" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Emotes" FontSize="13.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="Animations &amp; poses → .ycd emotes"
                                           FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <Border Grid.Column="1" Background="{DynamicResource ControlElevationBorderBrush}" />

                <Grid Grid.Column="2" Margin="18,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="RECENT FILES" Style="{StaticResource ColHeader}" />
                    <TextBlock Grid.Row="1" x:Name="EmptyRecent"
                               Text="No recent files yet — open a model and it shows up here."
                               FontSize="12" TextWrapping="Wrap" Margin="2,6,0,0"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="RecentList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource RecentRow}" Tag="{Binding Path}"
                                            MouseLeftButtonUp="OnRecent" ToolTip="{Binding Path}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Document24" FontSize="17"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="380" />
                                                <TextBlock Text="{Binding Dir}" FontSize="10.5"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="380" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Grid Grid.Row="2" Margin="24,12,24,18">
                <CheckBox x:Name="ShowOnStartupCheck" Content="Show this screen on startup"
                          FontSize="12" VerticalAlignment="Center" Click="OnToggleStartup"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11"
                           Text="All-in-one FiveM modding tool"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </Grid>
        </Grid>
    </Border>
</Window>
