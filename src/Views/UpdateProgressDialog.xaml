<ui:FluentWindow x:Class="FiveOS.Views.UpdateProgressDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Updating FiveOS"
                 Height="220" Width="460"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Updating FiveOS"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="20,12,20,0">
            <TextBlock x:Name="HeadlineText"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Text="Downloading update..." />
            <TextBlock x:Name="StatusText"
                       FontSize="12"
                       Opacity="0.75"
                       Margin="0,4,0,0"
                       Text="Starting..." />
            <ProgressBar x:Name="DownloadProgress"
                         Maximum="1"
                         Height="4"
                         Margin="0,14,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,16,16">
            <ui:Button x:Name="CancelButton"
                       Content="Cancel"
                       Appearance="Secondary"
                       Padding="20,6"
                       Click="OnCancel"
                       ToolTip="Abort the update download. Partially-downloaded bytes are cleaned up; you can retry from Help → Check for updates whenever you want." />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
