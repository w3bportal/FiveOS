<UserControl x:Class="FiveOS.Views.OptimizeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:FiveOS.ViewModels"
             xmlns:ctrl="clr-namespace:FiveOS.Views.Controls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             AllowDrop="True"
             Drop="OnFilesDropped"
             DragOver="OnDragOver"
             PreviewDrop="OnFilesDropped"
             PreviewDragOver="OnDragOver"
             d:DataContext="{d:DesignInstance vm:OptimizeViewModel}">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- Mode-picker card. Looks like a tile button; toggle-style
             selected state via IsChecked binding back to OptimizeMode.
             Default background sits one elevation above the strip
             behind it so the cards visibly lift off the surface. -->
        <Style x:Key="ModeCard" TargetType="RadioButton">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="GroupName" Value="OptimizeMode" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Order matters: hover trigger first so the
                                 selected trigger (declared last) wins when
                                 both fire. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush"
                                        Value="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush"
                                        Value="{DynamicResource SystemAccentColorBrush}" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Mode-picker cards -->
            <RowDefinition Height="*" />
            <!-- Workspace -->
            <RowDefinition Height="Auto" />
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ───────── Mode-picker row ───────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="20,16">
            <StackPanel>
                <TextBlock Text="OPTIMIZE"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Opacity="0.55"
                           Margin="0,0,0,10" />
                <UniformGrid Rows="1">
                    <UniformGrid.Style>
                        <!-- 6 cards normally; Beginner level hides the txAdmin
                             card, so drop to 5 columns to avoid an empty cell
                             (UniformGrid reserves cells for collapsed children). -->
                        <Style TargetType="UniformGrid">
                            <Setter Property="Columns" Value="6" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.LevelStandardPlus, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Columns" Value="5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </UniformGrid.Style>
                    <RadioButton Style="{StaticResource ModeCard}"
                                 Margin="0,0,8,0"
                                 IsChecked="{Binding IsPropsMode, Mode=OneWay}"
                                 Click="OnModeProps"
                                 ToolTip="Decimate static-prop drawables (.ydr). Each drop is run through g3sharp's quadric-edge-collapse on the High LOD only — Med/Low/VLow tiers are kept as-is.">
                        <StackPanel Orientation="Horizontal">
                            <Border CornerRadius="6"
                                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Padding="8" Margin="0,0,12,0">
                                <ui:SymbolIcon Symbol="Cube24" FontSize="20" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Optimize Props (YDR)"
                                           FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="Decimate prop geometry &amp; LODs"
                                           FontSize="11" Opacity="0.6"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource ModeCard}"
                                 Margin="0,0,8,0"
                                 IsChecked="{Binding IsClothingMode, Mode=OneWay}"
                                 Click="OnModeClothing"
                                 ToolTip="Decimate clothing drawable dictionaries (.ydd). Each clothing piece inside the dictionary is reduced. Skinning is preserved heuristically — at high reduction ratios skin deformation can look wrong, so keep ratios above ~0.5 for ped clothing.">
                        <StackPanel Orientation="Horizontal">
                            <Border CornerRadius="6"
                                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Padding="8" Margin="0,0,12,0">
                                <ui:SymbolIcon Symbol="BowTie24" FontSize="20" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Optimize Clothing (YDD)"
                                           FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="Reduce skinned mesh density"
                                           FontSize="11" Opacity="0.6"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource ModeCard}"
                                 Margin="0,0,8,0"
                                 IsChecked="{Binding IsTexturesMode, Mode=OneWay}"
                                 Click="OnModeTextures"
                                 ToolTip="Compress and downsize textures inside .ytd dictionaries. Re-encodes to BC1/BC3 via texconv. Folder drops recurse, so you can throw a whole resource folder at it.">
                        <StackPanel Orientation="Horizontal">
                            <Border CornerRadius="6"
                                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Padding="8" Margin="0,0,12,0">
                                <ui:SymbolIcon Symbol="Image24" FontSize="20" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Optimize Textures (YTD)"
                                           FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="Compress &amp; downsize"
                                           FontSize="11" Opacity="0.6"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- Vehicle (YFT) geometry optimization moved to the Vehicles tab. -->

                    <RadioButton Style="{StaticResource ModeCard}"
                                 Margin="0,0,8,0"
                                 IsChecked="{Binding IsEmbeddedTexturesMode, Mode=OneWay}"
                                 Click="OnModeEmbeddedTextures"
                                 ToolTip="Compress the textures embedded INSIDE model files (.ydd / .ydr / .yft) — each drawable's ShaderGroup texture dictionary — without touching its geometry. Same per-texture re-encode / downsize / cap controls as the YTD tab. Output overwrites the model in place.">
                        <StackPanel Orientation="Horizontal">
                            <Border CornerRadius="6"
                                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Padding="8" Margin="0,0,12,0">
                                <ui:SymbolIcon Symbol="ImageMultiple24" FontSize="20" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Optimize Embedded (Models)"
                                           FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="Textures inside .ydd/.ydr/.yft"
                                           FontSize="11" Opacity="0.6"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- txAdmin Optimizer — formerly its own rail entry/AppView;
                         now a mode card whose workspace is the TxAdminOptimizeView
                         hosted below. Hidden at Beginner level like the old rail
                         entry was (the UniformGrid style drops to 5 columns). -->
                    <RadioButton Style="{StaticResource ModeCard}"
                                 IsChecked="{Binding IsTxAdminMode, Mode=OneWay}"
                                 Click="OnModeTxAdmin"
                                 Visibility="{Binding DataContext.LevelStandardPlus, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibility}}"
                                 ToolTip="txAdmin Optimizer — paste your server console log and FiveOS shrinks every oversized streaming asset (.ytd/.ydr/.ydd/.yft) just enough to clear the warning.">
                        <StackPanel Orientation="Horizontal">
                            <Border CornerRadius="6"
                                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Padding="8" Margin="0,0,12,0">
                                <ui:SymbolIcon Symbol="Server24" FontSize="20" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="txAdmin Optimizer"
                                           FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="Auto-shrink from a server log"
                                           FontSize="11" Opacity="0.6"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- ───────── Workspace ───────── -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsTxAdminMode, Converter={StaticResource InverseBooleanToVisibility}}">
            <Grid.ColumnDefinitions>
                <!-- Width is toggled in code-behind: 320 for the texture modes
                     (which need the compression options), 0 for the geometry
                     modes (everything is driven from the workbench). -->
                <ColumnDefinition x:Name="OptionsColumn" Width="320" />
                <ColumnDefinition Width="2*" MinWidth="320" />
                <ColumnDefinition Width="3*" MinWidth="380" />
            </Grid.ColumnDefinitions>

            <!-- Options sidebar (texture modes only — compression settings) -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    Visibility="{Binding IsTextureMode, Converter={StaticResource BooleanToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,16,20,16">

                        <!-- ─── Texture compression options (Textures + Embedded) ─── -->
                        <StackPanel Visibility="{Binding IsTextureMode, Converter={StaticResource BooleanToVisibility}}">
                            <DockPanel Margin="16,18,16,8">
                                <ui:SymbolIcon DockPanel.Dock="Right"
                                               Style="{StaticResource HelpIconStyle}"
                                               ToolTip="Compress textures inside each dropped .ytd. Re-encode to BC1 (no alpha) / BC3 (with alpha), optionally halve each texture's dimensions, optionally skip files smaller than 16 MB. Pass texconv per-texture; folder drops recurse. Output is a copy with the same name in your Downloads folder." />
                                <TextBlock Text="COMPRESSION"
                                           FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                            <ui:ToggleSwitch IsChecked="{Binding YtdDownsize}"
                                             IsEnabled="{Binding YtdNoCap}"
                                             Content="Downsize 2×"
                                             ToolTip="Halve every triggered texture's W/H once. Saves ~75% memory; visible quality loss varies by content. Disabled while a Max resolution cap is set — the cap shrinks to a target instead." />

                            <TextBlock Text="Max resolution (cap)"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,12,0,4" />
                            <ComboBox SelectedIndex="{Binding YtdMaxSizeIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      ToolTip="Shrink any triggered texture whose longest side exceeds this down TO it (by repeated halving — 4096→cap in one run), instead of Downsize 2×'s single halve. Textures already at or under the cap aren't resized. Only textures passing the trigger threshold below are considered. 'No cap' defers to the Downsize 2× toggle.">
                                <ComboBoxItem Content="No cap (use Downsize 2×)" ToolTip="No resolution ceiling — the Downsize 2× toggle decides resizing." />
                                <ComboBoxItem Content="2048 — clamp larger down to 2048" ToolTip="Anything bigger than 2048 on its longest side is shrunk to 2048; smaller is left as-is." />
                                <ComboBoxItem Content="1024 — clamp larger down to 1024" ToolTip="Anything bigger than 1024 on its longest side is shrunk to 1024; smaller is left as-is." />
                                <ComboBoxItem Content="512 — clamp larger down to 512" ToolTip="Anything bigger than 512 on its longest side is shrunk to 512; smaller is left as-is. Aggressive." />
                            </ComboBox>

                            <ui:ToggleSwitch IsChecked="{Binding YtdFormatOptimization}"
                                             Content="Force BC1/BC3 re-encode"
                                             Margin="0,8,0,0"
                                             ToolTip="Re-encode to BC1 (no alpha) / BC3 (with alpha) regardless of source format. Bigger savings, irreversible." />
                            <ui:ToggleSwitch IsChecked="{Binding YtdOnlyOversized}"
                                             Content="Skip files &lt; 16 MB physical"
                                             Margin="0,8,0,0"
                                             Visibility="{Binding IsTexturesMode, Converter={StaticResource BooleanToVisibility}}"
                                             ToolTip="Only-oversized rule: leaves small YTDs alone. Applies to whole .ytd files only — it has no effect on embedded textures." />

                            <TextBlock Text="Trigger threshold (W+H)"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,12,0,4" />
                            <ComboBox SelectedIndex="{Binding YtdThresholdIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      ToolTip="Only re-encode / downsize textures larger than this sum of width + height. Higher threshold = touch only the biggest textures; lower threshold = touch nearly everything. The 8192 default skips anything 2K square and smaller.">
                                <ComboBoxItem Content="8192 (>2K square)" ToolTip="Only oversized textures larger than 2048×2048-ish get touched. Safest setting." />
                                <ComboBoxItem Content="4096 (>1K square)" ToolTip="Anything bigger than 1024×1024-ish gets touched." />
                                <ComboBoxItem Content="2048 (>512 square)" ToolTip="Anything bigger than 512×512-ish gets touched." />
                                <ComboBoxItem Content="1024 (>256 square)" ToolTip="Anything bigger than 256×256-ish — aggressive, hits most textures." />
                            </ComboBox>

                            <TextBlock Margin="0,16,0,0"
                                       FontSize="11"
                                       Opacity="0.55"
                                       TextWrapping="Wrap"
                                       Text="Per-texture re-encode via texconv inside each YTD. Trigger threshold picks WHICH textures are touched; Downsize 2× / Max resolution cap pick HOW they're resized. Folder drops are recursed and written back in place, keeping subfolders." />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right pane: drop zone or queue -->
            <Grid Grid.Column="1" Margin="16,12,16,12">

                <!-- Empty state -->
                <Border Visibility="{Binding HasFiles, Converter={StaticResource InverseBooleanToVisibility}}"
                        Background="Transparent"
                        BorderBrush="{DynamicResource AccentControlElevationBorderBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        ToolTip="Drag and drop files (.ydr / .ydd / .yft for drawables, .ytd for textures) — or a whole folder / clothing pack — anywhere here. Folders recurse for every supported type and keep their subfolders. Or use the buttons below.">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="ArrowUpload24"
                                       FontSize="56"
                                       HorizontalAlignment="Center"
                                       Opacity="0.55"
                                       Margin="0,0,0,16" />
                        <TextBlock Text="{Binding EmptyHint}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="Drag files or a folder here — or browse:"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Opacity="0.7" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,16,0,0">
                            <ui:Button Content="Browse files"
                                       Appearance="Secondary"
                                       Margin="0,0,8,0"
                                       Click="OnDropZoneClick"
                                       ToolTip="Pick one or more files to add to the queue.">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="DocumentAdd24" />
                                </ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Browse folder"
                                       Appearance="Primary"
                                       Click="OnAddFolder"
                                       ToolTip="Pick a whole resource or clothing pack. Every .ydr / .ydd / .ytd / .yft inside is queued recursively, keeping its subfolders.">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="FolderAdd24" />
                                </ui:Button.Icon>
                            </ui:Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Queue state -->
                <Grid Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding FileCount, Mode=OneWay}" />
                            <Run Text=" queued" />
                        </TextBlock>
                        <ui:Button Grid.Column="1"
                                   Appearance="Secondary"
                                   Margin="0,0,8,0"
                                   Click="OnOpenOutput"
                                   ToolTip="Open the destination folder for the current optimize mode in Explorer.">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="FolderOpen24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Grid.Column="2"
                                   Appearance="Secondary"
                                   Margin="0,0,8,0"
                                   Click="OnAddFolder"
                                   ToolTip="Pick a folder (a resource or clothing pack). Every .ydr / .ydd / .ytd / .yft inside is queued recursively and optimized in place, keeping the pack's subfolders.">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="FolderAdd24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Grid.Column="3"
                                   Content="Add files..."
                                   Appearance="Secondary"
                                   Margin="0,0,8,0"
                                   Click="OnDropZoneClick"
                                   ToolTip="Browse for more files to add to the queue. Same as dragging files onto the drop zone." />
                        <ui:Button Grid.Column="4"
                                   Content="Clear"
                                   Appearance="Secondary"
                                   Click="OnClear"
                                   ToolTip="Empty the queue. Files already optimized stay where they were saved on disk." />
                    </Grid>

                    <Border Grid.Row="1"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                        <ListBox ItemsSource="{Binding ActiveQueue}"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="3"
                                                Padding="6,1"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Extension}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="White" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FileName}"
                                                   Margin="8,0,8,0"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   ToolTip="{Binding Path}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TrisDisplay}"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   Opacity="0.7"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"
                                                   ToolTip="Triangles before → after" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding VertsDisplay}"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   Opacity="0.7"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"
                                                   ToolTip="Vertices before → after (welding can shrink these even when triangles don't change)" />
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding SizeDisplay}"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   Opacity="0.6"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0" />
                                        <!-- Status icon + text. The icon glyph
                                             swaps via DataTriggers on the
                                             StatusKind enum — was previously
                                             a ✓/✗ char inside the Status
                                             string itself; split into a real
                                             SymbolIcon so the affordance
                                             reads cleanly and the text stays
                                             plain. -->
                                        <StackPanel Grid.Column="5"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <ui:SymbolIcon FontSize="12"
                                                           Margin="0,0,5,0"
                                                           VerticalAlignment="Center">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Symbol" Value="Check24" />
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="Running">
                                                                <Setter Property="Symbol" Value="ArrowSync24" />
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="Ok">
                                                                <Setter Property="Symbol" Value="Check24" />
                                                                <Setter Property="Foreground" Value="#4FBF6F" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="Error">
                                                                <Setter Property="Symbol" Value="ErrorCircle24" />
                                                                <Setter Property="Foreground" Value="#E45757" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="Skipped">
                                                                <Setter Property="Symbol" Value="Subtract24" />
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                            <TextBlock Text="{Binding StatusDisplay}"
                                                       FontSize="11"
                                                       Opacity="0.7"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Grid>

            <!-- ───────── Col 2: inline textured LOD preview panel (geometry modes) ───────── -->
            <Border Grid.Column="2"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    Visibility="{Binding IsLodMode, Converter={StaticResource BooleanToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar: LOD tabs + view toggles + Save -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="LOD:" VerticalAlignment="Center" Opacity="0.6"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,10,0" />
                                <RadioButton x:Name="OptLodHigh" Content="HIGH" GroupName="optLod" IsChecked="True"
                                             Margin="0,0,10,0" Checked="OnLodChecked" Tag="HIGH" />
                                <RadioButton x:Name="OptLodMed" Content="MED" GroupName="optLod"
                                             Margin="0,0,3,0" Checked="OnLodChecked" Tag="MED" />
                                <ui:SymbolIcon x:Name="OptLodMedWarn" Symbol="Warning24" FontSize="14"
                                               Foreground="#E0A33A" Visibility="Collapsed"
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                <RadioButton x:Name="OptLodLow" Content="LOW" GroupName="optLod"
                                             Margin="0,0,3,0" Checked="OnLodChecked" Tag="LOW" />
                                <ui:SymbolIcon x:Name="OptLodLowWarn" Symbol="Warning24" FontSize="14"
                                               Foreground="#E0A33A" Visibility="Collapsed"
                                               VerticalAlignment="Center" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" x:Name="OptWireToggle" Content="Wireframe"
                                             Margin="20,0,0,0" VerticalAlignment="Center"
                                             Checked="OnWireChanged" Unchecked="OnWireChanged"
                                             ToolTip="Show the mesh as wireframe — spot collapsed faces / holes." />
                            <ui:ToggleSwitch Grid.Column="2" x:Name="OptEdgedToggle" Content="Edged faces"
                                             Margin="14,0,0,0" VerticalAlignment="Center"
                                             Checked="OnEdgedChanged" Unchecked="OnEdgedChanged"
                                             ToolTip="Keep the textured surface and overlay triangle edges." />
                            <TextBlock Grid.Column="3" x:Name="OptSizeText"
                                       Text="—"
                                       FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Opacity="0.8" Margin="16,0,12,0"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="Projected file size if you Save LODs with the current per-LOD ratios (geometry chain only — embedded textures are left as-is). RSC7 is compressed, so this is computed by serializing the resource in memory, not a raw byte guess." />
                            <ui:Button Grid.Column="4" Content="Recenter" Appearance="Secondary"
                                       Margin="0,0,8,0" Click="OnRecenter"
                                       ToolTip="Re-frame the camera on the mesh." />
                            <ui:Button Grid.Column="5" x:Name="OptSaveButton" Content="Save HIGH"
                                       Appearance="Primary" IsEnabled="False" Click="OnSave"
                                       ToolTip="Reduce ONLY the currently-selected LOD's geometry to the slider ratio and overwrite the file in place. Never adds new LODs, so the file shrinks. Disabled at 100% (nothing to reduce) or when the model has no geometry for this LOD." />
                        </Grid>
                    </Border>

                    <!-- Per-LOD optimize slider + counts -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Run Text="Optimize " /><Run x:Name="OptLodNameRun" Text="HIGH" FontWeight="SemiBold" />
                            </TextBlock>
                            <Slider Grid.Column="1" x:Name="OptRatioSlider"
                                    Minimum="0.05" Maximum="1.0" Value="1.0"
                                    IsMoveToPointEnabled="True"
                                    VerticalAlignment="Center" ValueChanged="OnRatioChanged"
                                    ToolTip="Fraction of HIGH triangles to keep for this LOD. Click anywhere on the track to jump." />
                            <TextBlock Grid.Column="2" x:Name="OptRatioPctText" Text="100%"
                                       FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"
                                       MinWidth="40" TextAlignment="Right" Margin="10,0,16,0" />
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="OptSourceTrisText" Text="Source: —"
                                           FontFamily="Consolas" FontSize="12" Opacity="0.65" Margin="0,0,12,0" />
                                <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                                        CornerRadius="4" Padding="7,2" VerticalAlignment="Center">
                                    <TextBlock x:Name="OptOptimizedTrisText" Text="Optimized: —"
                                               FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Viewport (empty/loading/error states are drawn INSIDE
                         the page via fiveosWorkbench.setMessage — a WPF overlay
                         can't sit over a WebView2). -->
                    <wv2:WebView2 Grid.Row="2" x:Name="OptimizeViewport" />

                    <!-- External texture (.ytd) toggle. Clothing/props reference
                         their diffuse from a sibling .ytd, not embedded, so the
                         preview is flat until this loads it onto the model. -->
                    <Border Grid.Row="3"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="OptYtdToggle"
                                      Content="Show texture"
                                      IsEnabled="False"
                                      VerticalAlignment="Center"
                                      Checked="OnYtdToggle"
                                      Unchecked="OnYtdToggle"
                                      ToolTip="Load the model's external .ytd textures onto the preview. Off by default — clothing diffuse lives in a separate .ytd, so it isn't shown until you turn this on." />
                            <ui:SymbolIcon Symbol="Image24" FontSize="13" Opacity="0.6"
                                           VerticalAlignment="Center" Margin="16,0,6,0" />
                            <TextBlock x:Name="OptYtdNameText"
                                       Text="—"
                                       FontFamily="Consolas" FontSize="11"
                                       Opacity="0.75"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ───────── Col 2: flat texture gallery (texture modes) ─────────
                 Shares the cell with the LOD workbench above; only one is ever
                 visible, so collapsing the workbench frees the WebView2 airspace
                 and this pure-WPF panel renders cleanly. -->
            <Border Grid.Column="2"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    Visibility="{Binding IsTextureMode, Converter={StaticResource BooleanToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            Padding="14,10">
                        <TextBlock x:Name="GalleryHeader"
                                   Text="TEXTURES"
                                   FontSize="11" FontWeight="SemiBold" Opacity="0.55" />
                    </Border>

                    <!-- Thumbnail grid + empty/loading overlay -->
                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="8">
                            <ItemsControl x:Name="TextureGallery">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="150" Margin="8"
                                                CornerRadius="8"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                ToolTip="{Binding Name}">
                                            <StackPanel>
                                                <Border Height="130"
                                                        CornerRadius="8,8,0,0"
                                                        Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                                                    <Image Source="{Binding Image}"
                                                           Stretch="Uniform"
                                                           Margin="6"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Border>
                                                <StackPanel Margin="8,6,8,8">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11"
                                                               FontFamily="Consolas"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Detail}"
                                                               FontSize="10"
                                                               Opacity="0.6"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="GalleryEmpty"
                                   Text="Select a file to view its textures"
                                   FontSize="14"
                                   Opacity="0.55"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="320" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ───────── txAdmin workspace ─────────
             Replaces the whole asset workspace when the txAdmin mode card is
             active. Content resolves TxAdminOptimizeViewModel → TxAdminOptimizeView
             via the App.xaml DataTemplate; the VM lives on MainViewModel so the
             tab keeps its state (queue, parsed log) across mode/tab switches. -->
        <ContentControl Grid.Row="1"
                        Content="{Binding DataContext.TxAdminVm, RelativeSource={RelativeSource AncestorType=Window}}"
                        Visibility="{Binding IsTxAdminMode, Converter={StaticResource BooleanToVisibility}}" />

        <!-- ───────── Footer (texture modes only — the bulk OPTIMIZE button;
             geometry modes optimize per-LOD from the workbench instead) ───── -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Padding="16,12"
                Visibility="{Binding IsTextureMode, Converter={StaticResource BooleanToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ctrl:DotMatrixLoader Grid.Column="0"
                                      LoaderStyle="BlockDrop"
                                      DotSize="5"
                                      DotSpacing="2"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibility}}" />

                <StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Summary}"
                               FontSize="12"
                               Opacity="0.85"
                               TextTrimming="CharacterEllipsis" />
                    <ProgressBar Value="{Binding Progress}"
                                 Maximum="1"
                                 Height="3"
                                 Margin="0,4,0,0"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibility}}" />
                </StackPanel>

                <ui:Button Grid.Column="2"
                           Content="OPTIMIZE"
                           Appearance="Primary"
                           Padding="32,12"
                           FontSize="13"
                           FontWeight="SemiBold"
                           IsEnabled="{Binding CanProcess}"
                           Click="OnRun"
                           ToolTip="Run the optimizer on every file in the queue. Originals are preserved; optimized files land in your Downloads folder as {name}_opt.{ext}.">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Sparkle24" />
                    </ui:Button.Icon>
                </ui:Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
