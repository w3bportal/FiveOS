<UserControl x:Class="FiveOS.Views.PoseToEmoteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:vm="clr-namespace:FiveOS.ViewModels"
             xmlns:ctrl="clr-namespace:FiveOS.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PoseToEmoteViewModel}">
    <UserControl.Resources>

        <!-- ─── Blender-style chevron section header ───
             Whole row toggles a single bool (IsChecked); no chunky button
             chrome — just a small chevron, an uppercase caption, and a
             hairline divider that trails to the right edge. Mirrors
             Blender's Properties-editor section pattern (▶ collapsed,
             ▼ expanded). Hover lightly tints the chevron + label so the
             row still reads as clickable without painting a fill behind
             it. -->
        <Style x:Key="BlenderSectionHeader" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent"
                                Padding="0,4,0,4"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon x:Name="Chevron"
                                               Grid.Column="0"
                                               Symbol="ChevronDown12"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center" />
                                <TextBlock x:Name="Caption"
                                           Grid.Column="1"
                                           Text="{TemplateBinding Content}"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <Border Grid.Column="2"
                                        Height="1"
                                        Background="{DynamicResource ControlElevationBorderBrush}"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Chevron" Property="Symbol" Value="ChevronRight12" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chevron" Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Setter TargetName="Caption" Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Eye-toggle (visibility per body region) ───
             Bound to PoseBoneGroup.IsVisible; flips the SymbolIcon and
             dispatches a setPoseBoneVisibility call back to the viewer
             through OnGroupVisibilityToggled. -->
        <Style x:Key="EyeToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ui:SymbolIcon x:Name="Icon"
                                           Symbol="Eye24"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Icon" Property="Symbol" Value="EyeOff24" />
                                <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Lock toggle for timeline track rows -->
        <Style x:Key="LockToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ui:SymbolIcon x:Name="Icon"
                                           Symbol="LockOpen24"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Icon" Property="Symbol" Value="LockClosed24" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#FFAA33" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EmoteCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="EmoteCardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="EmoteChipText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- ─── Outliner tree (Blender-style) ───
             Three tightly-stacked row types share the same background
             and height profile so the tree reads as one continuous
             list of rows, indented like Blender's outliner:
               * Rig row — chevron, person icon, rig name. Clicking
                 selects the whole model (move/rot/scale gizmo on its
                 root). The selected rig gets an orange left-edge bar
                 and a tint so the active "object-mode" target is
                 unmistakable.
               * Group row — chevron, folder icon, region name, count
                 chip, eye toggle. Indented under its parent rig.
                 Click anywhere on the row toggles expand; the eye
                 toggle lives in a sibling layer so its own click
                 doesn't bubble through.
               * Bone row — indented further, tiny circle marker,
                 mono name, orange "edited" dot on the right edge.
             No row backgrounds by default — only hover and selected
             paint a fill, so the tree feels light and Blender-like. -->
        <DataTemplate DataType="{x:Type vm:PoseRig}" x:Key="PoseRigTemplate">
            <StackPanel>
                <Button Click="OnRigRowClick"
                        Tag="{Binding}"
                        Cursor="Hand"
                        Focusable="False"
                        HorizontalContentAlignment="Stretch">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RigRow"
                                    Background="Transparent"
                                    BorderThickness="2,0,0,0"
                                    BorderBrush="Transparent"
                                    Padding="4,4,8,4"
                                    SnapsToDevicePixels="True">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:SymbolIcon x:Name="RigChevron"
                                                   Symbol="ChevronRight12"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Margin="0,0,4,0"
                                                   VerticalAlignment="Center" />
                                    <ui:SymbolIcon Symbol="PersonStar24"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RigRow" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <Setter TargetName="RigChevron" Property="Symbol" Value="ChevronDown12" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsModelSelected}" Value="True">
                                    <Setter TargetName="RigRow" Property="Background" Value="#33FF7A2D" />
                                    <Setter TargetName="RigRow" Property="BorderBrush" Value="#FF7A2D" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- Nested bone groups, indented ~14 px so the group
                     headers visibly hang under the rig row.
                     DynamicResource (not StaticResource) on the
                     template ref: BoneGroupTemplate is defined LATER
                     in this resource dictionary, and StaticResource
                     looks up at parse time — crashed the app at
                     window construction with "Cannot find resource
                     named 'BoneGroupTemplate'". DynamicResource
                     resolves at apply time, after the whole
                     dictionary has loaded. -->
                <ItemsControl ItemsSource="{Binding BoneGroups}"
                              ItemTemplate="{DynamicResource BoneGroupTemplate}"
                              Margin="14,0,0,0"
                              Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibility}}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PoseBoneGroup}" x:Key="BoneGroupTemplate">
            <StackPanel Visibility="{Binding IsFilteredOut, Converter={StaticResource InverseBooleanToVisibility}}">
                <Grid>
                    <!-- Full-width clickable group row. Padding-right
                         reserves space for the floating count + eye
                         overlay so the region name never collides with
                         them at narrow sidebar widths. -->
                    <Button Click="OnGroupRowClick"
                            Tag="{Binding}"
                            Cursor="Hand"
                            Focusable="False"
                            HorizontalContentAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Row"
                                        Background="Transparent"
                                        BorderThickness="2,0,0,0"
                                        BorderBrush="Transparent"
                                        Padding="6,3,58,3"
                                        SnapsToDevicePixels="True">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:SymbolIcon x:Name="Chevron"
                                                       Symbol="ChevronRight12"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="0,0,4,0"
                                                       VerticalAlignment="Center" />
                                        <ui:SymbolIcon x:Name="FolderIcon"
                                                       Symbol="Folder20"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Row" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                        <Setter TargetName="Chevron" Property="Symbol" Value="ChevronDown12" />
                                        <Setter TargetName="FolderIcon" Property="Symbol" Value="FolderOpen20" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Right-edge overlay: bone count + eye toggle.
                         Lives in the same Grid cell as the row Button;
                         WPF hit-tests this layer first so clicks on the
                         eye don't bleed through to the row's expand
                         click. -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                        <TextBlock Text="{Binding CountLabel}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <ToggleButton Style="{StaticResource EyeToggle}"
                                      IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                      Click="OnGroupVisibilityToggled"
                                      Tag="{Binding}"
                                      ToolTip="Show / hide joint markers for this region in the viewport" />
                    </StackPanel>
                </Grid>

                <!-- Children: bone rows. Indented ~28px from the group
                     row so the hierarchy reads visually like Blender's
                     outliner. Collapsed when IsExpanded is false. -->
                <ItemsControl ItemsSource="{Binding Bones}"
                              Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibility}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PoseBoneEntry}">
                            <Button Click="OnBoneRowClick"
                                    Tag="{Binding}"
                                    HorizontalContentAlignment="Stretch"
                                    Cursor="Hand"
                                    Focusable="False"
                                    Visibility="{Binding IsHidden, Converter={StaticResource InverseBooleanToVisibility}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Row"
                                                Background="Transparent"
                                                BorderThickness="2,0,0,0"
                                                BorderBrush="Transparent"
                                                Padding="28,2,10,2"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <!-- Tiny joint dot mirrors the joint
                                                     spheres in the viewport so the
                                                     row reads as "this bone". -->
                                                <Ellipse Grid.Column="0"
                                                         Width="5" Height="5"
                                                         Fill="{DynamicResource TextFillColorTertiaryBrush}"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Name}"
                                                           FontFamily="Consolas"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                                <Ellipse Grid.Column="2"
                                                         Width="5" Height="5"
                                                         Fill="#FFAA33"
                                                         Margin="6,0,0,0"
                                                         VerticalAlignment="Center"
                                                         Visibility="{Binding IsModified, Converter={StaticResource BooleanToVisibility}}" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Row" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="Row" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                <Setter TargetName="Row" Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Workspace (drag the splitter below to resize). -->
            <RowDefinition Height="*" MinHeight="200" />
            <!-- Horizontal splitter between workspace + timeline. -->
            <RowDefinition Height="4" />
            <!-- Timeline pane. Starts at a height that fits the
                 controls + ~118 px canvas; users can drag the splitter
                 above to grow / shrink it for finer keyframe work. -->
            <RowDefinition Height="280" MinHeight="160" />
        </Grid.RowDefinitions>

        <GridSplitter Grid.Row="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource ControlElevationBorderBrush}"
                      ShowsPreview="False"
                      ResizeBehavior="PreviousAndNext"
                      Visibility="{Binding HasRig, Converter={StaticResource BooleanToVisibility}}"
                      Cursor="SizeNS" />

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <!-- Sidebar: tool stack + footer. Resizable via the
                     vertical splitter on its right edge. -->
                <ColumnDefinition Width="310" MinWidth="220" />
                <!-- Vertical splitter between sidebar and outliner/viewport. -->
                <ColumnDefinition Width="4" />
                <!-- Outliner column: tab on the sidebar edge + a
                     width-bound panel that slides out into the
                     viewport when the user clicks the tab. Auto-width
                     so the panel can collapse to 0 and only the tab
                     stays visible against the sidebar's edge. -->
                <ColumnDefinition Width="Auto" />
                <!-- Viewport takes the rest. -->
                <ColumnDefinition Width="*" MinWidth="240" />
                <!-- Inspector column: same Auto-width slide-out
                     pattern as the outliner on the left, but flipped
                     so the tab hugs the viewport's right edge with
                     the panel collapsing into the right margin. -->
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource ControlElevationBorderBrush}"
                          ShowsPreview="False"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <!-- ─── Sidebar ───
                 Tool stack + footer. The outliner used to live here
                 (the middle row); it's now a separate slide-out panel
                 to the right of this border so the user can fold it
                 away and reclaim viewport width. -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Tool stack: scrollable Blender section
                             chevrons (model / library / character / prop). -->
                        <RowDefinition Height="*" MinHeight="120" />
                        <!-- Footer: status / chip / undo / mirror / export. -->
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ─── Top tool stack ───
                         Blender-style chevron sections. Each section is a
                         tight clickable header — small chevron + caps
                         caption + hairline divider, no chunky button
                         chrome — that collapses its content below.
                         Default expanded; collapse state lives on the
                         VM so a tab switch doesn't reset the user's
                         layout. Rig-only sections still collapse the
                         whole block (header + content) until a model
                         loads. -->
                    <!-- ─── Top tool stack (Blender-section chevrons) ───
                         Fills the sidebar above the footer now that the
                         outliner has moved out into its own slide-out
                         panel. ScrollViewer kicks in for shorter screens. -->
                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,12,12,12">

                            <TextBlock Text="Use File → Emote to open a rigged model."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"
                                       Visibility="{Binding HasRig, Converter={StaticResource InverseBooleanToVisibility}}" />

                            <!-- LIBRARY -->
                            <StackPanel Visibility="{Binding HasRig, Converter={StaticResource BooleanToVisibility}}">
                                <ToggleButton Style="{StaticResource BlenderSectionHeader}"
                                              IsChecked="{Binding LibraryExpanded, Mode=TwoWay}"
                                              Content="LIBRARY"
                                              Margin="0,0,0,6" />
                                <StackPanel Visibility="{Binding LibraryExpanded, Converter={StaticResource BooleanToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button Grid.Column="0"
                                               Click="OnSaveCurrentPose"
                                               Appearance="Secondary"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Center"
                                               Padding="0,6"
                                               Margin="0,0,3,0"
                                               ToolTip="Save the current pose to %APPDATA%\FiveOS\poses\ for quick reuse later.">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="BookmarkAdd24" FontSize="13" Margin="0,0,6,0" />
                                            <TextBlock Text="Save Pose" FontSize="11" />
                                        </StackPanel>
                                    </ui:Button>
                                    <ui:Button Grid.Column="1"
                                               Click="OnImportYcd"
                                               Appearance="Secondary"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Center"
                                               Padding="0,6"
                                               Margin="3,0,0,0"
                                               ToolTip="Import a .ycd animation file into the timeline so you can tweak existing emotes.">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ArrowImport24" FontSize="13" Margin="0,0,6,0" />
                                            <TextBlock Text="Import .ycd" FontSize="11" />
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                                <ui:Button Click="OnImportAnimation"
                                           Appearance="Secondary"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Center"
                                           Padding="0,6"
                                           Margin="0,6,0,0"
                                           ToolTip="Import an animated .glb/.gltf/.fbx/.dae/.bvh clip. Retargeted onto the GTA skeleton and dropped on the timeline as keyframes.">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="EmojiHand24" FontSize="13" Margin="0,0,6,0" />
                                        <TextBlock Text="Import Animation (.glb / .fbx / .bvh)" FontSize="11" />
                                    </StackPanel>
                                </ui:Button>
                                <ItemsControl ItemsSource="{Binding CustomPoses}"
                                              Margin="0,8,0,0"
                                              Visibility="{Binding HasCustomPoses, Converter={StaticResource BooleanToVisibility}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Padding="8,5"
                                                    Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Subtitle}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <ui:Button Grid.Column="1"
                                                               Click="OnApplyCustomPose"
                                                               Appearance="Secondary"
                                                               Padding="6,3"
                                                               Margin="6,0,3,0"
                                                               Tag="{Binding Slug}"
                                                               ToolTip="Apply this pose to the rig.">
                                                        <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="12" />
                                                    </ui:Button>
                                                    <ui:Button Grid.Column="2"
                                                               Click="OnDeleteCustomPose"
                                                               Appearance="Secondary"
                                                               Padding="6,3"
                                                               Tag="{Binding Slug}"
                                                               ToolTip="Delete this saved pose.">
                                                        <ui:SymbolIcon Symbol="Delete24" FontSize="12" />
                                                    </ui:Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </StackPanel>
                            </StackPanel>

                            <!-- CHARACTER -->
                            <StackPanel Visibility="{Binding HasRig, Converter={StaticResource BooleanToVisibility}}">
                                <ToggleButton Style="{StaticResource BlenderSectionHeader}"
                                              IsChecked="{Binding CharacterExpanded, Mode=TwoWay}"
                                              Content="CHARACTER"
                                              Margin="0,14,0,6" />
                                <StackPanel Visibility="{Binding CharacterExpanded, Converter={StaticResource BooleanToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button Grid.Column="0"
                                               Click="OnAddSecondaryPed"
                                               Appearance="Secondary"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Center"
                                               Padding="0,6"
                                               Margin="0,0,3,0"
                                               ToolTip="Add a second character offset to the right (for paired-emote authoring). Editing focus stays on the current character.">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="PeopleAdd24" FontSize="13" Margin="0,0,6,0" />
                                            <TextBlock Text="Add Ped B" FontSize="11" />
                                        </StackPanel>
                                    </ui:Button>
                                    <ui:Button Grid.Column="1"
                                               Click="OnSwapPedFocus"
                                               Appearance="Secondary"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Center"
                                               Padding="0,6"
                                               Margin="3,0,0,0"
                                               IsEnabled="{Binding HasSecondaryPed}"
                                               ToolTip="Swap which character is the active editing target. Each ped keeps its own pose.">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ArrowSwap24" FontSize="13" Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding SecondaryPedLabel}" FontSize="11" />
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                                </StackPanel>
                            </StackPanel>

                            <!-- PROP -->
                            <StackPanel Visibility="{Binding HasRig, Converter={StaticResource BooleanToVisibility}}">
                                <ToggleButton Style="{StaticResource BlenderSectionHeader}"
                                              IsChecked="{Binding PropExpanded, Mode=TwoWay}"
                                              Content="PROP"
                                              Margin="0,14,0,6" />
                                <StackPanel Visibility="{Binding PropExpanded, Converter={StaticResource BooleanToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button Grid.Column="0"
                                               Click="OnLoadProp"
                                               Appearance="Secondary"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Center"
                                               Padding="0,6"
                                               Margin="0,0,3,0"
                                               ToolTip="Load a prop (.glb / .fbx) and attach it to the ped's selected bone for preview. Used to author emotes that hold an item.">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Cube24" FontSize="13" Margin="0,0,6,0" />
                                            <TextBlock Text="Load Prop" FontSize="11" />
                                        </StackPanel>
                                    </ui:Button>
                                    <ui:Button Grid.Column="1"
                                               Click="OnRemoveProp"
                                               Appearance="Secondary"
                                               Padding="8,6"
                                               IsEnabled="{Binding HasProp}"
                                               ToolTip="Remove the loaded prop">
                                        <ui:SymbolIcon Symbol="Delete24" FontSize="13" />
                                    </ui:Button>
                                </Grid>
                                <StackPanel Margin="0,8,0,0"
                                            Visibility="{Binding HasProp, Converter={StaticResource BooleanToVisibility}}">
                                    <TextBlock Text="GTA prop model name"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,2" />
                                    <TextBox Text="{Binding PropModelName, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas"
                                             FontSize="11"
                                             ToolTip="GTA model name dpemotes will spawn at the bone, e.g. prop_phone_ing" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,3,0">
                                            <TextBlock Text="Attach bone (name)"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,0,2" />
                                            <ComboBox SelectedValue="{Binding PropAttachBoneName, Mode=TwoWay}"
                                                      SelectionChanged="OnPropBoneNameChanged"
                                                      SelectedValuePath="Content"
                                                      FontFamily="Consolas"
                                                      FontSize="11"
                                                      IsEditable="True"
                                                      ToolTip="Skeleton bone the prop attaches to. Pick a SKEL_* name or type a custom one — the bone tag (game) field updates automatically for common bones.">
                                                <ComboBoxItem Content="SKEL_R_Hand" />
                                                <ComboBoxItem Content="SKEL_L_Hand" />
                                                <ComboBoxItem Content="SKEL_Head" />
                                                <ComboBoxItem Content="SKEL_Spine3" />
                                                <ComboBoxItem Content="SKEL_R_Foot" />
                                                <ComboBoxItem Content="SKEL_L_Foot" />
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="3,0,0,0">
                                            <TextBlock Text="Bone tag (game)"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,0,2" />
                                            <ui:NumberBox Value="{Binding PropBoneId, Mode=TwoWay}"
                                                          Minimum="0"
                                                          Maximum="65535"
                                                          ClearButtonEnabled="False"
                                                          SpinButtonPlacementMode="Hidden"
                                                          ToolTip="Runtime bone tag dpemotes uses for AttachEntityToEntity. R Hand = 28422, L Hand = 60309" />
                                        </StackPanel>
                                    </Grid>
                                    <ui:Button Click="OnSelectProp"
                                               Appearance="Secondary"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Center"
                                               Padding="0,5"
                                               Margin="0,8,0,0"
                                               ToolTip="Attach the transform gizmo to the loaded prop so you can move / rotate / scale it relative to its bone.">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ArrowMove24" FontSize="12" Margin="0,0,6,0" />
                                            <TextBlock Text="Edit Prop Transform" FontSize="11" />
                                        </StackPanel>
                                    </ui:Button>
                                </StackPanel>
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ─── Footer ───
                         Status / chip / history / mirror / reset / export.
                         Visually a single block so it reads as one
                         "controls" cluster. -->
                    <StackPanel Grid.Row="1" Margin="12,10,12,12">
                        <Border CornerRadius="9"
                                Padding="8,3"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Left"
                                BorderThickness="1"
                                Visibility="{Binding HasRig, Converter={StaticResource BooleanToVisibility}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#3a3f55" />
                                    <Setter Property="BorderBrush" Value="#3a3f55" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAnimatedExport}" Value="True">
                                            <Setter Property="Background" Value="#FFAA33" />
                                            <Setter Property="BorderBrush" Value="#FFAA33" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="PlayCircle24"
                                               FontSize="12"
                                               Margin="0,0,5,0"
                                               Foreground="#FFFFFF" />
                                <TextBlock Text="{Binding AnimatedChipText}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#FFFFFF" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="11"
                                   Opacity="0.65"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4" />
                        <Grid Visibility="{Binding HasSkippedBones, Converter={StaticResource BooleanToVisibility}}"
                              Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SkippedSummary}"
                                       FontSize="10"
                                       Foreground="#FFD23F" />
                            <ui:HyperlinkButton Grid.Column="1"
                                                Click="OnShowSkippedReport"
                                                Content="View report" />
                        </Grid>
                        <Grid Margin="0,0,0,6"
                              Visibility="{Binding HasRig, Converter={StaticResource BooleanToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0"
                                       Click="OnUndoPose"
                                       Appearance="Secondary"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       Padding="0,5"
                                       Margin="0,0,3,0"
                                       IsEnabled="{Binding CanUndo}"
                                       ToolTip="Undo the most recent pose edit (Ctrl+Z).">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowUndo24" FontSize="12" Margin="0,0,4,0" />
                                    <TextBlock Text="Undo" FontSize="11" />
                                    <TextBlock Text="{Binding UndoDepthLabel}" FontSize="10" Opacity="0.6" Margin="3,0,0,0" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Grid.Column="1"
                                       Click="OnRedoPose"
                                       Appearance="Secondary"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       Padding="0,5"
                                       Margin="3,0,3,0"
                                       IsEnabled="{Binding CanRedo}"
                                       ToolTip="Redo the most recently undone pose edit (Ctrl+Y).">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowRedo24" FontSize="12" Margin="0,0,4,0" />
                                    <TextBlock Text="Redo" FontSize="11" />
                                    <TextBlock Text="{Binding RedoDepthLabel}" FontSize="10" Opacity="0.6" Margin="3,0,0,0" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Grid.Column="2"
                                       Click="OnToggleDebugPanel"
                                       Appearance="Secondary"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       Padding="0,5"
                                       Margin="3,0,0,0"
                                       ToolTip="Open / close the event log. Press &#x0060; (backtick) inside the viewport for the in-viewer overlay.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Bug24" FontSize="12" Margin="0,0,4,0" />
                                    <TextBlock Text="{Binding DebugBadgeText}" FontSize="11" />
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                        <TextBlock Text="Motion Modifiers"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,2,0,6" />
                        <ui:Button Click="OnMirrorPose"
                                   Appearance="Secondary"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Center"
                                   Padding="0,6"
                                   Margin="0,0,0,6"
                                   IsEnabled="{Binding HasRig}"
                                   ToolTip="Copy left-side pose to the right side. Works on rigs with _L_ / _R_ or Left/Right bone naming.">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="FlipHorizontal24" FontSize="13" Margin="0,0,6,0" />
                                <TextBlock Text="Mirror L &lt;-&gt; R" />
                            </StackPanel>
                        </ui:Button>

                        <TextBlock Text="Timing" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,6,0,6" />
                        <ComboBox SelectedIndex="{Binding MovementIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,8"
                                  ToolTip="How the emote coexists with movement. To WALK while emoting the animation must be upper-body only (legs stay free) — that's how FiveM works.">
                            <ComboBoxItem Content="In place (full body)" ToolTip="Whole body plays; player locked in place. Dances / full poses. (flag 1/2)" />
                            <ComboBoxItem Content="Upper body (can move)" ToolTip="Only the upper body animates; legs keep walking/idling. Waves, salutes, gestures. (flag 49)" />
                            <ComboBoxItem Content="Walkable (moving)" ToolTip="Upper-body overlay tuned for moving around while it loops (dpemotes 'EmoteMoving'). (flag 51)" />
                            <ComboBoxItem Content="Root motion (ped travels)" ToolTip="Full body + mover extraction: the ped physically walks/moves along the recorded path. Needs the standalone resource export — dpemotes can't extract movers. (flag 786433)" />
                        </ComboBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0"
                                       Click="OnResetPose"
                                       Appearance="Secondary"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       Padding="0,6"
                                       Margin="0,0,4,0"
                                       IsEnabled="{Binding HasRig}"
                                       ToolTip="Reset every bone to its T-pose / bind pose. Clears the current pose; keyframes on the timeline are preserved.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowReset24" FontSize="13" Margin="0,0,6,0" />
                                    <TextBlock Text="Revert" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Grid.Column="1"
                                       Click="OnExportPose"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       Padding="0,6"
                                       Margin="4,0,0,0"
                                       IsEnabled="{Binding HasRig}"
                                       ToolTip="Export the pose (or full keyframed clip) as a FiveM-ready package.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Save24" FontSize="13" Margin="0,0,6,0" />
                                    <TextBlock Text="Export" />
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── Outliner slide-out (Blender N-panel) ───
                 A tab anchored to the sidebar's right edge plus a
                 width-bound panel that slides INTO the viewport when
                 the user clicks the tab. The tab stays put (clamped
                 to the sidebar's edge); only the panel grows / shrinks
                 between OutlinerPanelWidth = 0 (closed) and 280 (open).
                 The viewport column is `*` so the freed width snaps
                 back to the viewport when the panel folds away. -->
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />   <!-- Tab -->
                    <ColumnDefinition Width="Auto" /> <!-- Panel (width-bound below) -->
                </Grid.ColumnDefinitions>

                <!-- Tab — sits flush against the sidebar's right
                     border; vertical "OUTLINER" caption + chevron
                     that flips direction so the user can see which
                     way the next click expands. -->
                <Button Grid.Column="0"
                        Click="OnOutlinerToggleClick"
                        Cursor="Hand"
                        Focusable="False"
                        ToolTip="Show / hide the outliner panel.">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Tab"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderThickness="0,0,1,0"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    SnapsToDevicePixels="True">
                                <StackPanel Orientation="Vertical"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <ui:SymbolIcon x:Name="Chevron"
                                                   Symbol="ChevronRight12"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,0,8" />
                                    <TextBlock Text="OUTLINER"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="-90" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Tab" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    <Setter TargetName="Chevron" Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsOutlinerOpen}" Value="True">
                                    <Setter TargetName="Chevron" Property="Symbol" Value="ChevronLeft12" />
                                    <Setter TargetName="Tab" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Outliner panel — width binding lets the parent
                     Auto column shrink to just the tab when closed.
                     ClipToBounds keeps content from bleeding into the
                     viewport while the panel is mid-collapse. -->
                <Border Grid.Column="1"
                        Width="{Binding OutlinerPanelWidth}"
                        ClipToBounds="True"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderThickness="0,0,1,0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <Grid>
                        <!-- Empty state (no rig loaded) -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="20"
                                    Visibility="{Binding HasRig, Converter={StaticResource InverseBooleanToVisibility}}">
                            <ui:SymbolIcon Symbol="PersonStar24"
                                           FontSize="36"
                                           Opacity="0.35"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8" />
                            <TextBlock Text="Load a rigged model to see its skeleton."
                                       FontSize="11"
                                       Opacity="0.55"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="220" />
                        </StackPanel>

                        <Grid Visibility="{Binding HasRig, Converter={StaticResource BooleanToVisibility}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="200" />
                            </Grid.RowDefinitions>
                            <!-- Outliner header strip -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Padding="10,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Grid.Column="0"
                                                   Symbol="Stream24"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="Outliner"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center">
                                        <Run Text="{Binding BoneCountLabel, Mode=OneWay}" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <!-- Search box -->
                            <Border Grid.Row="1"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Padding="6,5">
                                <ui:TextBox x:Name="OutlinerSearchBox"
                                            Text="{Binding OutlinerFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="Search bones…"
                                            FontSize="11"
                                            TextChanged="OnOutlinerFilterChanged"
                                            ToolTip="Filter the bone outliner by name. Substring match, case-insensitive. Empty = show everything.">
                                    <ui:TextBox.Icon>
                                        <ui:SymbolIcon Symbol="Search24" />
                                    </ui:TextBox.Icon>
                                </ui:TextBox>
                            </Border>
                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <ItemsControl x:Name="BoneGroupsTree"
                                              ItemsSource="{Binding Rigs}"
                                              ItemTemplate="{StaticResource PoseRigTemplate}" />
                            </ScrollViewer>
                            <!-- ─── Clips library header + Bake action ───
                                 Sits beneath the bone tree, fixed-height
                                 list so the bones still get the elastic
                                 share of the panel. Bake button is gated
                                 on having at least 2 keyframes — single-
                                 frame clips have nothing to animate
                                 through and the JS baker would throw. -->
                            <Border Grid.Row="3"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderThickness="0,1,0,1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    Padding="10,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Grid.Column="0"
                                                   Symbol="VideoClipMultiple24"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="Clips"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ClipLibraryCountLabel}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="3"
                                               Click="OnBakeAsClipClick"
                                               IsEnabled="{Binding IsAnimatedExport}"
                                               ToolTip="Bake the current keyframe sequence into a reusable clip."
                                               Padding="6,2"
                                               FontSize="10">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Add24" FontSize="11" Margin="0,0,4,0" />
                                            <TextBlock Text="Bake" />
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </Border>
                            <!-- Clip list (or empty-state hint) -->
                            <Grid Grid.Row="4"
                                  Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <TextBlock Visibility="{Binding HasClipLibrary, Converter={StaticResource InverseBooleanToVisibility}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="220"
                                           Margin="16"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Text="Bake a 2+ keyframe pose or import an animated model to populate the clip library." />
                                <ListBox Visibility="{Binding HasClipLibrary, Converter={StaticResource BooleanToVisibility}}"
                                         ItemsSource="{Binding ClipLibrary}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:SymbolIcon Grid.Column="0"
                                                               Symbol="VideoClip24"
                                                               FontSize="13"
                                                               Margin="2,0,8,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock FontSize="9"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                        <Run Text="{Binding KindLabel, Mode=OneWay}" />
                                                        <Run Text="·" />
                                                        <Run Text="{Binding DurationLabel, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <ui:Button Grid.Column="2"
                                                           Appearance="Transparent"
                                                           Padding="2"
                                                           Margin="0,0,2,0"
                                                           Click="OnAddClipToTimelineClick"
                                                           Tag="{Binding Id}"
                                                           ToolTip="Add to timeline at the playhead">
                                                    <ui:SymbolIcon Symbol="Add24" FontSize="11" />
                                                </ui:Button>
                                                <ui:Button Grid.Column="3"
                                                           Appearance="Transparent"
                                                           Padding="2"
                                                           Click="OnDeleteClipClick"
                                                           Tag="{Binding Id}"
                                                           ToolTip="Remove from library">
                                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="11" />
                                                </ui:Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─── Viewport ─── -->
            <Grid Grid.Column="3">
                <wv2:WebView2 x:Name="Viewport" />
                <Border Background="#FF1E1E1E"
                        Visibility="{Binding HasModel, Converter={StaticResource InverseBooleanToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="380">
                        <Border Width="80" Height="80"
                                CornerRadius="40"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="PersonStar24" FontSize="36"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Pose -> Emote"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6" />
                        <TextBlock TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="12"
                                   Opacity="0.65"
                                   Text="Drop a rigged .glb / .fbx (player or ped with bones), pose the joints with the gizmo, then export to JSON. .ycd export is coming in a future build." />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ─── Inspector (right-side collapsible) ───
                 Mirrors the outliner's tab-and-slide-out pattern but
                 anchored to the viewport's right edge: panel grows
                 leftward when open, collapses to just the tab when
                 closed. Holds knobs for derived / auto features
                 (secondary motion today, future ML in-between +
                 ballistic ghost) that don't belong in the per-pose
                 sidebar on the left. -->
            <Grid Grid.Column="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /> <!-- Panel (width-bound) -->
                    <ColumnDefinition Width="28" />   <!-- Tab -->
                </Grid.ColumnDefinitions>

                <!-- Inspector panel — width binding lets the parent
                     Auto column shrink to just the tab when closed. -->
                <Border Grid.Column="0"
                        Width="{Binding InspectorPanelWidth}"
                        ClipToBounds="True"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderThickness="1,0,0,0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14,12,14,12">

                            <!-- Header strip -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Grid.Column="0"
                                               Symbol="Options24"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="Inspector"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- ═══ Secondary Motion ═══ -->
                            <ToggleButton Content="SECONDARY MOTION"
                                          IsChecked="True"
                                          Style="{StaticResource BlenderSectionHeader}" />
                            <StackPanel Margin="0,4,0,12">
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="11"
                                           Opacity="0.65"
                                           Margin="0,0,0,8"
                                           Text="Damped-spring follow-through on auto-detected secondary bones (head, hands, hair, spine tip, tail). Applies during playback only." />

                                <!-- Enabled toggle -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Enabled"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <ui:ToggleSwitch Grid.Column="1"
                                                     IsChecked="{Binding SecondaryMotionEnabled, Mode=TwoWay}"
                                                     ToolTip="Turn the damped-spring follow-through on / off. Off = bones snap exactly to the keyed rotation each frame." />
                                </Grid>

                                <!-- Intensity slider -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Intensity"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               FontFamily="Consolas"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center">
                                        <Run Text="{Binding SecondaryMotionIntensity, StringFormat={}{0:F2}, Mode=OneWay}" />
                                    </TextBlock>
                                </Grid>
                                <Slider Minimum="0"
                                        Maximum="1"
                                        SmallChange="0.05"
                                        LargeChange="0.1"
                                        TickFrequency="0.25"
                                        Value="{Binding SecondaryMotionIntensity, Mode=TwoWay}"
                                        IsEnabled="{Binding SecondaryMotionEnabled}"
                                        Margin="0,2,0,0"
                                        ToolTip="Spring tuning. Left = snappy (tight follow, no overshoot). Right = floaty (visible lag, soft bounce). 0.5 is the default soft natural feel." />
                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="snappy"
                                               FontSize="9"
                                               Opacity="0.5"
                                               HorizontalAlignment="Left" />
                                    <TextBlock Grid.Column="1"
                                               Text="floaty"
                                               FontSize="9"
                                               Opacity="0.5"
                                               HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>

                            <!-- ═══ Onion Skin ═══ -->
                            <ToggleButton Content="ONION SKIN"
                                          IsChecked="True"
                                          Style="{StaticResource BlenderSectionHeader}" />
                            <StackPanel Margin="0,4,0,12">
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="11"
                                           Opacity="0.65"
                                           Margin="0,0,0,8"
                                           Text="Ghost rigs at the previous and next keyframes around the scrubber. Helps see how the current pose relates to its neighbours." />
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Enabled"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <ui:ToggleSwitch Grid.Column="1"
                                                     IsChecked="{Binding OnionSkinEnabled, Mode=TwoWay}"
                                                     ToolTip="Show / hide the prev (orange-red) and next (teal) ghost rigs around the scrubber. Pure visual aid; doesn't affect playback." />
                                </Grid>
                                <!-- Legend chips: shows which colour means what -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <Border Width="9" Height="9"
                                            CornerRadius="2"
                                            Background="#FF6B47"
                                            VerticalAlignment="Center"
                                            Margin="0,0,5,0" />
                                    <TextBlock Text="prev"
                                               FontSize="10"
                                               Opacity="0.7"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0" />
                                    <Border Width="9" Height="9"
                                            CornerRadius="2"
                                            Background="#55D6BE"
                                            VerticalAlignment="Center"
                                            Margin="0,0,5,0" />
                                    <TextBlock Text="next"
                                               FontSize="10"
                                               Opacity="0.7"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <!-- ═══ Pose Library ═══
                                 Binds to the SAME CustomPoses collection
                                 the sidebar's "Save Pose" button writes
                                 to (via PoseLibraryService). One library,
                                 two access points — Inspector here for
                                 quick recall while the sidebar stays
                                 collapsed, sidebar list when the user
                                 wants to manage saved poses. -->
                            <ToggleButton Content="POSE LIBRARY"
                                          IsChecked="True"
                                          Style="{StaticResource BlenderSectionHeader}" />
                            <StackPanel Margin="0,4,0,12">
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="11"
                                           Opacity="0.65"
                                           Margin="0,0,0,8"
                                           Text="Saved poses from PoseLibrary. Click a row to apply; click the dismiss button to delete. Save new poses with the sidebar's Save Pose button." />

                                <!-- Save action — opens the same naming dialog
                                     as the sidebar's Save Pose so the entry
                                     ends up in CustomPoses. -->
                                <ui:Button Click="OnSaveCurrentPose"
                                           Appearance="Primary"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Center"
                                           Padding="0,5"
                                           Margin="0,0,0,8"
                                           ToolTip="Capture the current pose and save it to the library under a name you pick.">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Save24" FontSize="13" Margin="0,0,6,0" />
                                        <TextBlock Text="Save current pose" FontSize="11" />
                                    </StackPanel>
                                </ui:Button>

                                <!-- Empty-state hint -->
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="10"
                                           Opacity="0.45"
                                           FontStyle="Italic"
                                           Text="No poses saved yet. Pose the rig, click Save current pose."
                                           Visibility="{Binding HasCustomPoses, Converter={StaticResource InverseBooleanToVisibility}}" />

                                <!-- Saved poses list — same model + handlers
                                     the sidebar list uses, just rendered
                                     in the Inspector's narrower column. -->
                                <ItemsControl ItemsSource="{Binding CustomPoses}"
                                              Visibility="{Binding HasCustomPoses, Converter={StaticResource BooleanToVisibility}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="0"
                                                    Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="OnApplyCustomPose"
                                                            Tag="{Binding Slug}"
                                                            Cursor="Hand"
                                                            HorizontalContentAlignment="Stretch"
                                                            Padding="9,6"
                                                            ToolTip="Apply this saved pose to the rig.">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon Symbol="PersonStar24"
                                                                           FontSize="13"
                                                                           Foreground="#FF6B47"
                                                                           Margin="0,0,7,0"
                                                                           VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Grid.Column="1"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="OnDeleteCustomPose"
                                                            Tag="{Binding Slug}"
                                                            Cursor="Hand"
                                                            Padding="7,6"
                                                            ToolTip="Delete this saved pose.">
                                                        <ui:SymbolIcon Symbol="Dismiss24"
                                                                       FontSize="11"
                                                                       Opacity="0.6" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- ASSIST section (ML auto in-between +
                                 ballistic ghost) is HIDDEN until the
                                 features actually exist. Empty "coming
                                 soon" sections train users to ignore
                                 the Inspector. Restore Visibility when
                                 either feature ships. -->
                            <ToggleButton Content="ASSIST"
                                          IsChecked="False"
                                          Visibility="Collapsed"
                                          Style="{StaticResource BlenderSectionHeader}" />
                            <StackPanel Margin="0,4,0,4"
                                        Visibility="Collapsed">
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="11"
                                           Opacity="0.55"
                                           Text="Auto in-between (ML) and ballistic ghost (physics-aware pose overlay) — coming soon." />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Tab — vertical "INSPECTOR" caption + chevron,
                     anchored to the viewport's right edge. -->
                <Button Grid.Column="1"
                        Click="OnInspectorToggleClick"
                        Cursor="Hand"
                        Focusable="False"
                        ToolTip="Show / hide the inspector panel.">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Tab"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderThickness="1,0,0,0"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    SnapsToDevicePixels="True">
                                <StackPanel Orientation="Vertical"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <ui:SymbolIcon x:Name="Chevron"
                                                   Symbol="ChevronLeft12"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,0,8" />
                                    <TextBlock Text="INSPECTOR"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="-90" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Tab" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    <Setter TargetName="Chevron" Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsInspectorOpen}" Value="True">
                                    <Setter TargetName="Chevron" Property="Symbol" Value="ChevronRight12" />
                                    <Setter TargetName="Tab" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>

        <!-- ─── Timeline (Cascadeur-style clip editor) ─── -->
        <Border Grid.Row="2"
                Background="#FF181818"
                BorderThickness="0,1,0,0"
                BorderBrush="#FF454545"
                Visibility="{Binding HasRig, Converter={StaticResource BooleanToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ── Toolbar: key tools + transport + timecode ── -->
                <Border Grid.Row="0"
                        Background="#FF252526"
                        BorderBrush="#FF454545"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: keyframe tools -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <ui:Button Click="OnAddKeyframe"
                                       Appearance="Secondary"
                                       Padding="7,4"
                                       Margin="0,0,4,0"
                                       ToolTip="Set keyframe (K)">
                                <ui:SymbolIcon Symbol="Record28" FontSize="13" Foreground="#4A9EFF" />
                            </ui:Button>
                            <ui:Button Click="OnDeleteKeyframe"
                                       Appearance="Secondary"
                                       Padding="7,4"
                                       Margin="0,0,4,0"
                                       ToolTip="Delete keyframe">
                                <ui:SymbolIcon Symbol="Subtract24" FontSize="12" />
                            </ui:Button>
                            <ui:Button Click="OnClearKeyframes"
                                       Appearance="Secondary"
                                       Padding="7,4"
                                       Margin="0,0,10,0"
                                       ToolTip="Clear keyframes">
                                <ui:SymbolIcon Symbol="Delete24" FontSize="12" />
                            </ui:Button>
                            <TextBlock Text="{Binding AnimatedChipText}"
                                       FontSize="11"
                                       Foreground="#9A9A9A"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Center: timecode + transport -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding TimelineTimecodeLabel}"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       Foreground="#E8E8E8"
                                       VerticalAlignment="Center"
                                       Margin="0,0,14,0" />
                            <ui:Button Click="OnTimelineGoToStart"
                                       Appearance="Secondary"
                                       Padding="7,4"
                                       Margin="0,0,2,0"
                                       ToolTip="Go to start (Home)">
                                <ui:SymbolIcon Symbol="Previous24" FontSize="12" />
                            </ui:Button>
                            <ui:Button Click="OnTimelinePrevFrame"
                                       Appearance="Secondary"
                                       Padding="7,4"
                                       Margin="0,0,2,0"
                                       ToolTip="Previous frame (, )">
                                <TextBlock Text="◀" FontSize="10" />
                            </ui:Button>
                            <ui:Button Click="OnTimelinePlayPause"
                                       Appearance="Primary"
                                       Padding="10,4"
                                       Margin="0,0,2,0"
                                       ToolTip="Play / pause (Space)">
                                <ui:SymbolIcon x:Name="PlayIcon" Symbol="Play24" FontSize="13" />
                            </ui:Button>
                            <ui:Button Click="OnTimelineNextFrame"
                                       Appearance="Secondary"
                                       Padding="7,4"
                                       Margin="0,0,2,0"
                                       ToolTip="Next frame (. )">
                                <TextBlock Text="▶" FontSize="10" />
                            </ui:Button>
                            <ui:Button Click="OnTimelineGoToEnd"
                                       Appearance="Secondary"
                                       Padding="7,4"
                                       Margin="0,0,10,0"
                                       ToolTip="Go to end (End)">
                                <ui:SymbolIcon Symbol="Next24" FontSize="12" />
                            </ui:Button>
                            <ui:Button Click="OnTimelineLoopToggle"
                                       Appearance="Secondary"
                                       Padding="7,4"
                                       ToolTip="Loop">
                                <ui:SymbolIcon x:Name="LoopIcon" Symbol="ArrowRepeatAll24" FontSize="12" />
                            </ui:Button>
                        </StackPanel>

                        <!-- Right: trim tools -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <ui:Button Click="OnTimelineSetInClick"
                                       Appearance="Secondary"
                                       Padding="8,4"
                                       Margin="0,0,3,0"
                                       ToolTip="Trim start to playhead (I)">
                                <TextBlock Text="[ In" FontFamily="Consolas" FontSize="10" />
                            </ui:Button>
                            <ui:Button Click="OnTimelineSetOutClick"
                                       Appearance="Secondary"
                                       Padding="8,4"
                                       Margin="0,0,3,0"
                                       ToolTip="Trim end to playhead (O)">
                                <TextBlock Text="Out ]" FontFamily="Consolas" FontSize="10" />
                            </ui:Button>
                            <ui:Button Click="OnTimelineSplitClick"
                                       Appearance="Secondary"
                                       Padding="8,4"
                                       ToolTip="Split at playhead">
                                <ui:SymbolIcon Symbol="Cut24" FontSize="11" />
                            </ui:Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Sequencer body ───────────────────────────────── -->
                <Border Grid.Row="1"
                        x:Name="TimelineBorder"
                        Background="#1E1E1E"
                        SnapsToDevicePixels="True"
                        SizeChanged="OnTimelineSizeChanged">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="168" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Track list (Cascadeur left gutter) -->
                        <Border Grid.Column="0"
                                Background="#252525"
                                BorderBrush="#FF454545"
                                BorderThickness="0,0,1,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24" />
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="#2B2B2B"
                                        BorderBrush="#FF454545"
                                        BorderThickness="0,0,0,1"
                                        Padding="10,0,0,0">
                                    <TextBlock Text="Tracks"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#B0B0B0"
                                               VerticalAlignment="Center" />
                                </Border>

                                <Border Grid.Row="1"
                                        Background="#252525"
                                        BorderBrush="#FF454545"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#4A90C4" />
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="4,0,4,0">
                                            <ToggleButton Style="{StaticResource EyeToggle}"
                                                          IsChecked="{Binding TimelineClipTrackVisible, Mode=TwoWay}"
                                                          ToolTip="Show or hide the animation clip on the timeline and in playback" />
                                            <ToggleButton Style="{StaticResource LockToggle}"
                                                          IsChecked="{Binding TimelineClipTrackLocked, Mode=TwoWay}"
                                                          ToolTip="Lock clip — prevents trim and move (scrub still works)" />
                                            <TextBlock Text="{Binding PrimaryTrackLabel}"
                                                       FontSize="11"
                                                       Foreground="#E0E0E0"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2"
                                        Visibility="{Binding ShowTimelineKeyframes, Converter={StaticResource BooleanToVisibility}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#5BBFB5" />
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="4,0,4,0"
                                                    Height="34">
                                            <ToggleButton Style="{StaticResource EyeToggle}"
                                                          IsChecked="{Binding TimelineKeyframeTrackVisible, Mode=TwoWay}"
                                                          ToolTip="Show or hide the keyframe lane" />
                                            <ToggleButton Style="{StaticResource LockToggle}"
                                                          IsChecked="{Binding TimelineKeyframeTrackLocked, Mode=TwoWay}"
                                                          ToolTip="Lock keyframes — prevents drag and delete" />
                                            <TextBlock Text="Keyframes"
                                                       FontSize="11"
                                                       Foreground="#E0E0E0"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Ruler + tracks + playhead -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24" />
                                <RowDefinition Height="34" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Canvas Grid.Row="0"
                                    x:Name="TimelineRulerCanvas"
                                    Background="#2B2B2B"
                                    ClipToBounds="True"
                                    Cursor="Hand"
                                    MouseWheel="OnTimelineMouseWheel"
                                    MouseLeftButtonDown="OnTimelineSeekClick"
                                    MouseMove="OnTimelineSeekMove"
                                    MouseLeftButtonUp="OnTimelineSeekUp" />

                            <Canvas Grid.Row="1"
                                    x:Name="TimelineStripCanvas"
                                    Background="#1E1E1E"
                                    ClipToBounds="True"
                                    Cursor="Hand"
                                    MouseWheel="OnTimelineMouseWheel"
                                    MouseLeftButtonDown="OnTimelineSeekClick"
                                    MouseMove="OnTimelineSeekMove"
                                    MouseLeftButtonUp="OnTimelineSeekUp" />

                            <Canvas Grid.Row="2"
                                    x:Name="TimelineTrackCanvas"
                                    Background="#1A1A1A"
                                    ClipToBounds="True"
                                    Height="34"
                                    Visibility="{Binding ShowTimelineKeyframes, Converter={StaticResource BooleanToVisibility}}"
                                    MouseLeftButtonDown="OnTimelineSeekClick"
                                    MouseMove="OnTimelineSeekMove"
                                    MouseLeftButtonUp="OnTimelineSeekUp" />

                            <Canvas Grid.Row="0"
                                    Grid.RowSpan="3"
                                    x:Name="TimelinePlayheadCanvas"
                                    IsHitTestVisible="False"
                                    ClipToBounds="True" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- ── Bottom range bar ─────────────────────────────── -->
                <Border Grid.Row="2"
                        Background="#232323"
                        BorderBrush="#FF454545"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="10,0">
                        <TextBlock Text="{Binding TimelineCurrentFrame, StringFormat='Frame {0}'}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="#888888"
                                   VerticalAlignment="Center" />
                        <Border Background="#1A1A1A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="1"
                                CornerRadius="2"
                                Height="14"
                                Margin="90,0,200,0"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                            <Border Background="#4A90C4"
                                    Opacity="0.35"
                                    HorizontalAlignment="Stretch" />
                        </Border>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="0"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="#888888"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding TimelineTotalFrames}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="#888888"
                                       Margin="0,0,12,0" />
                            <StackPanel Orientation="Horizontal">
                                <ui:NumberBox Value="{Binding TimelineDuration, Mode=TwoWay}"
                                              Minimum="0.1"
                                              Maximum="60"
                                              SmallChange="0.1"
                                              LargeChange="1"
                                              Width="64"
                                              ClearButtonEnabled="False"
                                              SpinButtonPlacementMode="Compact"
                                              FontSize="11"
                                              Margin="0,0,4,0"
                                              ToolTip="Duration (seconds)" />
                                <TextBlock Text="s @"
                                           FontSize="11"
                                           Foreground="#666666"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <ui:NumberBox Value="{Binding TimelineFps, Mode=TwoWay}"
                                              Minimum="1"
                                              Maximum="120"
                                              SmallChange="1"
                                              LargeChange="10"
                                              Width="48"
                                              ClearButtonEnabled="False"
                                              SpinButtonPlacementMode="Compact"
                                              FontSize="11"
                                              ToolTip="FPS" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Shortcut hints (advanced only) -->
                <Border Grid.Row="3"
                        Background="#1A1A1A"
                        Padding="10,3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="10"
                                   Foreground="#5C637A"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="Shortcuts:" FontWeight="SemiBold" Foreground="#7A8195" />
                            <Run Text="Space" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="play  ·" />
                            <Run Text="← → , ." FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="step 1f  ·" />
                            <Run Text="Shift+" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="step 10f  ·" />
                            <Run Text="↑ ↓" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="prev/next KF  ·" />
                            <Run Text="Home / End" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="ends  ·" />
                            <Run Text="/" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="loop  ·" />
                            <Run Text="K" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="capture  ·" />
                            <Run Text="Del" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="remove KF  ·" />
                            <Run Text="Shift+Del" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="clear all" />
                        </TextBlock>
                        <TextBlock Grid.Column="1"
                                   FontSize="10"
                                   Foreground="#5C637A"
                                   Margin="12,0,0,0">
                            <Run Text="M" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="mirror  ·" />
                            <Run Text="Ctrl+Z/Y" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="undo/redo  ·" />
                            <Run Text="Shift+X/Y/Z" FontFamily="Consolas" Foreground="#D8DEEF" />
                            <Run Text="axis lock" />
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ─── Workspace loading overlay ───
             Full-bleed splash that sits on top of the sidebar / viewport /
             timeline while the WebView2 host spins up and the default
             skeleton imports, so the user never sees the empty WebView
             flash through. Hidden the moment pose-mode-entered fires (rig
             ready, joint markers built). Theme brushes only — overlay must
             read as part of the app chrome, not a separate blue surface. -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Panel.ZIndex="100"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                Visibility="{Binding IsViewerLoading, Converter={StaticResource BooleanToVisibility}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="420">
                <Image Source="pack://application:,,,/Assets/Branding/FiveOS.png"
                       Width="112" Height="112"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,18" />
                <TextBlock Text="Pose → Emote"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />
                <TextBlock Text="Booting workspace..."
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,22" />
                <ctrl:DotMatrixLoader LoaderStyle="HelixGlow"
                                      DotSize="8"
                                      DotSpacing="4"
                                      DotColor="{DynamicResource TextFillColorPrimaryBrush}"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,12" />
                <TextBlock Text="{Binding ViewerLoadingCaption}"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Opacity="0.9"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
