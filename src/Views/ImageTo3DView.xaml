<UserControl x:Class="FiveOS.Views.ImageTo3DView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:FiveOS.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ImageTo3DViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ───────── Hero panel ───────── -->
        <Grid Grid.Row="0">
            <Border Margin="32,24,32,12"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    Padding="40,32">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="620">

                    <!-- ImageSparkle24 is in the SymbolRegular enum but the
                         Wpf.Ui 3.0.5 bundled Fluent Icons font doesn't ship
                         a glyph for it, so it falls back to rendering the
                         literal "Dz" digraph (U+01C5). Sparkle24 is a safe,
                         long-standing icon that conveys the AI-generation
                         motif. -->
                    <ui:SymbolIcon Symbol="Sparkle24"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Opacity="0.85"
                                   Margin="0,0,0,12" />

                    <TextBlock Text="AI → 3D"
                               FontSize="26"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="Pick a provider, hand it an image (or a prompt), get a GLB."
                               FontSize="13"
                               Opacity="0.75"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,6,0,0" />

                    <TextBlock Text="Output saves to ~/Downloads/FiveOS_meshes/generated/ — open in 3D Model to convert."
                               FontSize="11"
                               Opacity="0.55"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,2,0,20" />

                    <!-- ─── Provider picker ─── -->
                    <TextBlock Text="PROVIDER"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Opacity="0.55"
                               Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Providers}"
                              SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              HorizontalAlignment="Stretch"
                              IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolean}}"
                              ToolTip="Which AI service to use. Each provider has its own quality / speed / cost tradeoff and needs an API key under Settings → API keys. Switching providers is safe — the input you typed/picked carries over." />
                    <TextBlock Text="{Binding ProviderTagline}"
                               FontSize="11"
                               Opacity="0.65"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />

                    <!-- ─── Mode toggle (image / text) ─── -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,0"
                                Visibility="{Binding ShowModeToggle, Converter={StaticResource BooleanToVisibility}}">
                        <RadioButton Content="From image"
                                     GroupName="ImageTo3DMode"
                                     Padding="12,4"
                                     Margin="0,0,8,0"
                                     IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolean}}"
                                     IsChecked="{Binding IsImageMode, Mode=OneWay}"
                                     Click="OnModeImage"
                                     ToolTip="Generate a 3D model FROM a reference image (PNG / JPG). The image goes to the provider, which returns a textured GLB." />
                        <RadioButton Content="From text"
                                     GroupName="ImageTo3DMode"
                                     Padding="12,4"
                                     IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolean}}"
                                     IsChecked="{Binding IsTextMode, Mode=OneWay}"
                                     Click="OnModeText"
                                     ToolTip="Generate a 3D model from a written prompt instead of an image. Not all providers support this mode." />
                    </StackPanel>

                    <!-- ─── Image action ─── -->
                    <ui:Button Content="Generate from image..."
                               Appearance="Primary"
                               Padding="24,10"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"
                               IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolean}}"
                               Visibility="{Binding IsImageMode, Converter={StaticResource BooleanToVisibility}}"
                               Click="OnGenerateFromImage"
                               ToolTip="Pick a reference image and send it to the selected provider. The resulting GLB lands in ~/Downloads/FiveOS_meshes/generated/ and the next step is to drop it on the 3D Model tab to convert.">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="ArrowUpload24" />
                        </ui:Button.Icon>
                    </ui:Button>

                    <!-- ─── Text action ─── -->
                    <StackPanel Margin="0,16,0,0"
                                Visibility="{Binding IsTextMode, Converter={StaticResource BooleanToVisibility}}">
                        <ui:TextBox Text="{Binding TextPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="A low-poly red sports car, isometric view"
                                    AcceptsReturn="False"
                                    IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolean}}"
                                    ToolTip="Describe what you want. Style hints help (&quot;low-poly&quot;, &quot;isometric&quot;, &quot;PBR materials&quot;, &quot;1k tris&quot;). Keep it under ~100 chars — most providers do better with focused prompts than essays." />
                        <ui:Button Content="Generate from prompt"
                                   Appearance="Primary"
                                   Padding="24,10"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"
                                   IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolean}}"
                                   Click="OnGenerateFromText"
                                   ToolTip="Send the prompt to the selected provider. Output is a GLB in ~/Downloads/FiveOS_meshes/generated/.">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Wand24" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>

                    <ui:Button Content="Edit API key for this provider"
                               Appearance="Transparent"
                               HorizontalAlignment="Center"
                               Padding="6,2"
                               FontSize="11"
                               Margin="0,8,0,0"
                               Click="OnEditProviderKey"
                               ToolTip="Jump straight to Settings → API keys with this provider highlighted. Save a key there before trying to generate." />

                    <!-- ─── Progress block ─── -->
                    <StackPanel Margin="0,20,0,0"
                                Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibility}}">
                        <TextBlock Text="{Binding GenerationStatus}"
                                   FontSize="12"
                                   Opacity="0.85"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                        <ProgressBar Value="{Binding GenerationProgress}"
                                     Maximum="1"
                                     Height="4"
                                     Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- ─── Last result ─── -->
                    <Border Margin="0,20,0,0"
                            CornerRadius="6"
                            Padding="12,10"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsGenerating}" Value="False" />
                                            <Condition Binding="{Binding HasLastOutput}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <!-- (Static thumbnail removed — the interactive 3D
                                 preview pane on the right replaces it.) -->
                            <TextBlock Text="✓ Generated"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LastOutputPath}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Opacity="0.7"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,8" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <ui:Button Content="Texture with AI"
                                           Appearance="Primary"
                                           Padding="10,4"
                                           FontSize="11"
                                           Margin="0,0,8,0"
                                           Click="OnTextureWithAi"
                                           Visibility="{Binding ShowTextureButton, Converter={StaticResource BooleanToVisibility}}"
                                           IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolean}}"
                                           ToolTip="Run the AI texturing pass on this model (Meshy refine). Text-to-3D previews come out untextured — this adds materials and colour, replacing the current result with the textured version.">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="Sparkle24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Content="Reveal in Explorer"
                                           Appearance="Secondary"
                                           Padding="10,4"
                                           FontSize="11"
                                           Click="OnRevealOutput"
                                           ToolTip="Open the output folder with the generated GLB selected — drag it onto the 3D Model tab to convert it into a FiveM .ydr." />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ───────── Footer hint ───────── -->
        <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Padding="16,10">
            <TextBlock FontSize="11"
                       Opacity="0.6"
                       TextAlignment="Center"
                       Text="API keys are managed under Settings → API keys. Each provider stores its own credential separately." />
        </Border>
    </Grid>
</UserControl>
