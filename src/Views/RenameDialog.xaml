<ui:FluentWindow x:Class="FiveOS.Views.RenameDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Rename"
                 Width="400"
                 SizeToContent="Height"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Rename" ShowMaximize="False" ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="16,4,16,0">
            <TextBlock x:Name="PromptText" Text="New name:" FontSize="12" Opacity="0.8" Margin="0,0,0,6" />
            <ui:TextBox x:Name="NameBox" FontFamily="Consolas" FontSize="13" />
            <TextBlock x:Name="HintText" Text="" FontSize="11" Opacity="0.55" TextWrapping="Wrap" Margin="0,6,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,12,12">
            <ui:Button Content="Cancel" Appearance="Secondary" Padding="16,5" Margin="0,0,8,0" Click="OnCancel" />
            <ui:Button x:Name="OkButton" Content="Rename" Appearance="Primary" Padding="16,5" Click="OnOk" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
